<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Ariadne.Desktop.Controls.EmptyStateArt"
             Width="140" Height="112"
             IsHitTestVisible="False">
  <!-- 模型线描空态 + Accent 重着色；无手写 Path 堆砌 -->
  <Panel>
    <Image x:Name="ArtImage"
           Stretch="Uniform"
           HorizontalAlignment="Center"
           VerticalAlignment="Center" />

    <!-- 次要页仍用轻量线描（非三主空态） -->
    <Viewbox x:Name="WelcomeQuillArt" Stretch="Uniform" IsVisible="False">
      <Canvas Width="80" Height="64">
        <Path Stroke="{DynamicResource Ariadne.AccentPrimary}" StrokeThickness="1.7" StrokeLineCap="Round"
              Data="M38,8 L32,52" />
        <Path Stroke="{DynamicResource Ariadne.AccentPrimary}" StrokeThickness="1.5" StrokeLineCap="Round"
              Data="M32,52 L28,58 M32,52 L36,58" />
        <Path Stroke="{DynamicResource Ariadne.TextSubtle}" StrokeThickness="1.4" StrokeLineCap="Round"
              Data="M38,10 C48,4 58,12 54,24 C50,34 40,36 34,30 C28,24 30,14 38,10" />
        <Path Stroke="{DynamicResource Ariadne.AccentPrimary}" StrokeThickness="1.35" StrokeLineCap="Round"
              Data="M24,36 C32,28 44,30 50,38 C56,46 46,52 38,48 C32,46 28,52 34,56" />
      </Canvas>
    </Viewbox>

    <Viewbox x:Name="RunLogArt" Stretch="Uniform" IsVisible="False">
      <Canvas Width="80" Height="64">
        <Path Stroke="{DynamicResource Ariadne.TextSubtle}" StrokeThickness="1.4" StrokeLineCap="Round"
              Data="M18,14 L62,14 M18,26 L54,26 M18,38 L58,38 M18,50 L48,50" />
        <Path Stroke="{DynamicResource Ariadne.AccentPrimary}" StrokeThickness="2" StrokeLineCap="Round"
              Data="M12,14 L12,14.01 M12,26 L12,26.01 M12,38 L12,38.01 M12,50 L12,50.01" />
      </Canvas>
    </Viewbox>

    <Viewbox x:Name="TemplatesArt" Stretch="Uniform" IsVisible="False">
      <Canvas Width="80" Height="64">
        <Path Stroke="{DynamicResource Ariadne.AccentPrimary}" StrokeThickness="1.5" StrokeLineCap="Round"
              Data="M16,12 L36,12 L36,32 L16,32 Z M44,12 L64,12 L64,32 L44,32 Z M16,40 L36,40 L36,56 L16,56 Z" />
        <Path Stroke="{DynamicResource Ariadne.TextSubtle}" StrokeThickness="1.3" StrokeLineCap="Round"
              Data="M44,40 L64,40 L64,56 L44,56 Z M20,18 L32,18 M20,24 L28,24" />
      </Canvas>
    </Viewbox>

    <Viewbox x:Name="ProjectAiArt" Stretch="Uniform" IsVisible="False">
      <Canvas Width="80" Height="64">
        <Path Stroke="{DynamicResource Ariadne.AccentPrimary}" StrokeThickness="1.6" StrokeLineCap="Round"
              Data="M18,14 L54,14 Q60,14 60,20 L60,34 Q60,40 54,40 L34,40 L24,50 L26,40 L18,40 Q12,40 12,34 L12,20 Q12,14 18,14 Z" />
        <Path Stroke="{DynamicResource Ariadne.TextSubtle}" StrokeThickness="1.3" StrokeLineCap="Round"
              Data="M22,24 L50,24 M22,32 L42,32" />
      </Canvas>
    </Viewbox>
  </Panel>
</UserControl>
