<Window
    x:Class="Ariadne.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="clr-namespace:Ariadne.Desktop.Controls"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:MainWindowViewModel"
    Width="1280"
    Height="800"
    MinWidth="1120"
    MinHeight="700"
    CanResize="True"
    UseLayoutRounding="True"
    TextElement.FontSize="14"
    TextOptions.TextRenderingMode="SubpixelAntialias"

    RenderOptions.BitmapInterpolationMode="HighQuality"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaTitleBarHeightHint="-1"
    WindowDecorations="None"
    TransparencyLevelHint="Mica, AcrylicBlur"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    Title="{Binding AppName}">

  <!-- 外层圆角窗体：Mica 透出壁纸微光，内容浮在其上 -->
  <Border
      Background="{DynamicResource Ariadne.WindowBase}"
      BorderBrush="{DynamicResource Ariadne.BorderStrong}"
      BorderThickness="1"
      CornerRadius="10"
      ClipToBounds="True">
    <Panel>
    <Grid RowDefinitions="40,*">

      <!-- ================= 顶栏（自定义标题栏 + 项目 + 预算） ================= -->
      <Grid
          Grid.Row="0"
          ColumnDefinitions="Auto,*,Auto,Auto"
          Background="Transparent"
          PointerPressed="OnTitleBarPointerPressed">

        <!-- 品牌 + 项目 chip -->
        <StackPanel
            Grid.Column="0"
            Orientation="Horizontal"
            Spacing="10"
            Margin="14,0"
            VerticalAlignment="Center">
          <!-- 斜钢笔 + 波浪线；强调色底 + 反色笔画，均随个性化 token -->
          <ctl:BrandLogo Width="24" Height="24" OnAccent="True" VerticalAlignment="Center" />
          <TextBlock
              Text="{Binding AppName}"
              Foreground="{DynamicResource Ariadne.TextPrimary}"
              FontWeight="SemiBold"
              VerticalAlignment="Center" />
          <Button Classes="subtle" Padding="0" VerticalAlignment="Center" ToolTip.Tip="{Binding ProjectMenuText}">
            <Border Classes="chip">
              <TextBlock
                  Text="{Binding ProjectTitle}"
                  Classes="caption"
                  VerticalAlignment="Center" />
            </Border>
            <Button.Flyout>
              <!-- 项目菜单：全局 MenuFlyoutPresenter 毛玻璃样式 -->
              <MenuFlyout Placement="BottomEdgeAlignedLeft">
                <MenuItem Header="{Binding CreateProjectText}" Command="{Binding CreateProjectCommand}" />
                <MenuItem Header="{Binding OpenProjectText}" Command="{Binding OpenProjectCommand}" />
                <MenuItem Header="{Binding SwitchProjectText}" Command="{Binding SwitchProjectCommand}" />
                <Separator />
                <ItemsControl ItemsSource="{Binding ProjectMenuItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProjectMenuItemViewModel}">
                      <MenuItem Header="{Binding Name}" Command="{Binding OpenCommand}" ToolTip.Tip="{Binding ProjectRoot}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Separator />
                <MenuItem Header="{Binding LeaveProjectText}" Command="{Binding LeaveProjectCommand}"
                          IsEnabled="{Binding HasOpenProject}" Classes="danger" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>

        <!-- 中段：后端连接状态 -->
        <TextBlock
            Grid.Column="1"
            Text="{Binding HeaderStatusText}"
            Classes="subtle"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,18,0" />

        <!-- 预算条 -->
        <StackPanel
            Grid.Column="2"
            Orientation="Horizontal"
            Spacing="8"
            VerticalAlignment="Center"
            Margin="0,0,12,0">
          <TextBlock Text="{Binding BudgetLabel}" Classes="caption" VerticalAlignment="Center" />
          <ProgressBar
              Width="92"
              Height="8"
              Minimum="0"
              Maximum="100"
              Value="{Binding BudgetUsagePercent}"
              VerticalAlignment="Center" />
          <TextBlock Text="{Binding BudgetStatusText}" Classes="caption" VerticalAlignment="Center" />
        </StackPanel>

        <!-- 窗口控制（矢量 Path，不依赖字体） -->
        <StackPanel Grid.Column="3" Orientation="Horizontal">
          <Button
              Classes="window-control"
              ToolTip.Tip="{Binding MinimizeWindowText}"
              Click="OnMinimizeClicked">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Minimize}" />
          </Button>
          <Button
              Classes="window-control"
              ToolTip.Tip="{Binding MaximizeWindowText}"
              Click="OnMaximizeClicked">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Maximize}" />
          </Button>
          <Button
              Classes="window-control close"
              ToolTip.Tip="{Binding CloseWindowText}"
              Click="OnCloseClicked">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Close}" />
          </Button>
        </StackPanel>
      </Grid>

      <!-- ================= 主体：侧栏 + 内容 ================= -->
      <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

        <!-- 左侧栏 -->
        <Border
            Grid.Column="0"
            Width="{Binding SidebarWidth}"
            Background="{DynamicResource Ariadne.BackgroundSurface}"
            BorderBrush="{DynamicResource Ariadne.BorderMuted}"
            BorderThickness="0,0,1,0">
          <DockPanel Margin="0,4,0,0">

            <!-- 折叠按钮 -->
            <Button
                DockPanel.Dock="Top"
                Classes="subtle"
                Margin="10,2,10,6"
                HorizontalAlignment="Left"
                Width="36"
                Height="32"
                Command="{Binding ToggleSidebarCommand}"
                ToolTip.Tip="{Binding ToggleSidebarText}">
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Menu}" />
            </Button>

            <!-- 底部：版本 + 反馈 -->
            <StackPanel DockPanel.Dock="Bottom" Margin="10,8,10,14" Spacing="2">
              <Separator Margin="2,6" />
              <Button Classes="nav" Command="{Binding OpenVersionCommand}">
                <Grid ColumnDefinitions="30,*">
                  <Path Grid.Column="0" Classes="icon" Data="{StaticResource Ariadne.Icon.Info}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding VersionText}" Classes="caption" VerticalAlignment="Center" />
                </Grid>
              </Button>
              <Button Classes="nav" Command="{Binding OpenFeedbackCommand}">
                <Grid ColumnDefinitions="30,*">
                  <Path Grid.Column="0" Classes="icon" Data="{StaticResource Ariadne.Icon.Feedback}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding FeedbackText}" Classes="caption" VerticalAlignment="Center" />
                </Grid>
              </Button>
            </StackPanel>

            <!-- 导航：上组 →(大间距分隔)→ 下组，顺排靠上，不置底 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <!-- 左右 0 边距：悬停横条贴齐左栏左缘，不留缝 -->
              <StackPanel Margin="0,4,0,0" Spacing="0">
                <ItemsControl ItemsSource="{Binding PrimaryNavigationItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NavigationItemViewModel}">
                      <Button Classes="nav" ctl:SelectedClass.IsSelected="{Binding IsSelected}" Command="{Binding SelectCommand}">
                        <Grid ColumnDefinitions="3,26,*,Auto" Margin="0,0,10,0">
                          <!-- 选中竖条贴左缘 -->
                          <Border
                              Grid.Column="0"
                              Width="3"
                              VerticalAlignment="Stretch"
                              IsVisible="{Binding IsSelected}"
                              Background="{DynamicResource Ariadne.AccentPrimary}" />
                          <Path Grid.Column="1" Classes="icon" Width="17" Height="17" Data="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0,0,0" />
                          <TextBlock Grid.Column="2" Text="{Binding Title}" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0" />
                          <Border Grid.Column="3" Classes="badge" IsVisible="{Binding HasBadge}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding BadgeCount}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Border>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Height="52" VerticalAlignment="Center">
                  <Border Height="1" Margin="12,0" VerticalAlignment="Center" Background="{DynamicResource Ariadne.BorderMuted}" />
                </Grid>

                <ItemsControl ItemsSource="{Binding SecondaryNavigationItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NavigationItemViewModel}">
                      <Button Classes="nav" ctl:SelectedClass.IsSelected="{Binding IsSelected}" Command="{Binding SelectCommand}">
                        <Grid ColumnDefinitions="3,26,*,Auto" Margin="0,0,10,0">
                          <Border
                              Grid.Column="0"
                              Width="3"
                              VerticalAlignment="Stretch"
                              IsVisible="{Binding IsSelected}"
                              Background="{DynamicResource Ariadne.AccentPrimary}" />
                          <Path Grid.Column="1" Classes="icon" Width="17" Height="17" Data="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0,0,0" />
                          <TextBlock Grid.Column="2" Text="{Binding Title}" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0" />
                          <Border Grid.Column="3" Classes="badge" IsVisible="{Binding HasBadge}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding BadgeCount}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Border>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Border>

        <!-- 内容区 -->
        <ContentControl
            Grid.Column="1"
            Content="{Binding CurrentPage}" />
      </Grid>
      <!-- ================= 全局弹窗遮罩（Win11 半透明 scrim） ================= -->
      <Border x:Name="DialogScrim"
              Grid.Row="1"
              Background="{DynamicResource Ariadne.Scrim}"
              IsVisible="{Binding Dialog.IsOpen}"
              PointerPressed="OnDialogScrimPressed">
        <ContentControl Content="{Binding Dialog.ActiveDialog}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="40"
                        FontFamily="{DynamicResource Ariadne.Font.Ui}" />
      </Border>
    </Grid>
    </Panel>
  </Border>
</Window>
