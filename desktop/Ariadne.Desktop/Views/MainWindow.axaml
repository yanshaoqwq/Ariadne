<Window
    x:Class="Ariadne.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="clr-namespace:Ariadne.Desktop.Controls"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:MainWindowViewModel"
    Width="1280"
    Height="800"
    MinWidth="720"
    MinHeight="480"
    CanResize="True"
    UseLayoutRounding="True"
    TextElement.FontSize="14"
    TextOptions.TextRenderingMode="SubpixelAntialias"

    RenderOptions.BitmapInterpolationMode="HighQuality"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaTitleBarHeightHint="-1"
    WindowDecorations="None"
    TransparencyLevelHint="Mica, AcrylicBlur"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    Title="{Binding AppName}">

  <!-- 外层圆角窗体：最大化时圆角/边框归零（U61） -->
  <Border
      x:Name="WindowChrome"
      Background="{DynamicResource Ariadne.WindowBase}"
      BorderBrush="{DynamicResource Ariadne.BorderStrong}"
      BorderThickness="1"
      CornerRadius="10"
      ClipToBounds="True">
    <Panel>
    <Grid RowDefinitions="40,Auto,Auto,*">

      <!-- ================= 顶栏（自定义标题栏 + 项目 + 预算） ================= -->
      <Grid
          Grid.Row="0"
          ColumnDefinitions="Auto,*,Auto,Auto"
          Background="Transparent"
          PointerPressed="OnTitleBarPointerPressed">

        <!-- 品牌 + 项目 chip：限宽 + 省略号（U43） -->
        <StackPanel
            Grid.Column="0"
            Orientation="Horizontal"
            Spacing="10"
            Margin="14,0"
            VerticalAlignment="Center"
            MaxWidth="360">
          <ctl:BrandLogo Width="24" Height="24" OnAccent="True" VerticalAlignment="Center" />
          <TextBlock
              Text="{Binding AppName}"
              Foreground="{DynamicResource Ariadne.TextPrimary}"
              FontWeight="SemiBold"
              VerticalAlignment="Center" />
          <Button Classes="subtle" Padding="0" VerticalAlignment="Center"
                  ToolTip.Tip="{Binding ProjectMenuText}"
                  AutomationProperties.Name="{Binding ProjectMenuText}">
            <Border Classes="chip" MaxWidth="220">
              <TextBlock
                  Text="{Binding ProjectTitle}"
                  Classes="caption"
                  VerticalAlignment="Center"
                  TextTrimming="CharacterEllipsis"
                  MaxWidth="200"
                  ToolTip.Tip="{Binding ProjectTitle}" />
            </Border>
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedLeft">
                <MenuItem Header="{Binding CreateProjectText}" Command="{Binding CreateProjectCommand}" />
                <MenuItem Header="{Binding OpenProjectText}" Command="{Binding OpenProjectCommand}" />
                <MenuItem Header="{Binding SwitchProjectText}" Command="{Binding SwitchProjectCommand}" />
                <Separator />
                <ItemsControl ItemsSource="{Binding ProjectMenuItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProjectMenuItemViewModel}">
                      <MenuItem Header="{Binding Name}" Command="{Binding OpenCommand}" ToolTip.Tip="{Binding ProjectRoot}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Separator />
                <MenuItem Header="{Binding LeaveProjectText}" Command="{Binding LeaveProjectCommand}"
                          IsEnabled="{Binding HasOpenProject}" Classes="danger" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>

        <!-- 中段：短状态 + 省略（U43） -->
        <TextBlock
            Grid.Column="1"
            Text="{Binding HeaderStatusText}"
            Classes="subtle"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="8,0,12,0"
            TextTrimming="CharacterEllipsis"
            MaxWidth="280"
            ToolTip.Tip="{Binding HeaderStatusText}" />

        <!-- 预算条：文本限宽 -->
        <StackPanel
            Grid.Column="2"
            Orientation="Horizontal"
            Spacing="8"
            VerticalAlignment="Center"
            Margin="0,0,8,0">
          <TextBlock Text="{Binding BudgetLabel}" Classes="caption" VerticalAlignment="Center" />
          <ProgressBar
              Width="72"
              Height="8"
              Minimum="0"
              Maximum="100"
              Value="{Binding BudgetUsagePercent}"
              VerticalAlignment="Center" />
          <TextBlock Text="{Binding BudgetStatusText}"
                     Classes="caption"
                     VerticalAlignment="Center"
                     MaxWidth="100"
                     TextTrimming="CharacterEllipsis"
                     ToolTip.Tip="{Binding BudgetStatusText}" />
        </StackPanel>

        <!-- 窗口控制：与 40px 顶栏垂直居中；最小化横条略偏下以对齐 max/close 视觉中心 -->
        <StackPanel
            Grid.Column="3"
            Orientation="Horizontal"
            Spacing="2"
            Margin="0,0,4,0"
            VerticalAlignment="Center"
            HorizontalAlignment="Right">
          <Button
              Classes="window-control"
              ToolTip.Tip="{Binding MinimizeWindowText}"
              AutomationProperties.Name="{Binding MinimizeWindowText}"
              Click="OnMinimizeClicked">
            <Path Classes="icon minimize" Data="{StaticResource Ariadne.Icon.Minimize}" />
          </Button>
          <Button
              Classes="window-control"
              ToolTip.Tip="{Binding MaximizeWindowText}"
              AutomationProperties.Name="{Binding MaximizeWindowText}"
              Click="OnMaximizeClicked">
            <Path x:Name="MaximizeRestoreIcon"
                  Classes="icon"
                  Data="{StaticResource Ariadne.Icon.Maximize}" />
          </Button>
          <Button
              Classes="window-control close"
              ToolTip.Tip="{Binding CloseWindowText}"
              AutomationProperties.Name="{Binding CloseWindowText}"
              Click="OnCloseClicked">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Close}" />
          </Button>
        </StackPanel>
      </Grid>

      <!-- D3：项目维护门禁横幅（active/failed） -->
      <Border Grid.Row="1"
              IsVisible="{Binding IsMaintenanceBlocking}"
              Background="{DynamicResource Ariadne.LogWarningBg}"
              BorderBrush="{DynamicResource Ariadne.StatusWarning}"
              BorderThickness="0,0,0,1"
              Padding="12,6">
        <TextBlock Text="{Binding MaintenanceBannerText}"
                   TextWrapping="Wrap"
                   Classes="body"
                   Foreground="{DynamicResource Ariadne.StatusWarning}" />
      </Border>

      <!-- U1：默认只显示本地化摘要，作者主动展开后才显示脱敏诊断。 -->
      <Border Grid.Row="2"
              IsVisible="{Binding HasDiagnostic}"
              Background="{DynamicResource Ariadne.LogWarningBg}"
              BorderBrush="{DynamicResource Ariadne.StatusWarning}"
              BorderThickness="0,0,0,1"
              Padding="12,6">
        <StackPanel Spacing="6">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0" Text="{Binding DiagnosticTitleText}"
                       Classes="caption" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="{Binding DiagnosticSummaryText}"
                       Classes="caption" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
            <Button Grid.Column="2" Classes="subtle" Command="{Binding ToggleDiagnosticCommand}"
                    Content="{Binding DiagnosticToggleText}"
                    AutomationProperties.Name="{Binding DiagnosticToggleText}" />
            <Button Grid.Column="3" Classes="subtle" Command="{Binding ClearDiagnosticCommand}"
                    Content="{Binding DiagnosticClearText}"
                    AutomationProperties.Name="{Binding DiagnosticClearText}" />
          </Grid>
          <Border IsVisible="{Binding IsDiagnosticExpanded}"
                  Background="{DynamicResource Ariadne.BackgroundSubtle}"
                  BorderBrush="{DynamicResource Ariadne.BorderMuted}"
                  BorderThickness="1" CornerRadius="4" Padding="8">
            <TextBlock Text="{Binding DiagnosticDetailText}" Classes="caption"
                       TextWrapping="Wrap" MaxHeight="96" />
          </Border>
        </StackPanel>
      </Border>

      <!-- ================= 主体：侧栏 + 内容 ================= -->
      <Grid Grid.Row="3" ColumnDefinitions="Auto,*">

        <!-- 左侧栏：折叠时仅图标（U66） -->
        <Border
            Grid.Column="0"
            Width="{Binding SidebarWidth}"
            Background="{DynamicResource Ariadne.BackgroundSubtle}"
            BorderBrush="{DynamicResource Ariadne.BorderMuted}"
            BorderThickness="0,0,1,0">
          <DockPanel Margin="0,4,0,0">

            <Button
                DockPanel.Dock="Top"
                Classes="subtle"
                Margin="8,2,8,6"
                HorizontalAlignment="Left"
                Width="36"
                Height="32"
                Command="{Binding ToggleSidebarCommand}"
                ToolTip.Tip="{Binding ToggleSidebarText}"
                AutomationProperties.Name="{Binding ToggleSidebarText}">
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Menu}" />
            </Button>

            <!-- 底部：版本 + 反馈 -->
            <StackPanel DockPanel.Dock="Bottom" Margin="4,8,4,14" Spacing="2">
              <Separator Margin="2,6" />
              <Button Classes="nav"
                      Command="{Binding OpenVersionCommand}"
                      ToolTip.Tip="{Binding VersionToolTipText}"
                      AutomationProperties.Name="{Binding VersionText}">
                <Panel>
                  <!-- 展开 -->
                  <Grid ColumnDefinitions="30,*" IsVisible="{Binding SidebarExpanded}">
                    <Path Grid.Column="0" Classes="icon" Data="{StaticResource Ariadne.Icon.Info}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding VersionText}" Classes="caption" VerticalAlignment="Center" />
                  </Grid>
                  <!-- 折叠 -->
                  <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Info}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsVisible="{Binding SidebarCollapsed}" />
                </Panel>
              </Button>
              <Button Classes="nav"
                      Command="{Binding OpenFeedbackCommand}"
                      ToolTip.Tip="{Binding FeedbackToolTipText}"
                      AutomationProperties.Name="{Binding FeedbackText}">
                <Panel>
                  <Grid ColumnDefinitions="30,*" IsVisible="{Binding SidebarExpanded}">
                    <Path Grid.Column="0" Classes="icon" Data="{StaticResource Ariadne.Icon.Feedback}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding FeedbackText}" Classes="caption" VerticalAlignment="Center" />
                  </Grid>
                  <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Feedback}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsVisible="{Binding SidebarCollapsed}" />
                </Panel>
              </Button>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Margin="0,4,0,0" Spacing="6">
                <!-- U66：模板在 App.DataTemplates（NavigationItemViewModel 单源） -->
                <ItemsControl ItemsSource="{Binding PrimaryNavigationItems}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Spacing="6" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>

                <Grid Height="52" VerticalAlignment="Center">
                  <Border Height="1" Margin="12,0" VerticalAlignment="Center" Background="{DynamicResource Ariadne.BorderMuted}" />
                </Grid>

                <ItemsControl ItemsSource="{Binding SecondaryNavigationItems}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Spacing="6" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Border>

        <ContentControl
            Grid.Column="1"
            Content="{Binding CurrentPage}" />
      </Grid>
      <!-- ================= 全局弹窗遮罩 ================= -->
      <Border x:Name="DialogScrim"
              Grid.Row="1"
              Grid.RowSpan="3"
              Background="{DynamicResource Ariadne.Scrim}"
              IsVisible="{Binding Dialog.IsOpen}"
              PointerPressed="OnDialogScrimPressed">
        <ContentControl Content="{Binding Dialog.ActiveDialog}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="24"
                        MaxHeight="{Binding $parent[Border].Bounds.Height}"
                        FontFamily="{DynamicResource Ariadne.Font.Ui}" />
      </Border>
    </Grid>
    </Panel>
  </Border>
</Window>
