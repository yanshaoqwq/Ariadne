<UserControl
    x:Class="Ariadne.Desktop.Views.ConfirmDialogView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:ConfirmDialogViewModel"
    FontFamily="{DynamicResource Ariadne.Font.Ui}">
  <!-- Win11 毛玻璃弹窗：半透明 tint + 亮边 + 柔阴影；高度上限 + 正文滚动（U68） -->
  <Panel>
    <ExperimentalAcrylicBorder CornerRadius="14" IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
            BackgroundSource="Digger"
            TintColor="{DynamicResource Ariadne.Color.GlassTint}"
            TintOpacity="0.82"
            MaterialOpacity="0.9" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <Border
        x:Name="DialogChrome"
        Classes="glass-dialog"
        MaxWidth="480"
        MinWidth="360"
        MaxHeight="520"
        Padding="26,24">
      <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14">
        <!-- 头部：语义图标 + 标题（U63） -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
          <Border Width="36" Height="36" CornerRadius="10"
                  Background="{DynamicResource Ariadne.AccentLight}"
                  BorderBrush="{DynamicResource Ariadne.AccentBorder}"
                  BorderThickness="1"
                  VerticalAlignment="Top">
            <Path x:Name="SeverityIcon"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Width="18" Height="18" Stretch="Uniform"
                  StrokeThickness="1.6"
                  Fill="Transparent"
                  Data="M12,3 L22,20 L2,20 Z M12,9 L12,14 M12,16.5 L12,17.5" />
          </Border>
          <TextBlock Text="{Binding Title}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     FontFamily="{DynamicResource Ariadne.Font.Ui}"
                     Foreground="{DynamicResource Ariadne.TextHeading}"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap" />
        </StackPanel>

        <!-- 正文 + 可选输入：可滚动，底部按钮始终可见 -->
        <ScrollViewer x:Name="BodyScroll"
                      Grid.Row="1"
                      MaxHeight="320"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding Message}"
                       FontSize="13.5"
                       FontFamily="{DynamicResource Ariadne.Font.Ui}"
                       Foreground="{DynamicResource Ariadne.TextSecondary}"
                       TextWrapping="Wrap"
                       Margin="48,0,0,0"
                       LineHeight="22" />

            <StackPanel Spacing="6" Margin="48,0,0,0" IsVisible="{Binding HasInput}">
              <TextBlock Text="{Binding InputLabel}"
                         Classes="caption"
                         FontFamily="{DynamicResource Ariadne.Font.Ui}" />
              <TextBox x:Name="InputBox"
                       Text="{Binding InputText, Mode=TwoWay}"
                       PlaceholderText="{Binding InputPlaceholder}"
                       MinHeight="38"
                       FontSize="14"
                       FontFamily="{DynamicResource Ariadne.Font.Ui}"
                       CornerRadius="8"
                       MaxLength="80" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>

        <!-- 按钮组：可换行，始终贴底 -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Buttons}" Margin="0,4,0,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:DialogButton}">
              <Button Classes.primary="{Binding IsPrimary}"
                      Classes.danger="{Binding IsDanger}"
                      Classes.subtle="{Binding IsSubtle}"
                      IsDefault="{Binding IsDefault}"
                      IsCancel="{Binding IsCancel}"
                      MinWidth="84"
                      MinHeight="34"
                      Margin="6,4,0,0"
                      Padding="16,8"
                      FontSize="13"
                      FontFamily="{DynamicResource Ariadne.Font.Ui}"
                      Content="{Binding Text}"
                      Command="{Binding Command}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>
  </Panel>
</UserControl>
