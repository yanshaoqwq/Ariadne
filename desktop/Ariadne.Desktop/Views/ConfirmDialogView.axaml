<UserControl
    x:Class="Ariadne.Desktop.Views.ConfirmDialogView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:ConfirmDialogViewModel">
  <!-- 弹窗卡片：Win11 风格圆角 + 阴影；宿主遮罩负责居中与半透明背景。 -->
  <Border
      MaxWidth="440"
      MinWidth="380"
      Background="{DynamicResource Ariadne.BackgroundElevated}"
      BorderBrush="{DynamicResource Ariadne.BorderDefault}"
      BorderThickness="1"
      CornerRadius="12"
      BoxShadow="0 12 40 0 #33140A00"
      Padding="24,22">
    <StackPanel Spacing="14">
      <!-- 头部：警示图标 + 标题 -->
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Border Width="34" Height="34" CornerRadius="8"
                Background="{DynamicResource Ariadne.AccentLight}"
                VerticalAlignment="Top">
          <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="18" Height="18" Stretch="Uniform"
                Fill="{DynamicResource Ariadne.StatusWarning}"
                Data="M12,3 L22,20 L2,20 Z M12,9 L12,14 M12,16.5 L12,17.5" />
        </Border>
        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource Ariadne.TextHeading}"
                   VerticalAlignment="Center" TextWrapping="Wrap" />
      </StackPanel>

      <!-- 正文 -->
      <TextBlock Text="{Binding Message}" FontSize="13"
                 Foreground="{DynamicResource Ariadne.TextSecondary}"
                 TextWrapping="Wrap" Margin="46,0,0,0" LineHeight="20" />

      <!-- 按钮组：右对齐，按变体套样式 -->
      <ItemsControl ItemsSource="{Binding Buttons}" Margin="0,6,0,0">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:DialogButton}">
            <Button Classes.primary="{Binding IsPrimary}"
                    Classes.danger="{Binding IsDanger}"
                    Classes.subtle="{Binding IsSubtle}"
                    MinWidth="76" Padding="14,7"
                    Content="{Binding Text}" Command="{Binding Command}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</UserControl>
