<UserControl
    x:Class="Ariadne.Desktop.Views.ConfirmDialogView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:ConfirmDialogViewModel"
    FontFamily="{DynamicResource Ariadne.Font.Ui}">
  <!-- Win11 毛玻璃弹窗：半透明 tint + 亮边 + 柔阴影；字体统一 Ui -->
  <Panel>
    <!-- 可选真实模糊层（窗口已开 Mica/AcrylicBlur 时 digger 生效） -->
    <ExperimentalAcrylicBorder CornerRadius="14" IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
            BackgroundSource="Digger"
            TintColor="{DynamicResource Ariadne.Color.GlassTint}"
            TintOpacity="0.82"
            MaterialOpacity="0.9" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <Border
        Classes="glass-dialog"
        MaxWidth="460"
        MinWidth="380"
        Padding="26,24">
      <StackPanel Spacing="16">
        <!-- 头部：图标 + 标题 -->
        <StackPanel Orientation="Horizontal" Spacing="12">
          <Border Width="36" Height="36" CornerRadius="10"
                  Background="{DynamicResource Ariadne.AccentLight}"
                  BorderBrush="{DynamicResource Ariadne.AccentBorder}"
                  BorderThickness="1"
                  VerticalAlignment="Top">
            <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                  Width="18" Height="18" Stretch="Uniform"
                  Fill="{DynamicResource Ariadne.StatusWarning}"
                  Data="M12,3 L22,20 L2,20 Z M12,9 L12,14 M12,16.5 L12,17.5" />
          </Border>
          <TextBlock Text="{Binding Title}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     FontFamily="{DynamicResource Ariadne.Font.Ui}"
                     Foreground="{DynamicResource Ariadne.TextHeading}"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap" />
        </StackPanel>

        <!-- 正文 -->
        <TextBlock Text="{Binding Message}"
                   FontSize="13.5"
                   FontFamily="{DynamicResource Ariadne.Font.Ui}"
                   Foreground="{DynamicResource Ariadne.TextSecondary}"
                   TextWrapping="Wrap"
                   Margin="48,0,0,0"
                   LineHeight="22" />

        <!-- 可选输入（新建项目名称等） -->
        <StackPanel Spacing="6" Margin="48,0,0,0" IsVisible="{Binding HasInput}">
          <TextBlock Text="{Binding InputLabel}"
                     Classes="caption"
                     FontFamily="{DynamicResource Ariadne.Font.Ui}" />
          <TextBox Text="{Binding InputText, Mode=TwoWay}"
                   PlaceholderText="{Binding InputPlaceholder}"
                   MinHeight="38"
                   FontSize="14"
                   FontFamily="{DynamicResource Ariadne.Font.Ui}"
                   CornerRadius="8" />
        </StackPanel>

        <!-- 按钮组 -->
        <ItemsControl ItemsSource="{Binding Buttons}" Margin="0,4,0,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:DialogButton}">
              <Button Classes.primary="{Binding IsPrimary}"
                      Classes.danger="{Binding IsDanger}"
                      Classes.subtle="{Binding IsSubtle}"
                      MinWidth="84"
                      MinHeight="34"
                      Padding="16,8"
                      FontSize="13"
                      FontFamily="{DynamicResource Ariadne.Font.Ui}"
                      Content="{Binding Text}"
                      Command="{Binding Command}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>
  </Panel>
</UserControl>
