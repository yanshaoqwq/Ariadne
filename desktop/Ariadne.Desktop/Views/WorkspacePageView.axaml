<UserControl
    x:Class="Ariadne.Desktop.Views.WorkspacePageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="clr-namespace:Ariadne.Desktop.Controls"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:WorkspacePageViewModel">
  <!-- 根 Panel：拖库 ghost 叠在最上层且不裁剪 -->
  <Panel Background="{DynamicResource Ariadne.BackgroundMain}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="{Binding RightPanelSplitterWidth}" />
      <!-- MinWidth 随开合：收起为 0，避免残留窄条 + 第二枚展开钮 -->
      <ColumnDefinition Width="{Binding RightPanelColumnWidth, Mode=TwoWay}" MinWidth="0" MaxWidth="560" />
    </Grid.ColumnDefinitions>

    <Grid x:Name="WorkspaceGrid" Grid.Column="0" RowDefinitions="*,Auto,220">
      <!-- Grid 宿主：工具栏/空态始终可见；Canvas 只放节点层 -->
      <Grid x:Name="CanvasHost" Grid.Row="0"
            Background="{DynamicResource Ariadne.CanvasBackground}"
            ClipToBounds="True">
        <Grid.ContextMenu>
          <ContextMenu Classes="ariadne">
            <MenuItem Header="{Binding CtxAddNodeText}" Command="{Binding AddContextNodeCommand}" />
            <Separator />
            <MenuItem Header="{Binding UndoText}" Command="{Binding UndoCommand}" />
            <MenuItem Header="{Binding RedoText}" Command="{Binding RedoCommand}" />
            <Separator />
            <MenuItem Header="{Binding CtxCopyText}" Command="{Binding CopySelectedNodeCommand}" />
            <MenuItem Header="{Binding CtxCutText}" Command="{Binding CutSelectedNodeCommand}" />
            <MenuItem Header="{Binding CtxPasteText}" Command="{Binding PasteNodeCommand}" />
            <Separator />
            <MenuItem Header="{Binding CtxFitViewText}" Command="{Binding FitViewCommand}" />
            <Separator />
            <MenuItem Header="{Binding CtxDeleteText}" Command="{Binding DeleteSelectedNodeCommand}" />
          </ContextMenu>
        </Grid.ContextMenu>

        <!-- 节点/边坐标系：铺满宿主（修复嵌套 Canvas 时 ItemsControl 尺寸为 0） -->
        <Canvas x:Name="CanvasOverlay"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                PointerPressed="OnCanvasBackgroundPointerPressed"
                PointerMoved="OnCanvasBackgroundPointerMoved"
                PointerReleased="OnCanvasBackgroundPointerReleased"
                PointerCaptureLost="OnCanvasBackgroundCaptureLost"
                PointerWheelChanged="OnCanvasPointerWheel">
        <ItemsControl x:Name="EdgesItemsControl" ItemsSource="{Binding Edges}">
          <ItemsControl.RenderTransform>
            <TransformGroup>
              <ScaleTransform ScaleX="{Binding CanvasZoom}" ScaleY="{Binding CanvasZoom}" />
              <TranslateTransform />
            </TransformGroup>
          </ItemsControl.RenderTransform>
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <Canvas />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:WorkflowEdgeViewModel}">
              <Canvas>
                <!-- 宽透明命中层：点选边进入属性编辑 -->
                <Path Stroke="#01000000"
                      StrokeThickness="14"
                      Fill="Transparent"
                      Data="{Binding EdgePath}"
                      Cursor="Hand"
                      PointerPressed="OnEdgePointerPressed" />
                <Path Stroke="{Binding StrokeBrush}"
                      StrokeThickness="{Binding StrokeThickness}"
                      Opacity="{Binding StrokeOpacity}"
                      Fill="Transparent"
                      StrokeLineCap="Round"
                      Data="{Binding EdgePath}"
                      IsHitTestVisible="False" />
                <Border Canvas.Left="{Binding LabelX}"
                        Canvas.Top="{Binding LabelY}"
                        Background="{DynamicResource Ariadne.BackgroundSurface}"
                        BorderBrush="{DynamicResource Ariadne.BorderMuted}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="5,1"
                        Opacity="0.92"
                        Cursor="Hand"
                        IsVisible="{Binding HasMidpointLabel}"
                        PointerPressed="OnEdgePointerPressed">
                  <TextBlock Text="{Binding MidpointLabel}"
                             Classes="caption"
                             FontSize="10"
                             MaxWidth="72"
                             TextTrimming="CharacterEllipsis" />
                </Border>
              </Canvas>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 端口拖线橡皮筋预览（与落点同坐标系） -->
        <Path x:Name="RubberBandPath"
              Stroke="{DynamicResource Ariadne.EdgeData}"
              StrokeThickness="1.8"
              StrokeDashArray="5,3"
              Opacity="0.85"
              IsVisible="False"
              IsHitTestVisible="False" />

        <!-- 左键拖空白处框选 -->
        <Border x:Name="MarqueeRect"
                IsVisible="False"
                IsHitTestVisible="False"
                BorderBrush="{DynamicResource Ariadne.AccentPrimary}"
                BorderThickness="1.5"
                Background="#222E726B"
                CornerRadius="2"
                ZIndex="50" />

        <ItemsControl x:Name="NodesItemsControl" ItemsSource="{Binding Nodes}">
          <ItemsControl.RenderTransform>
            <TransformGroup>
              <ScaleTransform ScaleX="{Binding CanvasZoom}" ScaleY="{Binding CanvasZoom}" />
              <TranslateTransform />
            </TransformGroup>
          </ItemsControl.RenderTransform>
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <Canvas />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:WorkflowNodeViewModel}">
              <!--
                单卡片节点（宽 200）：执行/数据引脚在节点内侧边；
                通信口在顶中略出框；未连空心 / 已连实心。
                几何常量见 NodePortSpec（连线必须对齐）。
              -->
              <Grid Width="200"
                    ctl:SelectedClass.IsSelected="{Binding IsSelected}">
                <Grid.RowDefinitions>
                  <RowDefinition Height="10" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 通信：顶中圆角玻璃方块 -->
                <Border Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Width="14" Height="14"
                        Margin="0,0,0,-6"
                        CornerRadius="4"
                        Classes="pin-glass"
                        Background="{Binding PortCommunicationFill}"
                        BorderBrush="{DynamicResource Ariadne.EdgeCommunication}"
                        BorderThickness="1.2"
                        Opacity="{Binding PortCommunicationOpacity}"
                        Cursor="Cross"
                        Tag="communication|both"
                        ToolTip.Tip="{Binding $parent[UserControl].DataContext.PortCommunicationTip}"
                        PointerPressed="OnPortPointerPressed"
                        PointerMoved="OnPortPointerMoved"
                        PointerReleased="OnPortPointerReleased"
                        ZIndex="3" />

                <!-- 选中环：外扩 = 描边宽 2.5，内侧贴紧卡片外缘 -->
                <Border Grid.Row="1"
                        Classes="node-flow-ring"
                        Margin="-2.5"
                        CornerRadius="12"
                        IsHitTestVisible="False"
                        IsVisible="{Binding IsSelected}" />

                <!-- 整卡：标题 + 内容，引脚都在内侧 -->
                <Border Grid.Row="1"
                        Background="{DynamicResource Ariadne.NodeBackground}"
                        BorderBrush="{Binding NodeBorderBrush}"
                        BorderThickness="1.4"
                        CornerRadius="10"
                        BoxShadow="{DynamicResource Ariadne.Shadow.Card}"
                        ClipToBounds="True"
                        PointerPressed="OnNodeSelectPointerPressed">
                  <DockPanel>
                    <!-- 标题栏：左执行入 / 文案 / 运行 / 右执行出 -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource Ariadne.AccentLight}"
                            Padding="6,7"
                            Cursor="SizeAll"
                            PointerPressed="OnNodePointerPressed"
                            PointerMoved="OnNodePointerMoved"
                            PointerReleased="OnNodePointerReleased"
                            PointerCaptureLost="OnNodePointerCaptureLost">
                      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="6">
                        <Border Grid.Column="0"
                                Width="16" Height="16"
                                VerticalAlignment="Center"
                                Classes="pin-glass-soft"
                                CornerRadius="3"
                                Opacity="{Binding PortControlInOpacity}"
                                Cursor="Cross"
                                Tag="control|in"
                                ToolTip.Tip="{Binding $parent[UserControl].DataContext.PortControlInTip}"
                                PointerPressed="OnPortPointerPressed"
                                PointerMoved="OnPortPointerMoved"
                                PointerReleased="OnPortPointerReleased">
                          <Path Width="11" Height="11" Stretch="Uniform"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Stroke="{DynamicResource Ariadne.AccentPrimary}"
                                StrokeThickness="1.4"
                                Fill="{Binding PortControlInFill}"
                                Data="M3,2.5 L12,7 L3,11.5 Z" />
                        </Border>
                        <Border Grid.Column="1" Width="3" Height="14" CornerRadius="1"
                                Background="{Binding TypeAccentBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Label}"
                                   FontWeight="SemiBold" FontSize="12"
                                   Foreground="{DynamicResource Ariadne.AccentPrimary}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="3" Width="22" Height="20" Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="{DynamicResource Ariadne.BackgroundSurface}"
                                BorderBrush="{DynamicResource Ariadne.AccentPrimary}"
                                BorderThickness="1"
                                CornerRadius="4"
                                IsVisible="{Binding IsStartNode}"
                                Command="{Binding RunCommand}">
                          <Path Width="8" Height="8" Stretch="Uniform"
                                Fill="{DynamicResource Ariadne.AccentPrimary}"
                                Data="M9,6 L18,12 L9,18 Z" />
                        </Button>
                        <Border Grid.Column="4"
                                Width="16" Height="16"
                                VerticalAlignment="Center"
                                Classes="pin-glass-soft"
                                CornerRadius="3"
                                Opacity="{Binding PortControlOutOpacity}"
                                Cursor="Cross"
                                Tag="control|out"
                                ToolTip.Tip="{Binding $parent[UserControl].DataContext.PortControlOutTip}"
                                PointerPressed="OnPortPointerPressed"
                                PointerMoved="OnPortPointerMoved"
                                PointerReleased="OnPortPointerReleased">
                          <Path Width="11" Height="11" Stretch="Uniform"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Stroke="{DynamicResource Ariadne.AccentPrimary}"
                                StrokeThickness="1.4"
                                Fill="{Binding PortControlOutFill}"
                                Data="M3,2.5 L12,7 L3,11.5 Z" />
                        </Border>
                      </Grid>
                    </Border>

                    <!-- 内容栏：数据入顶对齐 + Spacing=8（14+8=22=DataPortSpacing），与 LocalCenter 一致 -->
                    <Border Padding="6,8" MinHeight="44">
                      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                        <ItemsControl Grid.Column="0"
                                      VerticalAlignment="Top"
                                      ItemsSource="{Binding DataInPins}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <!-- 间距 8：与 NodePortSpec.DataPortSpacing(22)=14+8 对齐 -->
                              <StackPanel Spacing="8" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NodeDataInPinViewModel}">
                              <Border Width="14" Height="14"
                                      Classes="pin-glass"
                                      CornerRadius="7"
                                      Cursor="Cross"
                                      Tag="{Binding PortTag}"
                                      ToolTip.Tip="{Binding Handle}"
                                      PointerPressed="OnPortPointerPressed"
                                      PointerMoved="OnPortPointerMoved"
                                      PointerReleased="OnPortPointerReleased">
                                <Ellipse Width="9" Height="9"
                                         Stroke="{DynamicResource Ariadne.EdgeData}"
                                         StrokeThickness="1.3"
                                         Fill="{Binding FillBrush}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Top" Margin="0,0,0,0">
                          <TextBlock Text="{Binding Name}" Classes="caption" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding ImportPathDisplay}" Classes="caption mono"
                                     TextTrimming="CharacterEllipsis" Opacity="0.85"
                                     IsVisible="{Binding IsImportNode}" />
                          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                            <Ellipse Grid.Column="0" Width="6" Height="6"
                                     Fill="{Binding StatusIndicatorBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                                       Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                          </Grid>
                        </StackPanel>
                        <!-- 数据出与首个数据入同一顶对齐基线 -->
                        <Border Grid.Column="2"
                                Width="14" Height="14"
                                VerticalAlignment="Top"
                                Classes="pin-glass"
                                CornerRadius="7"
                                Opacity="{Binding PortDataOutOpacity}"
                                Cursor="Cross"
                                Tag="data|out"
                                ToolTip.Tip="{Binding $parent[UserControl].DataContext.PortDataOutTip}"
                                PointerPressed="OnPortPointerPressed"
                                PointerMoved="OnPortPointerMoved"
                                PointerReleased="OnPortPointerReleased">
                          <Ellipse Width="9" Height="9"
                                   Stroke="{DynamicResource Ariadne.EdgeData}"
                                   StrokeThickness="1.3"
                                   Fill="{Binding PortDataOutFill}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                      </Grid>
                    </Border>
                  </DockPanel>
                </Border>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        </Canvas>

        <!-- 空画布提示（有节点时隐藏） -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding !HasNodes}"
                IsHitTestVisible="False"
                MaxWidth="360"
                Padding="20">
          <StackPanel Spacing="10" HorizontalAlignment="Center">
            <ctl:EmptyStateArt Kind="Workspace" Width="140" Height="112" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding EmptyCanvasTitle}" Classes="subtitle" HorizontalAlignment="Center" TextAlignment="Center" />
            <TextBlock Text="{Binding EmptyCanvasHint}" Classes="caption" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Opacity="0.9" />
          </StackPanel>
        </Border>

        <!-- 工具栏：右上固定，不依赖 Canvas.Right -->
        <StackPanel x:Name="TopToolbar"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,16,0"
                    Orientation="Horizontal"
                    Spacing="4">
          <Button Classes="icon-btn" ToolTip.Tip="{Binding UndoText}" AutomationProperties.Name="{Binding UndoText}" Command="{Binding UndoCommand}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Undo}" />
          </Button>
          <Button Classes="icon-btn" ToolTip.Tip="{Binding RedoText}" AutomationProperties.Name="{Binding RedoText}" Command="{Binding RedoCommand}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Redo}" />
          </Button>
          <Button Classes="icon-btn" ToolTip.Tip="{Binding ImportText}" AutomationProperties.Name="{Binding ImportText}" Command="{Binding ImportCommand}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Import}" />
          </Button>
          <Button Classes="icon-btn" ToolTip.Tip="{Binding ExportText}" AutomationProperties.Name="{Binding ExportText}" Command="{Binding ExportCommand}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Export}" />
          </Button>
          <Button Classes="icon-btn save"
                  ToolTip.Tip="{Binding SaveToolTipText}"
                  AutomationProperties.Name="{Binding SaveToolTipText}"
                  Command="{Binding SaveCommand}">
            <Panel>
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Save}" />
              <!-- W5：脏状态角标 -->
              <Ellipse Width="7" Height="7"
                       HorizontalAlignment="Right" VerticalAlignment="Top"
                       Margin="0,2,2,0"
                       Fill="{DynamicResource Ariadne.AccentPrimary}"
                       IsVisible="{Binding HasUnsavedChanges}" />
            </Panel>
          </Button>
          <Border Width="1" Height="20" Margin="4,6" Background="{DynamicResource Ariadne.BorderMuted}" />
          <Button Classes="icon-btn" ToolTip.Tip="{Binding ZoomOutText}" AutomationProperties.Name="{Binding ZoomOutText}" Command="{Binding ZoomOutCommand}">
            <TextBlock Text="{Binding ZoomOutGlyphText}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
          <Button Classes="subtle" MinWidth="58" Padding="8,0" ToolTip.Tip="{Binding ResetZoomText}" AutomationProperties.Name="{Binding ResetZoomText}" Command="{Binding ResetZoomCommand}">
            <TextBlock Text="{Binding CanvasZoomText}" Classes="caption" VerticalAlignment="Center" />
          </Button>
          <Button Classes="icon-btn" ToolTip.Tip="{Binding ZoomInText}" AutomationProperties.Name="{Binding ZoomInText}" Command="{Binding ZoomInCommand}">
            <TextBlock Text="{Binding ZoomInGlyphText}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
        </StackPanel>

        <TextBlock HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"
                   Margin="18,0,0,18"
                   Text="{Binding StatusText}"
                   Classes="caption"
                   IsHitTestVisible="False" />

        <Border x:Name="MiniMapHost"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,16,34"
                Width="156"
                Height="100"
                Background="{DynamicResource Ariadne.BackgroundSurface}"
                BorderBrush="{DynamicResource Ariadne.BorderMuted}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8"
                Opacity="0.9"
                Cursor="Hand"
                ToolTip.Tip="{Binding MinimapText}"
                PointerPressed="OnMiniMapPointerPressed">
          <Canvas x:Name="MiniMapCanvas"
                  Width="140"
                  Height="84"
                  ClipToBounds="True"
                  Background="Transparent">
            <!-- 显式尺寸 + Canvas 面板；位置由 code-behind ContainerFromItem 写入（绑定 Canvas.Left 对容器无效） -->
            <ItemsControl x:Name="MiniMapItemsControl"
                          Canvas.Left="0"
                          Canvas.Top="0"
                          Width="140"
                          Height="84"
                          ItemsSource="{Binding Nodes}"
                          IsHitTestVisible="False">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <Canvas Width="140" Height="84" ClipToBounds="True" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:WorkflowNodeViewModel}">
                  <Border Width="10"
                          Height="6"
                          CornerRadius="2"
                          Background="{Binding TypeAccentBrush}"
                          BorderBrush="{DynamicResource Ariadne.BackgroundSurface}"
                          BorderThickness="1"
                          IsHitTestVisible="False" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Border x:Name="MiniMapViewportFrame"
                    BorderBrush="{DynamicResource Ariadne.AccentPrimary}"
                    BorderThickness="1.5"
                    Background="#182E726B"
                    CornerRadius="2"
                    IsHitTestVisible="False"
                    Width="40"
                    Height="28" />
          </Canvas>
        </Border>

        <!-- pill  freelayout：用绝对 Canvas 叠在宿主上 -->
        <Canvas x:Name="PillLayer" IsHitTestVisible="True">
          <Border x:Name="LibraryTogglePill"
                  Canvas.Bottom="0"
                  Width="52"
                  Height="22"
                  Background="{DynamicResource Ariadne.BackgroundSurface}"
                  BorderBrush="{DynamicResource Ariadne.BorderDefault}"
                  BorderThickness="1"
                  CornerRadius="6,6,0,0"
                  BoxShadow="0 -2 6 0 #10000000"
                  Cursor="Hand"
                  ToolTip.Tip="{Binding BottomPanelToggleText}"
                  PointerPressed="OnPillPointerPressed"
                  PointerMoved="OnPillPointerMoved"
                  PointerReleased="OnPillPointerReleased">
            <!-- W16：开=收起(上)，关=展开(下)；tooltip 随节点库/执行模式 -->
            <Panel>
              <Path Classes="icon" Width="14" Height="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="{Binding BottomPanelShowsCollapseGlyph}"
                    Data="{StaticResource Ariadne.Icon.ChevronUp}" />
              <Path Classes="icon" Width="14" Height="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="{Binding !BottomPanelShowsCollapseGlyph}"
                    Data="{StaticResource Ariadne.Icon.ChevronDown}" />
            </Panel>
          </Border>

          <Border x:Name="WorkspaceRightPill"
                  Canvas.Right="0"
                  Width="22"
                  Height="52"
                  Background="{DynamicResource Ariadne.BackgroundSurface}"
                  BorderBrush="{DynamicResource Ariadne.BorderDefault}"
                  BorderThickness="1"
                  CornerRadius="8,0,0,8"
                  Cursor="Hand"
                  ToolTip.Tip="{Binding ToggleRightPanelText}"
                  PointerPressed="OnRightPillPointerPressed"
                  PointerMoved="OnRightPillPointerMoved"
                  PointerReleased="OnRightPillPointerReleased">
            <Panel>
              <Path Classes="icon" Width="14" Height="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="{Binding IsRightPanelOpen}"
                    Data="{StaticResource Ariadne.Icon.ChevronRight}" />
              <Path Classes="icon" Width="14" Height="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="{Binding !IsRightPanelOpen}"
                    Data="{StaticResource Ariadne.Icon.ChevronLeft}" />
            </Panel>
          </Border>
        </Canvas>
      </Grid>

      <GridSplitter x:Name="LibrarySplitter" Grid.Row="1" Height="5"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource Ariadne.BorderMuted}"
                    ResizeDirection="Rows" />

      <Border x:Name="LibraryContent" Grid.Row="2"
              Background="{DynamicResource Ariadne.BackgroundSurface}"
              BorderBrush="{DynamicResource Ariadne.BorderMuted}"
              BorderThickness="0,1,0,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="2" Margin="14,5,14,0">
            <Button Classes="tab" ctl:SelectedClass.IsSelected="{Binding IsNodeLibraryPanel}"
                    Content="{Binding NodeLibraryText}" Command="{Binding ShowNodeLibraryCommand}" />
            <Button Classes="tab" ctl:SelectedClass.IsSelected="{Binding IsExecutionPanel}"
                    Content="{Binding ExecutionText}" Command="{Binding ShowExecutionCommand}" />
          </StackPanel>
          <ScrollViewer Margin="0" IsVisible="{Binding IsNodeLibraryPanel}" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14,8,14,12" Spacing="10">
              <TextBlock Text="{Binding LibraryDragHintText}" Classes="caption" Opacity="0.85" TextWrapping="Wrap" />
              <TextBlock Text="{Binding EntryNodesText}" Classes="subtle" />
              <ItemsControl ItemsSource="{Binding EntryNodes}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:NodeLibraryItemViewModel}">
                    <!-- Border：单击/拖到画布均由页级指针手势处理（避免 Button/DnD 吞事件） -->
                    <Border Classes="library-chip entry"
                            Margin="0,0,8,8"
                            Padding="12,8"
                            Cursor="Hand"
                            ToolTip.Tip="{Binding Title}"
                            PointerPressed="OnNodeLibraryItemPointerPressed"
                            PointerMoved="OnNodeLibraryItemPointerMoved"
                            PointerReleased="OnNodeLibraryItemPointerReleased"
                            PointerCaptureLost="OnNodeLibraryItemCaptureLost">
                      <StackPanel Orientation="Horizontal" Spacing="8" IsHitTestVisible="False">
                        <Path Classes="icon-fill" Width="11" Height="11"
                              Fill="{DynamicResource Ariadne.AccentPrimary}" Data="M8,5 L19,12 L8,19 Z" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Title}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Ariadne.AccentPrimary}" FontWeight="SemiBold" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="{Binding WritingAgentsText}" Classes="subtle" />
              <ItemsControl ItemsSource="{Binding WritingAgents}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:NodeLibraryItemViewModel}">
                    <Border Classes="library-chip"
                            Margin="0,0,8,8"
                            Padding="12,8"
                            Cursor="Hand"
                            ToolTip.Tip="{Binding Title}"
                            PointerPressed="OnNodeLibraryItemPointerPressed"
                            PointerMoved="OnNodeLibraryItemPointerMoved"
                            PointerReleased="OnNodeLibraryItemPointerReleased"
                            PointerCaptureLost="OnNodeLibraryItemCaptureLost">
                      <StackPanel Orientation="Horizontal" Spacing="8" IsHitTestVisible="False">
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource Ariadne.AccentPrimary}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Title}" FontSize="12" VerticalAlignment="Center" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="{Binding UtilityNodesText}" Classes="subtle" />
              <ItemsControl ItemsSource="{Binding UtilityNodes}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:NodeLibraryItemViewModel}">
                    <Border Classes="library-chip"
                            Margin="0,0,8,8"
                            Padding="12,8"
                            Cursor="Hand"
                            ToolTip.Tip="{Binding Title}"
                            PointerPressed="OnNodeLibraryItemPointerPressed"
                            PointerMoved="OnNodeLibraryItemPointerMoved"
                            PointerReleased="OnNodeLibraryItemPointerReleased"
                            PointerCaptureLost="OnNodeLibraryItemCaptureLost">
                      <TextBlock Text="{Binding Title}" FontSize="12" IsHitTestVisible="False" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

          <!-- 执行页：入口卡 + 当前运行控制台 -->
          <ScrollViewer IsVisible="{Binding IsExecutionPanel}" VerticalScrollBarVisibility="Auto">
            <Grid Margin="14,10,14,14" ColumnDefinitions="*,18,280" MinHeight="160">
              <StackPanel Grid.Column="0" Spacing="12">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding RunFromStartText}" Classes="subtitle" />
                  <TextBlock Text="{Binding ExecutionHintText}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                </StackPanel>
                <ItemsControl ItemsSource="{Binding StartNodes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:WorkflowNodeViewModel}">
                      <Border Classes="card exec-start-card" Padding="14,12" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                          <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                                  Background="{DynamicResource Ariadne.AccentLight}"
                                  VerticalAlignment="Center">
                            <Path Width="12" Height="12" Stretch="Uniform"
                                  Fill="{DynamicResource Ariadne.AccentPrimary}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M9,6 L18,12 L9,18 Z" />
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding WorkDir}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <Ellipse Width="7" Height="7" Fill="{Binding StatusIndicatorBrush}" VerticalAlignment="Center" />
                              <TextBlock Text="{Binding StatusText}" Classes="subtle" VerticalAlignment="Center" />
                            </StackPanel>
                          </StackPanel>
                          <Button Grid.Column="2" Classes="primary" MinWidth="88"
                                  Content="{Binding $parent[UserControl].DataContext.RunText}"
                                  Command="{Binding RunCommand}"
                                  VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Classes="empty-state" Padding="12,16" IsVisible="{Binding !HasStartNodes}">
                  <StackPanel Spacing="8" HorizontalAlignment="Center" MaxWidth="420">
                    <ctl:EmptyStateArt Kind="Workspace" Width="140" Height="112" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding EmptyStartTitle}" Classes="subtitle" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding EmptyStartHint}" Classes="caption" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>

              <Border Grid.Column="2" Classes="card" Padding="16" VerticalAlignment="Stretch">
                <StackPanel Spacing="14">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding CurrentRunText}" Classes="subtitle" />
                    <TextBlock Text="{Binding CurrentRunValueText}" Classes="mono" TextWrapping="Wrap" FontSize="12" />
                  </StackPanel>
                  <Border Height="1" Background="{DynamicResource Ariadne.BorderMuted}" />
                  <StackPanel Spacing="8">
                    <Button Classes="secondary" HorizontalAlignment="Stretch" Content="{Binding PauseText}" Command="{Binding PauseWorkflowCommand}" />
                    <Button Classes="secondary" HorizontalAlignment="Stretch" Content="{Binding ResumeText}" Command="{Binding ResumeWorkflowCommand}" />
                    <Button Classes="danger" HorizontalAlignment="Stretch" Content="{Binding StopText}" Command="{Binding StopWorkflowCommand}" />
                  </StackPanel>
                  <Border Height="1" Background="{DynamicResource Ariadne.BorderMuted}" IsVisible="{Binding HasInDoubtOperations}" />
                  <StackPanel Spacing="8" IsVisible="{Binding HasInDoubtOperations}">
                    <TextBlock Text="{Binding InDoubtTitleText}" Classes="subtitle" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding InDoubtHintText}" Classes="caption" TextWrapping="Wrap" />
                    <ComboBox ItemsSource="{Binding InDoubtOperations}"
                              SelectedItem="{Binding SelectedInDoubtOperation, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding OperationId}" Classes="mono" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding SelectedInDoubtOperationSummary}" Classes="caption" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding InDoubtResponseText}" Classes="caption" />
                    <TextBox Text="{Binding InDoubtResponseJson, Mode=TwoWay}"
                             PlaceholderText="{Binding InDoubtResponsePlaceholder}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" />
                    <TextBlock Text="{Binding InDoubtReasonText}" Classes="caption" />
                    <TextBox Text="{Binding InDoubtStopReason, Mode=TwoWay}" />
                    <Button Classes="secondary" HorizontalAlignment="Stretch"
                            Content="{Binding RetryInDoubtText}" Command="{Binding RetryInDoubtOperationCommand}" />
                    <Button Classes="primary" HorizontalAlignment="Stretch"
                            Content="{Binding UseInDoubtResponseText}" Command="{Binding UseInDoubtResponseCommand}" />
                    <Button Classes="danger" HorizontalAlignment="Stretch"
                            Content="{Binding StopInDoubtText}" Command="{Binding StopInDoubtOperationCommand}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- 待审：可收起为顶栏横幅，便于边看画布边批（ui设计方案确认项体验） -->
      <Border Grid.Row="0"
              Grid.RowSpan="3"
              VerticalAlignment="Top"
              Margin="12,12,12,0"
              Padding="14,10"
              Background="{DynamicResource Ariadne.AccentLight}"
              BorderBrush="{DynamicResource Ariadne.AccentPrimary}"
              BorderThickness="1"
              CornerRadius="8"
              IsVisible="{Binding ShowConfirmationBanner}"
              ZIndex="20">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
          <TextBlock Grid.Column="0" Text="{Binding ConfirmationsBannerText}" VerticalAlignment="Center" TextWrapping="Wrap" />
          <Button Grid.Column="1" Classes="secondary" Content="{Binding ExpandConfirmationsText}" Command="{Binding ToggleConfirmationPanelCommand}" />
          <Button Grid.Column="2" Classes="secondary" Content="{Binding RefreshConfirmationsText}" Command="{Binding RefreshConfirmationsCommand}" />
        </Grid>
      </Border>

      <Border Grid.Row="0"
              Grid.RowSpan="3"
              Background="{DynamicResource Ariadne.BackgroundMain}"
              BorderBrush="{DynamicResource Ariadne.BorderMuted}"
              BorderThickness="0,0,1,0"
              IsVisible="{Binding ShowConfirmationFullPanel}"
              ZIndex="15">
        <Grid Margin="34,28" RowDefinitions="Auto,*" RowSpacing="22">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
            <StackPanel Grid.Column="0" Spacing="4">
              <TextBlock Text="{Binding ConfirmationsText}" Classes="display" />
              <TextBlock Text="{Binding ConfirmationCountText}" Classes="body secondary" TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1"
                    Classes="secondary"
                    Content="{Binding CollapseConfirmationsText}"
                    Command="{Binding ToggleConfirmationPanelCommand}"
                    VerticalAlignment="Top" />
            <Button Grid.Column="2"
                    Classes="secondary"
                    Content="{Binding RefreshConfirmationsText}"
                    Command="{Binding RefreshConfirmationsCommand}"
                    VerticalAlignment="Top" />
          </Grid>

          <Grid Grid.Row="1" ColumnDefinitions="292,*" ColumnSpacing="24">
            <DockPanel Grid.Column="0">
              <Border DockPanel.Dock="Right" Width="1" Background="{DynamicResource Ariadne.BorderMuted}" Margin="18,0,0,0" />
              <ScrollViewer Margin="0,0,18,0">
                <StackPanel Spacing="8">
                  <ItemsControl ItemsSource="{Binding Confirmations}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:ConfirmationItemViewModel}">
                        <Button Classes="nav"
                                ctl:SelectedClass.IsSelected="{Binding IsSelected}"
                                Command="{Binding SelectCommand}"
                                HorizontalContentAlignment="Stretch"
                                Padding="12,10">
                          <Grid RowDefinitions="Auto,Auto" RowSpacing="5">
                            <TextBlock Grid.Row="0"
                                       Text="{Binding Summary}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding State}"
                                       Classes="caption"
                                       TextWrapping="Wrap" />
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </DockPanel>

            <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="16">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="14">
                <StackPanel Grid.Column="0" Spacing="3">
                  <TextBlock Text="{Binding ConfirmationDiffText}" Classes="subtitle" />
                  <TextBlock Text="{Binding SelectedConfirmation.Summary}" Classes="caption" TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedConfirmation.ConfirmationId}"
                           Classes="mono"
                           VerticalAlignment="Top"
                           TextWrapping="Wrap" />
              </Grid>

              <TextBox Grid.Row="1"
                       Text="{Binding SelectedConfirmation.Diff}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       IsReadOnly="True"
                       Classes="detail-editor"
                       MinHeight="360"
                       Padding="18" />

              <Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="8">
                <TextBlock Grid.Row="0" Text="{Binding ConfirmationReasonText}" Classes="caption" />
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                  <TextBox Grid.Column="0"
                           Text="{Binding ConfirmationReason, Mode=TwoWay}"
                           PlaceholderText="{Binding ConfirmationReasonPlaceholder}"
                           VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Classes="secondary" Content="{Binding RejectConfirmationText}" Command="{Binding RejectConfirmationCommand}" />
                    <Button Classes="primary" Content="{Binding ApproveConfirmationText}" Command="{Binding ApproveConfirmationCommand}" />
                  </StackPanel>
                </Grid>
              </Grid>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <GridSplitter Grid.Column="1"
                  Width="4"
                  Background="{DynamicResource Ariadne.BorderMuted}"
                  ResizeDirection="Columns"
                  IsVisible="{Binding IsRightPanelOpen}" />

    <Panel Grid.Column="2">
      <Border
          Background="{DynamicResource Ariadne.BackgroundSurface}"
          BorderBrush="{DynamicResource Ariadne.BorderMuted}"
          BorderThickness="1,0,0,0"
          IsVisible="{Binding IsRightPanelOpen}">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,8,12,0">
            <Button Classes="tab" ctl:SelectedClass.IsSelected="{Binding IsProjectAiTab}"
                    Content="{Binding ProjectAiText}" Command="{Binding ShowProjectAiCommand}" />
            <Button Classes="tab" ctl:SelectedClass.IsSelected="{Binding IsNodeDetailsTab}"
                    Content="{Binding NodeDetailsText}" Command="{Binding ShowNodeDetailsCommand}" />
          </StackPanel>
          <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Ariadne.BorderMuted}" Margin="0,6,0,0" />

          <Grid>
            <DockPanel IsVisible="{Binding IsProjectAiTab}">
              <!-- 与作品页共用 ProjectAiComposer（主题色焦点边仅此一体区） -->
              <ctl:ProjectAiComposer DockPanel.Dock="Bottom" Margin="12,8,12,12" />
              <ScrollViewer Margin="12,10">
                <StackPanel Spacing="10">
                  <Border Classes="empty-state" Padding="8,16" IsVisible="{Binding !HasProjectAiBubbles}">
                    <StackPanel Spacing="6">
                      <ctl:EmptyStateArt Kind="ProjectAi" Width="120" Height="90" HorizontalAlignment="Left" />
                      <TextBlock Text="{Binding EmptyProjectAiTitle}" Classes="subtitle" />
                      <TextBlock Text="{Binding EmptyProjectAiHint}" Classes="caption" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding ProjectAiEmptyText}" Classes="subtle" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                  <ItemsControl ItemsSource="{Binding ProjectAiBubbles}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:ChatBubbleViewModel}">
                        <Border Background="{Binding BubbleBackground}"
                                BorderBrush="{DynamicResource Ariadne.BorderMuted}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12,8"
                                HorizontalAlignment="{Binding HorizontalAlignment}"
                                MaxWidth="320"
                                Margin="0,0,0,6">
                          <StackPanel Spacing="4">
                            <TextBlock Text="{Binding RoleLabel}" Classes="subtle" FontSize="11" />
                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="13" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </ScrollViewer>
            </DockPanel>

            <ScrollViewer IsVisible="{Binding IsNodeDetailsTab}" Margin="16,14">
              <StackPanel Spacing="18">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                  <Border Grid.Column="0" Classes="node-mark" Width="34" Height="34">
                    <Path Classes="icon" Width="17" Height="17" Data="{StaticResource Ariadne.Icon.Workspace}" />
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="3">
                    <TextBlock Text="{Binding SelectedNodeTitle}" Classes="subtitle" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding NoNodeSelectedText}" Classes="caption" TextWrapping="Wrap" IsVisible="{Binding !HasSelectedNode}" />
                    <TextBlock Text="{Binding SelectedNode.StatusText}" Classes="caption" TextWrapping="Wrap" IsVisible="{Binding HasSelectedNode}" />
                  </StackPanel>
                </Grid>
                <Border Height="1" Background="{DynamicResource Ariadne.BorderMuted}" />

                <StackPanel IsVisible="{Binding HasSelectedNode}" Spacing="18">
                  <Border Classes="panel-section" Padding="0,0,0,16">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding NodeNameLabel}" Classes="subtitle" />
                      <TextBox Text="{Binding SelectedNode.Name, Mode=TwoWay}" />
                      <StackPanel Spacing="4" IsVisible="{Binding IsSelectedStartNode}">
                        <TextBlock Text="{Binding WorkDirLabel}" Classes="caption" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                          <TextBox Grid.Column="0" Text="{Binding SelectedNode.WorkDir, Mode=TwoWay}" Classes="mono"
                                   PlaceholderText="{Binding WorkDirPlaceholder}" />
                          <Button Grid.Column="1" Classes="secondary"
                                  Content="{Binding BrowseWorkDirText}"
                                  Command="{Binding BrowseWorkDirCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding UserNoteLabel}" Classes="caption" />
                        <TextBox Text="{Binding SelectedNode.UserNote, Mode=TwoWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="56"
                                 PlaceholderText="{Binding UserNotePlaceholder}" />
                        <CheckBox IsChecked="{Binding SelectedNode.ExposedAsTool, Mode=TwoWay}"
                                  Content="{Binding ExposeToolLabel}" />
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Classes="panel-section" Padding="0,0,0,16" IsVisible="{Binding IsSelectedStartNode}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                      <StackPanel Grid.Column="0" Spacing="3">
                        <TextBlock Text="{Binding RunFromStartText}" Classes="subtitle" />
                        <TextBlock Text="{Binding SelectedNode.WorkDir}" Classes="caption" TextWrapping="Wrap" />
                      </StackPanel>
                      <Button Grid.Column="1" Classes="primary" Content="{Binding RunText}" Command="{Binding RunSelectedNodeCommand}" />
                    </Grid>
                  </Border>

                  <!-- 文档读：path + include_content（后端 WorkflowDocumentReadConfig） -->
                  <Border Classes="panel-section" Padding="0,0,0,18" IsVisible="{Binding SelectedNode.IsDocumentNode}">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding ImportFileLabel}" Classes="subtitle" />
                      <TextBlock Text="{Binding ImportFileHint}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding SelectedNode.ImportPath, Mode=TwoWay}" Classes="mono"
                                 PlaceholderText="{Binding ImportNoFileText}" />
                        <Button Grid.Column="1" Classes="secondary" Content="{Binding BrowseImportFileText}"
                                Command="{Binding BrowseImportFileCommand}" />
                      </Grid>
                      <CheckBox IsChecked="{Binding SelectedNode.IncludeContent, Mode=TwoWay}"
                                Content="{Binding IncludeContentText}" />
                    </StackPanel>
                  </Border>

                  <!-- 搜索：query_alias + limit（后端 project search） -->
                  <Border Classes="panel-section" Padding="0,0,0,18" IsVisible="{Binding SelectedNode.IsSearchNode}">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding SearchNodeTitle}" Classes="subtitle" />
                      <TextBlock Text="{Binding SearchNodeHint}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                      <TextBlock Text="{Binding QueryAliasLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.QueryAlias, Mode=TwoWay}" Classes="mono"
                               PlaceholderText="{Binding SearchQueryPlaceholder}" />
                      <TextBlock Text="{Binding SearchLimitLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.SearchLimit, Mode=TwoWay}" Width="100" HorizontalAlignment="Left" />
                    </StackPanel>
                  </Border>

                  <!-- 条件：input_alias / operator / expected -->
                  <Border Classes="panel-section" Padding="0,0,0,18" IsVisible="{Binding SelectedNode.IsConditionNode}">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding ConditionNodeTitle}" Classes="subtitle" />
                      <TextBlock Text="{Binding ConditionNodeHint}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                      <TextBlock Text="{Binding ConditionInputAliasLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.ConditionInputAlias, Mode=TwoWay}" Classes="mono" />
                      <TextBlock Text="{Binding ConditionOperatorLabel}" Classes="caption" />
                      <ComboBox ItemsSource="{x:Static vm:WorkflowNodeViewModel.ConditionOperators}"
                                SelectedItem="{Binding SelectedNode.ConditionOperator, Mode=TwoWay}"
                                HorizontalAlignment="Left" MinWidth="140" />
                      <TextBlock Text="{Binding ConditionExpectedLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.ConditionExpected, Mode=TwoWay}"
                               PlaceholderText="{Binding ConditionExpectedPlaceholder}" />
                    </StackPanel>
                  </Border>

                  <!-- 循环：max_iterations + stop_condition -->
                  <Border Classes="panel-section" Padding="0,0,0,18" IsVisible="{Binding SelectedNode.IsLoopNode}">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding LoopNodeTitle}" Classes="subtitle" />
                      <TextBlock Text="{Binding LoopNodeHint}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                      <TextBlock Text="{Binding MaxIterationsLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.MaxIterations, Mode=TwoWay}" Width="100" HorizontalAlignment="Left" />
                      <TextBlock Text="{Binding StopInputAliasLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.StopInputAlias, Mode=TwoWay}" Classes="mono" />
                      <TextBlock Text="{Binding StopExpectedLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.StopExpected, Mode=TwoWay}" />
                    </StackPanel>
                  </Border>

                  <!-- 审批：approval_id + auto_approve -->
                  <Border Classes="panel-section" Padding="0,0,0,18" IsVisible="{Binding SelectedNode.IsApprovalNode}">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding ApprovalNodeTitle}" Classes="subtitle" />
                      <TextBlock Text="{Binding ApprovalNodeHint}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                      <TextBlock Text="{Binding ApprovalIdLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.ApprovalId, Mode=TwoWay}" Classes="mono" />
                      <CheckBox IsChecked="{Binding SelectedNode.AutoApprove, Mode=TwoWay}"
                                Content="{Binding AutoApproveText}" />
                    </StackPanel>
                  </Border>

                  <!-- 导出：artifact_id / format / title -->
                  <Border Classes="panel-section" Padding="0,0,0,18" IsVisible="{Binding SelectedNode.IsExportNode}">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding ExportNodeTitle}" Classes="subtitle" />
                      <TextBlock Text="{Binding ExportNodeHint}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                      <TextBlock Text="{Binding ExportArtifactIdLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.ExportArtifactId, Mode=TwoWay}" Classes="mono" />
                      <TextBlock Text="{Binding ExportFormatLabel}" Classes="caption" />
                      <ComboBox ItemsSource="{x:Static vm:WorkflowNodeViewModel.ExportFormats}"
                                SelectedItem="{Binding SelectedNode.ExportFormat, Mode=TwoWay}"
                                HorizontalAlignment="Left" MinWidth="140" />
                      <TextBlock Text="{Binding ExportTitleLabel}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.ExportTitle, Mode=TwoWay}" />
                    </StackPanel>
                  </Border>

                  <!-- 数据入口：可建可删 -->
                  <Border Classes="panel-section" Padding="0,0,0,18"
                          IsVisible="{Binding SelectedNode.ShowDataInPinEditor}">
                    <StackPanel Spacing="8">
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{Binding DataInPinsLabel}" Classes="subtitle" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Classes="secondary" Padding="10,4"
                                Content="{Binding AddDataInPinText}"
                                Command="{Binding SelectedNode.AddDataInPinCommand}" />
                        <Button Grid.Column="2" Classes="subtle" Padding="10,4"
                                Content="{Binding RemoveDataInPinText}"
                                Command="{Binding SelectedNode.RemoveDataInPinCommand}" />
                      </Grid>
                      <ItemsControl ItemsSource="{Binding SelectedNode.DataInPins}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="{x:Type vm:NodeDataInPinViewModel}">
                            <Grid ColumnDefinitions="*,Auto" Margin="0,2" ColumnSpacing="8">
                              <TextBlock Grid.Column="0" Text="{Binding Handle}" Classes="caption mono" VerticalAlignment="Center" />
                              <Button Grid.Column="1" Classes="subtle" Padding="6,2" Content="×"
                                      Command="{Binding RemoveCommand}" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>

                  <Border Classes="panel-section" Padding="0,0,0,18" IsVisible="{Binding SelectedNode.ShowPromptEditor}">
                    <StackPanel Spacing="10">
                      <TextBlock Text="{Binding PromptTemplateText}" Classes="subtitle" />
                      <TextBox Text="{Binding SelectedNode.PromptTemplate, Mode=TwoWay}"
                               AcceptsReturn="True"
                               TextWrapping="Wrap"
                               MinHeight="128"
                               Classes="detail-editor" />
                      <Grid ColumnDefinitions="1.2*,0.8*" ColumnSpacing="10">
                        <StackPanel Grid.Column="0" Spacing="4">
                          <TextBlock Text="{Binding ModelIdText}" Classes="caption" />
                          <ComboBox ItemsSource="{Binding AvailableModelIds}"
                                    IsEditable="True"
                                    Text="{Binding SelectedNode.ModelId, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                          <TextBlock Text="{Binding NodeBudgetText}" Classes="caption" />
                          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                            <TextBlock Grid.Column="0" Text="$" Classes="caption" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding SelectedNode.BudgetUsd, Mode=TwoWay}"
                                     PlaceholderText="{Binding OptionalPlaceholder}" />
                          </Grid>
                        </StackPanel>
                      </Grid>
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <StackPanel Grid.Column="0" Spacing="4">
                          <TextBlock Text="{Binding NodeTimeoutText}" Classes="caption" />
                          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0" Text="{Binding SelectedNode.TimeoutSecondsText, Mode=TwoWay}" />
                            <TextBlock Grid.Column="1" Text="{Binding SecondsUnitText}" Classes="caption" VerticalAlignment="Center" />
                          </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Bottom">
                          <CheckBox IsChecked="{Binding SelectedNode.BreakpointEnabled, Mode=TwoWay}" Content="{Binding BreakpointText}" />
                          <Button Classes="secondary" Content="{Binding SaveText}" Command="{Binding ToggleBreakpointCommand}" />
                        </StackPanel>
                      </Grid>
                      <Button Classes="primary" Content="{Binding ApplyNodeConfigText}" HorizontalAlignment="Right" Command="{Binding ApplyNodeConfigCommand}" />
                    </StackPanel>
                  </Border>

                  <!-- 只显示与当前选中节点相关的边；点边也会选中端点节点 -->
                  <Border Classes="panel-section" Padding="0,0,0,18" IsVisible="{Binding HasRelatedEdges}">
                    <StackPanel Spacing="10">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding EdgeDetailsText}" Classes="subtitle" />
                        <Border Grid.Column="1" Classes="chip" Padding="8,2">
                          <TextBlock Text="{Binding EdgeCountText}" Classes="caption" />
                        </Border>
                      </Grid>
                      <ItemsControl ItemsSource="{Binding RelatedEdges}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="{x:Type vm:WorkflowEdgeViewModel}">
                            <Button Classes="nav" ctl:SelectedClass.IsSelected="{Binding IsSelected}" Command="{Binding SelectCommand}" HorizontalContentAlignment="Stretch">
                              <StackPanel Spacing="2">
                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding KindDisplay}" Classes="caption" />
                              </StackPanel>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <Border Classes="soft-panel" Padding="12" IsVisible="{Binding ShowEdgeConfigPanel}">
                        <StackPanel Spacing="8">
                          <TextBlock Text="{Binding SelectedEdge.KindDisplay}" Classes="caption" FontWeight="SemiBold" />
                          <!-- 数据边：可改句柄/别名 -->
                          <Grid ColumnDefinitions="*,*" ColumnSpacing="8" IsVisible="{Binding SelectedEdge.ShowHandleFields}">
                            <StackPanel Grid.Column="0" Spacing="4">
                              <TextBlock Text="{Binding SourceAliasText}" Classes="caption" />
                              <TextBox Text="{Binding SelectedEdge.SourceHandle, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                              <TextBlock Text="{Binding TargetAliasText}" Classes="caption" />
                              <TextBox Text="{Binding SelectedEdge.TargetHandle, Mode=TwoWay}" />
                            </StackPanel>
                          </Grid>
                          <!-- 通用标签（执行/数据/通信均可） -->
                          <StackPanel Spacing="4" IsVisible="{Binding SelectedEdge.ShowLabelField}">
                            <TextBlock Text="{Binding EdgeLabelText}" Classes="caption" />
                            <TextBox Text="{Binding SelectedEdge.Label, Mode=TwoWay}" />
                          </StackPanel>
                          <!-- 仅通信边：双向 alias / 模板 / 次数 -->
                          <StackPanel IsVisible="{Binding SelectedEdge.ShowCommunicationFields}" Spacing="8">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                              <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{Binding ForwardAliasText}" Classes="caption" />
                                <TextBox Text="{Binding SelectedEdge.ForwardAlias, Mode=TwoWay}" />
                              </StackPanel>
                              <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Binding ReverseAliasText}" Classes="caption" />
                                <TextBox Text="{Binding SelectedEdge.ReverseAlias, Mode=TwoWay}" />
                              </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                              <TextBlock Grid.Column="0" Text="{Binding ForwardTemplateText}" Classes="caption" VerticalAlignment="Center" />
                              <Button Grid.Column="1" Classes="secondary" Padding="8,3" Content="{Binding InsertForwardVariableText}" Command="{Binding InsertForwardTemplateVariableCommand}" />
                            </Grid>
                            <TextBox Text="{Binding SelectedEdge.ForwardTemplate, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="76" />
                            <Border Classes="layer" Padding="10,7">
                              <StackPanel Spacing="3">
                                <TextBlock Text="{Binding TemplatePreviewText}" Classes="caption" />
                                <TextBlock Text="{Binding SelectedEdge.ForwardTemplatePreview}" TextWrapping="Wrap" FontSize="12" />
                              </StackPanel>
                            </Border>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                              <TextBlock Grid.Column="0" Text="{Binding ReverseTemplateText}" Classes="caption" VerticalAlignment="Center" />
                              <Button Grid.Column="1" Classes="secondary" Padding="8,3" Content="{Binding InsertReverseVariableText}" Command="{Binding InsertReverseTemplateVariableCommand}" />
                            </Grid>
                            <TextBox Text="{Binding SelectedEdge.ReverseTemplate, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="76" />
                            <Border Classes="layer" Padding="10,7">
                              <StackPanel Spacing="3">
                                <TextBlock Text="{Binding TemplatePreviewText}" Classes="caption" />
                                <TextBlock Text="{Binding SelectedEdge.ReverseTemplatePreview}" TextWrapping="Wrap" FontSize="12" />
                              </StackPanel>
                            </Border>
                            <TextBlock Text="{Binding MaxCommunicationCountText}" Classes="caption" />
                            <TextBox Text="{Binding SelectedEdge.MaxCommunicationCount, Mode=TwoWay}" />
                          </StackPanel>
                          <Button Classes="secondary" HorizontalAlignment="Right" Content="{Binding ApplyEdgeConfigText}" Command="{Binding SaveEdgeConfigCommand}" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>

                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                      <Button Grid.Column="0" Classes="secondary" Content="{Binding ExportSelectionText}" Command="{Binding ExportSelectionCommand}" />
                      <Button Grid.Column="1" Classes="secondary" Content="{Binding SubworkflowText}" Command="{Binding PackSelectionCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBox Grid.Column="0" Text="{Binding AnnotationTitle, Mode=TwoWay}" PlaceholderText="{Binding AnnotationTitlePlaceholder}" />
                      <Button Grid.Column="1" Classes="secondary" Content="{Binding AddAnnotationText}" Command="{Binding AddAnnotationCommand}" />
                    </Grid>
                    <Button Classes="danger" Content="{Binding DeleteText}" HorizontalAlignment="Stretch" Command="{Binding DeleteSelectedNodeCommand}" />
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </DockPanel>
      </Border>
    </Panel>
  </Grid>

  <!-- 节点库拖放 ghost：全页浮层，不被画布 ClipToBounds 裁掉 -->
  <Canvas x:Name="LibraryDragLayer"
          IsHitTestVisible="False"
          ZIndex="200">
    <Border x:Name="LibraryDragGhost"
            IsVisible="False"
            Classes="library-chip"
            Padding="12,8"
            Opacity="0.92"
            BoxShadow="0 4 16 0 #28000000">
      <TextBlock x:Name="LibraryDragGhostText" FontSize="12" FontWeight="SemiBold" />
    </Border>
  </Canvas>
  </Panel>
</UserControl>
