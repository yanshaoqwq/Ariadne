<UserControl
    x:Class="Ariadne.Desktop.Views.WorkspacePageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:WorkspacePageViewModel">
  <Grid Background="{DynamicResource Ariadne.BackgroundMain}" ColumnDefinitions="*,Auto">

    <Grid x:Name="WorkspaceGrid" Grid.Column="0" RowDefinitions="*,Auto,220">
      <Canvas x:Name="CanvasOverlay" Grid.Row="0"
              Background="{DynamicResource Ariadne.CanvasBackground}"
              ClipToBounds="True">
        <Canvas.ContextMenu>
          <ContextMenu Classes="ariadne">
            <MenuItem Header="{Binding CtxAddNodeText}" Command="{Binding AddContextNodeCommand}" />
            <MenuItem Header="{Binding CtxAddStartText}" Command="{Binding AddStartNodeCommand}" />
            <Separator />
            <MenuItem Header="{Binding CtxDeleteText}" Command="{Binding DeleteSelectedNodeCommand}" />
          </ContextMenu>
        </Canvas.ContextMenu>

        <StackPanel x:Name="TopToolbar" Canvas.Top="12" Canvas.Right="16" Orientation="Horizontal" Spacing="4">
          <Button Classes="icon-btn" ToolTip.Tip="{Binding ImportText}" Command="{Binding ImportCommand}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Import}" />
          </Button>
          <Button Classes="icon-btn" ToolTip.Tip="{Binding ExportText}" Command="{Binding ExportCommand}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Export}" />
          </Button>
          <Button Classes="icon-btn save" ToolTip.Tip="{Binding SaveText}" Command="{Binding SaveCommand}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Save}" />
          </Button>
          <Button Classes="secondary" Content="{Binding PauseText}" Command="{Binding PauseWorkflowCommand}" />
          <Button Classes="danger" Content="{Binding StopText}" Command="{Binding StopWorkflowCommand}" />
          <Button Classes="secondary" Content="{Binding ResumeText}" Command="{Binding ResumeWorkflowCommand}" />
        </StackPanel>
        <TextBlock Canvas.Left="18" Canvas.Bottom="18" Text="{Binding StatusText}" Classes="caption" />

        <ItemsControl x:Name="NodesItemsControl" ItemsSource="{Binding Nodes}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <Canvas />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:WorkflowNodeViewModel}">
              <Border Width="202"
                      Canvas.Left="{Binding X}"
                      Canvas.Top="{Binding Y}"
                      Background="{DynamicResource Ariadne.NodeBackground}"
                      BorderBrush="{DynamicResource Ariadne.NodeBorder}"
                      BorderThickness="1.3"
                      CornerRadius="{DynamicResource Ariadne.Radius.Large}"
                      BoxShadow="{DynamicResource Ariadne.Shadow.Card}"
                      PointerPressed="OnNodeSelectPointerPressed">
                <DockPanel>
                  <Border DockPanel.Dock="Top"
                          Background="{DynamicResource Ariadne.AccentLight}"
                          CornerRadius="8,8,0,0"
                          Padding="9,7"
                          Cursor="SizeAll"
                          PointerPressed="OnNodePointerPressed"
                          PointerMoved="OnNodePointerMoved"
                          PointerReleased="OnNodePointerReleased">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Button Grid.Column="0" Width="26" Height="26" Padding="0"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              Background="{DynamicResource Ariadne.AccentLight}"
                              BorderBrush="{DynamicResource Ariadne.AccentPrimary}"
                              BorderThickness="1.2"
                              CornerRadius="5"
                              Command="{Binding RunCommand}">
                        <Path Width="10" Height="10" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Fill="{DynamicResource Ariadne.AccentPrimary}"
                              Data="M9,6 L18,12 L9,18 Z" />
                      </Button>
                      <TextBlock Grid.Column="1" Text="{Binding Label}"
                                 FontWeight="SemiBold" FontSize="12" Margin="8,0,4,0"
                                 Foreground="{DynamicResource Ariadne.AccentPrimary}"
                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                      <Path Grid.Column="2" Width="12" Height="12" Stretch="Uniform"
                            VerticalAlignment="Center"
                            Fill="Transparent"
                            Stroke="{DynamicResource Ariadne.AccentPrimary}"
                            StrokeThickness="1.5"
                            Data="M6,4 L18,12 L6,20 Z" />
                    </Grid>
                  </Border>
                  <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Ariadne.BorderMuted}" />
                  <StackPanel Margin="10,8" Spacing="7">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding $parent[UserControl].DataContext.NodeNameLabel}" Classes="subtle" />
                      <TextBox Text="{Binding Name, Mode=TwoWay}" MinHeight="26" Padding="7,3" FontSize="12"
                               CornerRadius="{DynamicResource Ariadne.Radius.Small}" />
                    </StackPanel>
                    <StackPanel Spacing="2" IsVisible="{Binding IsStartNode}">
                      <TextBlock Text="{Binding $parent[UserControl].DataContext.WorkDirLabel}" Classes="subtle" />
                      <TextBox Text="{Binding WorkDir, Mode=TwoWay}" MinHeight="26" Padding="7,3" FontSize="11"
                               Classes="mono" PlaceholderText="{Binding $parent[UserControl].DataContext.WorkDirPlaceholder}"
                               CornerRadius="{DynamicResource Ariadne.Radius.Small}" />
                    </StackPanel>
                    <CheckBox IsChecked="{Binding ExposedAsTool, Mode=TwoWay}" Margin="0,2,0,0" IsVisible="{Binding IsStartNode}">
                      <TextBlock Text="{Binding $parent[UserControl].DataContext.ExposeToolLabel}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" />
                    </CheckBox>
                    <TextBlock Text="{Binding StatusText}" Classes="caption" TextWrapping="Wrap" />
                  </StackPanel>
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border x:Name="LibraryTogglePill"
                Canvas.Bottom="0"
                Width="52"
                Height="22"
                Background="{DynamicResource Ariadne.BackgroundSurface}"
                BorderBrush="{DynamicResource Ariadne.BorderDefault}"
                BorderThickness="1"
                CornerRadius="6,6,0,0"
                BoxShadow="0 -2 6 0 #10000000"
                Cursor="Hand"
                ToolTip.Tip="{Binding NodeLibraryText}"
                PointerPressed="OnPillPointerPressed"
                PointerMoved="OnPillPointerMoved"
                PointerReleased="OnPillPointerReleased">
          <Path Classes="icon" Width="14" Height="14"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Data="{StaticResource Ariadne.Icon.ChevronDown}" />
        </Border>

        <Border x:Name="WorkspaceRightPill"
                Canvas.Right="0"
                Width="22"
                Height="52"
                Background="{DynamicResource Ariadne.BackgroundSurface}"
                BorderBrush="{DynamicResource Ariadne.BorderDefault}"
                BorderThickness="1"
                CornerRadius="8,0,0,8"
                Cursor="Hand"
                ToolTip.Tip="{Binding ToggleRightPanelText}"
                PointerPressed="OnRightPillPointerPressed"
                PointerMoved="OnRightPillPointerMoved"
                PointerReleased="OnRightPillPointerReleased">
          <Path Classes="icon" Width="14" Height="14"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Data="{StaticResource Ariadne.Icon.ChevronRight}" />
        </Border>
      </Canvas>

      <GridSplitter x:Name="LibrarySplitter" Grid.Row="1" Height="5"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource Ariadne.BorderMuted}"
                    ResizeDirection="Rows" />

      <Border x:Name="LibraryContent" Grid.Row="2"
              Background="{DynamicResource Ariadne.BackgroundSurface}"
              BorderBrush="{DynamicResource Ariadne.BorderMuted}"
              BorderThickness="0,1,0,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="14,9,14,5">
            <Border Classes="chip" Background="{DynamicResource Ariadne.AccentLight}" BorderThickness="0">
              <TextBlock Text="{Binding NodeLibraryText}" FontSize="12" Foreground="{DynamicResource Ariadne.AccentPrimary}" FontWeight="SemiBold" />
            </Border>
            <Border Classes="chip" Background="Transparent" BorderThickness="0">
              <TextBlock Text="{Binding ExecutionText}" FontSize="12" Foreground="{DynamicResource Ariadne.TextSecondary}" />
            </Border>
          </StackPanel>
          <StackPanel Margin="12,4,12,12" Spacing="8">
            <TextBlock Text="{Binding EntryNodesText}" Classes="subtle" />
            <ItemsControl ItemsSource="{Binding EntryNodes}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:NodeLibraryItemViewModel}">
                  <Button Classes="subtle" Margin="0,0,8,8" Padding="0" Command="{Binding AddCommand}">
                    <Border Classes="layer" Padding="10,6"
                            BorderBrush="{DynamicResource Ariadne.AccentPrimary}" BorderThickness="1">
                      <StackPanel Orientation="Horizontal" Spacing="7">
                        <Path Classes="icon-fill" Width="11" Height="11"
                              Fill="{DynamicResource Ariadne.AccentPrimary}" Data="M8,5 L19,12 L8,19 Z" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Title}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Ariadne.AccentPrimary}" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding WritingAgentsText}" Classes="subtle" />
            <ItemsControl ItemsSource="{Binding WritingAgents}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:NodeLibraryItemViewModel}">
                  <Button Classes="subtle" Margin="0,0,8,8" Padding="0" Command="{Binding AddCommand}">
                    <Border Classes="layer" Padding="10,6">
                      <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource Ariadne.AccentPrimary}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Title}" FontSize="12" VerticalAlignment="Center" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding UtilityNodesText}" Classes="subtle" />
            <ItemsControl ItemsSource="{Binding UtilityNodes}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:NodeLibraryItemViewModel}">
                  <Button Classes="subtle" Margin="0,0,8,8" Padding="0" Command="{Binding AddCommand}">
                    <Border Classes="layer" Padding="10,6">
                      <TextBlock Text="{Binding Title}" FontSize="12" />
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </DockPanel>
      </Border>
    </Grid>

    <Panel Grid.Column="1">
      <Border
          Width="280"
          Background="{DynamicResource Ariadne.BackgroundSurface}"
          BorderBrush="{DynamicResource Ariadne.BorderMuted}"
          BorderThickness="1,0,0,0"
          IsVisible="{Binding IsRightPanelOpen}">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,8,12,0">
            <Button Classes="tab" Classes.selected="{Binding IsProjectAiTab}"
                    Content="{Binding ProjectAiText}" Command="{Binding ShowProjectAiCommand}" />
            <Button Classes="tab" Classes.selected="{Binding IsNodeDetailsTab}"
                    Content="{Binding NodeDetailsText}" Command="{Binding ShowNodeDetailsCommand}" />
          </StackPanel>
          <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Ariadne.BorderMuted}" Margin="0,6,0,0" />

          <Grid>
            <DockPanel IsVisible="{Binding IsProjectAiTab}">
              <Border DockPanel.Dock="Bottom" Padding="12,8"
                      BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,1,0,0">
                <DockPanel>
                  <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                    <Button Grid.Column="1" Classes="primary" Width="34" Height="34" Padding="0"
                            Command="{Binding SendProjectAiCommand}"
                            ToolTip.Tip="{Binding ProjectAiText}">
                      <Path Classes="icon" Width="17" Height="17"
                            Stroke="{DynamicResource Ariadne.TextOnAccent}"
                            Data="M4,12 L20,4 L14,20 L11,13 Z M11,13 L4,12" />
                    </Button>
                  </Grid>
                  <TextBox MinHeight="60" MaxHeight="120" FontSize="13"
                           Text="{Binding ProjectAiMessage, Mode=TwoWay}"
                           AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0"
                           Background="Transparent" VerticalContentAlignment="Top"
                           PlaceholderText="{Binding ProjectAiPlaceholder}" />
                </DockPanel>
              </Border>
              <ScrollViewer Margin="12,10">
                <StackPanel Spacing="12">
                  <TextBlock Text="{Binding ProjectAiAnswer}" Classes="caption" TextWrapping="Wrap" />
                  <Separator />
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding ConfirmationsText}" Classes="subtitle" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding RefreshConfirmationsText}" Command="{Binding RefreshConfirmationsCommand}" />
                  </Grid>
                  <ItemsControl ItemsSource="{Binding Confirmations}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:ConfirmationItemViewModel}">
                        <Button Classes="nav" Classes.selected="{Binding IsSelected}" Command="{Binding SelectCommand}" HorizontalContentAlignment="Left">
                          <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding State}" Classes="caption" />
                          </StackPanel>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding ConfirmationDiffText}" Classes="caption" />
                  <TextBox Text="{Binding SelectedConfirmation.Diff}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" IsReadOnly="True" />
                  <TextBox Text="{Binding ConfirmationReason, Mode=TwoWay}" PlaceholderText="{Binding ConfirmationReasonPlaceholder}" />
                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Classes="secondary" Content="{Binding RejectConfirmationText}" Command="{Binding RejectConfirmationCommand}" />
                    <Button Classes="primary" Content="{Binding ApproveConfirmationText}" Command="{Binding ApproveConfirmationCommand}" />
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </DockPanel>

            <ScrollViewer IsVisible="{Binding IsNodeDetailsTab}" Margin="12,10">
              <StackPanel Spacing="10">
                <TextBlock Text="{Binding SelectedNodeTitle}" Classes="subtitle" TextWrapping="Wrap" />
                <StackPanel IsVisible="{Binding HasSelectedNode}" Spacing="8">
                  <Button Classes="secondary" Content="{Binding RunText}" Command="{Binding RunSelectedNodeCommand}" />
                  <TextBlock Text="{Binding PromptTemplateText}" Classes="caption" />
                  <TextBox Text="{Binding SelectedNode.PromptTemplate, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="86" />
                  <TextBlock Text="{Binding ModelIdText}" Classes="caption" />
                  <TextBox Text="{Binding SelectedNode.ModelId, Mode=TwoWay}" />
                  <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <StackPanel Grid.Column="0" Spacing="4">
                      <TextBlock Text="{Binding NodeBudgetText}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.BudgetUsd, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                      <TextBlock Text="{Binding NodeTimeoutText}" Classes="caption" />
                      <TextBox Text="{Binding SelectedNode.TimeoutMs, Mode=TwoWay}" />
                    </StackPanel>
                  </Grid>
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <CheckBox Grid.Column="0" IsChecked="{Binding SelectedNode.BreakpointEnabled, Mode=TwoWay}" Content="{Binding BreakpointText}" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding SaveText}" Command="{Binding ToggleBreakpointCommand}" />
                  </Grid>
                  <Button Classes="primary" Content="{Binding ApplyNodeConfigText}" Command="{Binding ApplyNodeConfigCommand}" />
                  <TextBlock Text="{Binding EdgeDetailsText}" Classes="subtitle" />
                  <Border Classes="layer" Padding="10">
                    <TextBlock Text="{Binding EdgeCountText}" Classes="caption" />
                  </Border>
                  <Button Classes="secondary" Content="{Binding ExportSelectionText}" Command="{Binding ExportSelectionCommand}" />
                  <Button Classes="secondary" Content="{Binding SubworkflowText}" Command="{Binding PackSelectionCommand}" />
                  <TextBox Text="{Binding AnnotationTitle, Mode=TwoWay}" PlaceholderText="{Binding AnnotationTitlePlaceholder}" />
                  <Button Classes="secondary" Content="{Binding AddAnnotationText}" Command="{Binding AddAnnotationCommand}" />
                  <Button Classes="danger" Content="{Binding DeleteText}" Command="{Binding DeleteSelectedNodeCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding NoNodeSelectedText}" Classes="subtle" TextWrapping="Wrap" IsVisible="{Binding !HasSelectedNode}" />
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </DockPanel>
      </Border>

      <Button Classes="panel-float" Command="{Binding ToggleRightPanelCommand}"
              ToolTip.Tip="{Binding ToggleRightPanelText}"
              IsVisible="{Binding !IsRightPanelOpen}">
        <Path Classes="icon" Width="16" Height="16" Data="{StaticResource Ariadne.Icon.ChevronLeft}" />
      </Button>
    </Panel>
  </Grid>
</UserControl>
