<UserControl
    x:Class="Ariadne.Desktop.Views.WorkspacePageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:WorkspacePageViewModel">
  <!-- 工作空间：全域画布 + 底部吸附可调高的节点库 + 右侧 AI/节点细节。本轮为视觉骨架。 -->
  <Grid Background="{DynamicResource Ariadne.BackgroundMain}" ColumnDefinitions="*,Auto">

    <!-- 左：画布（Row0）+ 拖拽分隔（Row1）+ 吸附下栏节点库（Row2） -->
    <Grid x:Name="WorkspaceGrid" Grid.Column="0" RowDefinitions="*,Auto,220">

      <!-- 全域流程图画布 -->
      <Canvas x:Name="CanvasOverlay" Grid.Row="0"
              Background="{DynamicResource Ariadne.CanvasBackground}"
              ClipToBounds="True">

        <!-- 顶部右上角图标工具条：导入图 / 导出图 / 保存 -->
        <StackPanel x:Name="TopToolbar" Canvas.Top="12" Canvas.Right="16" Orientation="Horizontal" Spacing="4">
          <Button Classes="icon-btn" ToolTip.Tip="{Binding ImportText}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Import}" />
          </Button>
          <Button Classes="icon-btn" ToolTip.Tip="{Binding ExportText}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Export}" />
          </Button>
          <Button Classes="icon-btn accent" ToolTip.Tip="{Binding SaveText}">
            <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Save}" />
          </Button>
        </StackPanel>

        <!-- 起始节点（节点库拖出的入口类型节点示例）：
             左上=执行按钮，右上=三角形执行输出端口，体内含名称/工作目录/工具开关。 -->
        <Border Canvas.Left="140" Canvas.Top="84"
                Width="200"
                DataContext="{Binding StartNode}"
                Background="{DynamicResource Ariadne.NodeBackground}"
                BorderBrush="{DynamicResource Ariadne.AccentPrimary}"
                BorderThickness="1.5"
                CornerRadius="{DynamicResource Ariadne.Radius.Large}"
                BoxShadow="{DynamicResource Ariadne.Shadow.Card}">
          <DockPanel>
            <!-- 标题条：左上执行按钮 + 标题 + 右上三角输出口 -->
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource Ariadne.AccentLight}"
                    CornerRadius="8,8,0,0"
                    Padding="8,6">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- 左上：执行按钮 -->
                <Button Grid.Column="0" Classes="primary" Width="26" Height="26" Padding="0"
                        Command="{Binding RunCommand}" ToolTip.Tip="{Binding RunText}">
                  <Path Width="12" Height="12" Stretch="Uniform"
                        Fill="{DynamicResource Ariadne.TextOnAccent}"
                        Data="M8,5 L19,12 L8,19 Z" />
                </Button>
                <TextBlock Grid.Column="1" Text="{Binding TitleText}"
                           FontWeight="SemiBold" FontSize="12" Margin="8,0,0,0"
                           Foreground="{DynamicResource Ariadne.AccentPrimary}" VerticalAlignment="Center" />
                <!-- 右上：三角形执行输出端口 -->
                <Path Grid.Column="2" Width="13" Height="13" Stretch="Uniform"
                      VerticalAlignment="Center"
                      Fill="{DynamicResource Ariadne.AccentPrimary}"
                      Data="M6,4 L18,12 L6,20 Z" ToolTip.Tip="exec-out" />
              </Grid>
            </Border>
            <!-- 节点体：名称 + 工作目录 + 工具开关 -->
            <StackPanel Margin="10,9" Spacing="8">
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding NameLabel}" Classes="subtle" />
                <TextBox Text="{Binding Name, Mode=TwoWay}" MinHeight="28" Padding="7,4" FontSize="12" />
              </StackPanel>
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding WorkDirLabel}" Classes="subtle" />
                <TextBox Text="{Binding WorkDir, Mode=TwoWay}" MinHeight="28" Padding="7,4" FontSize="11"
                         Classes="mono" PlaceholderText="{Binding WorkDirPlaceholder}" />
              </StackPanel>
              <CheckBox IsChecked="{Binding ExposedAsTool, Mode=TwoWay}">
                <TextBlock Text="{Binding ExposeToolLabel}" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" />
              </CheckBox>
            </StackPanel>
          </DockPanel>
        </Border>
      </Canvas>

      <!-- 可拖拽分隔条：调整下栏高度 -->
      <GridSplitter x:Name="LibrarySplitter" Grid.Row="1" Height="5"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource Ariadne.BorderMuted}"
                    ResizeDirection="Rows" />

      <!-- 底部吸附节点库：默认占满下方；标题条常驻，内容可收起 -->
      <Border Grid.Row="2"
              Background="{DynamicResource Ariadne.BackgroundSurface}"
              BorderBrush="{DynamicResource Ariadne.BorderMuted}"
              BorderThickness="0,1,0,0">
        <DockPanel>
          <!-- 标题条 + 收起键 -->
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="12,8,8,6">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
              <Border Classes="chip" Background="{DynamicResource Ariadne.AccentLight}" BorderThickness="0">
                <TextBlock Text="{Binding NodeLibraryText}" FontSize="12" Foreground="{DynamicResource Ariadne.AccentPrimary}" FontWeight="SemiBold" />
              </Border>
              <Border Classes="chip" Background="Transparent" BorderThickness="0">
                <TextBlock Text="{Binding ExecutionText}" FontSize="12" Foreground="{DynamicResource Ariadne.TextSecondary}" />
              </Border>
            </StackPanel>
            <Button Grid.Column="1" Classes="panel-collapse" Click="OnToggleLibrary" ToolTip.Tip="{Binding NodeLibraryText}">
              <Path Classes="icon" Width="14" Height="14" Data="{StaticResource Ariadne.Icon.ChevronDown}" />
            </Button>
          </Grid>
          <!-- 库内容（收起时隐藏，标题条仍吸附底部） -->
          <ScrollViewer x:Name="LibraryContent">
            <StackPanel Margin="12,4,12,12" Spacing="8">
              <TextBlock Text="{Binding EntryNodesText}" Classes="subtle" />
              <ItemsControl ItemsSource="{Binding EntryNodes}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="layer" Margin="0,0,8,8" Padding="10,6"
                            BorderBrush="{DynamicResource Ariadne.AccentPrimary}" BorderThickness="1">
                      <StackPanel Orientation="Horizontal" Spacing="7">
                        <Path Classes="icon-fill" Width="11" Height="11"
                              Fill="{DynamicResource Ariadne.AccentPrimary}" Data="M8,5 L19,12 L8,19 Z" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Ariadne.AccentPrimary}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="{Binding WritingAgentsText}" Classes="subtle" />
              <ItemsControl ItemsSource="{Binding WritingAgents}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="layer" Margin="0,0,8,8" Padding="10,6">
                      <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource Ariadne.AccentPrimary}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock Text="{Binding UtilityNodesText}" Classes="subtle" />
              <ItemsControl ItemsSource="{Binding UtilityNodes}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="layer" Margin="0,0,8,8" Padding="10,6">
                      <TextBlock Text="{Binding}" FontSize="12" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>

    <!-- 右：项目 AI / 节点细节（可收起；收起后右缘悬浮左向箭头展开） -->
    <Panel Grid.Column="1">
      <Border
          Width="264"
          Margin="0,14,14,14"
          Classes="card"
          Padding="0"
          IsVisible="{Binding IsRightPanelOpen}">
        <DockPanel>
          <!-- 右上标签切换（项目AI/节点细节）+ 收起键 -->
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="12,6,8,0">
            <StackPanel Grid.Column="0" Orientation="Horizontal">
              <Button Classes="tab" Classes.selected="{Binding IsProjectAiTab}"
                      Content="{Binding ProjectAiText}" Command="{Binding ShowProjectAiCommand}" />
              <Button Classes="tab" Classes.selected="{Binding IsNodeDetailsTab}"
                      Content="{Binding NodeDetailsText}" Command="{Binding ShowNodeDetailsCommand}" />
            </StackPanel>
            <Button Grid.Column="1" Classes="panel-collapse" VerticalAlignment="Center"
                    Command="{Binding ToggleRightPanelCommand}" ToolTip.Tip="{Binding ToggleRightPanelText}">
              <Path Classes="icon" Width="16" Height="16" Data="{StaticResource Ariadne.Icon.ChevronRight}" />
            </Button>
          </Grid>
          <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Ariadne.BorderMuted}" />

          <!-- ===== 标签内容 1：项目 AI ===== -->
          <DockPanel IsVisible="{Binding IsProjectAiTab}">
            <!-- 底部输入区：不套卡片，直接贴栏底，仅顶部一条分隔线 -->
            <Border DockPanel.Dock="Bottom" Padding="12,8"
                    BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,1,0,0">
              <DockPanel>
                <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                  <Button Grid.Column="1" Classes="primary" Width="34" Height="34" Padding="0"
                          ToolTip.Tip="{Binding ProjectAiText}">
                    <Path Classes="icon" Width="17" Height="17"
                          Stroke="{DynamicResource Ariadne.TextOnAccent}"
                          Data="M4,12 L20,4 L14,20 L11,13 Z M11,13 L4,12" />
                  </Button>
                </Grid>
                <TextBox MinHeight="60" MaxHeight="120" FontSize="13"
                         AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0"
                         Background="Transparent" VerticalContentAlignment="Top"
                         PlaceholderText="{Binding ProjectAiPlaceholder}" />
              </DockPanel>
            </Border>
            <ScrollViewer Margin="12,10" VerticalAlignment="Top">
              <TextBlock Text="{Binding ProjectAiEmptyText}" Classes="caption" TextWrapping="Wrap" />
            </ScrollViewer>
          </DockPanel>

          <!-- ===== 标签内容 2：节点细节 ===== -->
          <ScrollViewer IsVisible="{Binding IsNodeDetailsTab}" Margin="12,10">
            <TextBlock Text="{Binding NoNodeSelectedText}" Classes="subtle" TextWrapping="Wrap" />
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- 收起态：右缘悬浮左向箭头 -->
      <Button Classes="panel-float" Command="{Binding ToggleRightPanelCommand}"
              ToolTip.Tip="{Binding ToggleRightPanelText}"
              IsVisible="{Binding !IsRightPanelOpen}">
        <Path Classes="icon" Width="16" Height="16" Data="{StaticResource Ariadne.Icon.ChevronLeft}" />
      </Button>
    </Panel>
  </Grid>
</UserControl>
