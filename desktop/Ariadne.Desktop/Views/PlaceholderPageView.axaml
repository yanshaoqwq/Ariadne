<UserControl
    x:Class="Ariadne.Desktop.Views.PlaceholderPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:PlaceholderPageViewModel">
  <Grid Background="{DynamicResource Ariadne.BackgroundMain}">
    <Border
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Width="520"
        Background="{DynamicResource Ariadne.BackgroundSurface}"
        BorderBrush="{DynamicResource Ariadne.BorderDefault}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="28">
      <StackPanel Spacing="12">
        <TextBlock
            Text="{Binding Icon}"
            FontSize="26"
            Foreground="{DynamicResource Ariadne.AccentPrimary}" />
        <TextBlock
            Text="{Binding Title}"
            FontSize="22"
            FontWeight="SemiBold"
            Foreground="{DynamicResource Ariadne.TextPrimary}" />
        <TextBlock
            Text="{Binding Description}"
            Foreground="{DynamicResource Ariadne.TextSecondary}"
            TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
