<UserControl
    x:Class="Ariadne.Desktop.Views.SettingsPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="clr-namespace:Ariadne.Desktop.Controls"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:SettingsPageViewModel">
  <UserControl.Styles>
    <Style Selector="ListBox.settings-section-index">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.settings-section-index ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="8,5" />
    </Style>
    <Style Selector="ListBox.settings-section-index ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource Ariadne.AccentPrimary}" />
    </Style>
    <Style Selector="ListBox.settings-section-index ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource Ariadne.AccentPrimary}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="ListBox.settings-section-index ListBoxItem:focus">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
  </UserControl.Styles>
  <Grid RowDefinitions="Auto,*" Background="{DynamicResource Ariadne.BackgroundMain}">

    <Border
        Grid.Row="0"
        Background="{DynamicResource Ariadne.BackgroundSurface}"
        BorderBrush="{DynamicResource Ariadne.BorderMuted}"
        BorderThickness="0,0,0,1"
        Padding="28,20,28,12">
      <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="16" RowSpacing="14">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Title}" Classes="display" />
          <Border Grid.Row="0" Grid.Column="1" Classes="chip" HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock Text="{Binding StatusText}"
                       Classes="caption"
                       TextWrapping="Wrap"
                       AutomationProperties.Name="{Binding StatusText}"
                       AutomationProperties.LiveSetting="Assertive" />
          </Border>
          <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
            <ListBox ItemsSource="{Binding Tabs}"
                     SelectedItem="{Binding NavigationSelection, Mode=TwoWay}"
                     SelectionMode="Single"
                     Background="Transparent">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8" />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsTabViewModel}">
                  <TextBlock Text="{Binding Title}"
                             MinWidth="92"
                             Padding="14,8"
                             TextAlignment="Center"
                             AutomationProperties.Name="{Binding Title}" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </ScrollViewer>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <ScrollViewer x:Name="SettingsContentScroll" Padding="28,24,204,24">
        <Panel x:Name="SettingsContentHost" MaxWidth="960" HorizontalAlignment="Stretch">

          <StackPanel IsVisible="{Binding IsGeneralSelected}" IsEnabled="{Binding IsGeneralEditable}" Spacing="18">
            <TextBlock Text="{Binding GeneralTitle}" Classes="title" />
            <TextBlock Text="{Binding GeneralScopeHelpText}" Classes="caption" TextWrapping="Wrap" />
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="ProjectSectionAnchor" Text="{Binding ProjectSectionTitle}" Classes="subtitle" />
                <Grid ColumnDefinitions="180,*" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ProjectNameLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="0" Grid.Column="1"
                           Text="{Binding ProjectName, Mode=TwoWay}"
                           AutomationProperties.Name="{Binding ProjectNameLabel}" />
                </Grid>
              </StackPanel>
            </Border>
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="DirectoriesSectionAnchor" Text="{Binding DirectoriesSectionTitle}" Classes="subtitle" />
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="180,*,Auto" RowSpacing="12" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DocumentsDirLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DocumentsDir, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding DocumentsDirLabel}" />
                <Button Grid.Row="0" Grid.Column="2" Classes="secondary" Content="{Binding BrowseFolderText}" Command="{Binding BrowseDocumentsDirCommand}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding WorkflowsDirLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WorkflowsDir, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding WorkflowsDirLabel}" />
                <Button Grid.Row="1" Grid.Column="2" Classes="secondary" Content="{Binding BrowseFolderText}" Command="{Binding BrowseWorkflowsDirCommand}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding SkillsDirLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SkillsDir, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding SkillsDirLabel}" />
                <Button Grid.Row="2" Grid.Column="2" Classes="secondary" Content="{Binding BrowseFolderText}" Command="{Binding BrowseSkillsDirCommand}" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding ExportsDirLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ExportsDir, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding ExportsDirLabel}" />
                <Button Grid.Row="3" Grid.Column="2" Classes="secondary" Content="{Binding BrowseFolderText}" Command="{Binding BrowseExportsDirCommand}" />
                </Grid>
              </StackPanel>
            </Border>
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="ProjectMemorySectionAnchor" Text="{Binding ProjectMemorySectionTitle}" Classes="subtitle" />
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="180,*" RowSpacing="10" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ProjectMemoryLabel}" Classes="secondary" VerticalAlignment="Top" />
                  <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding ProjectMemory, Mode=TwoWay}"
                         PlaceholderText="{Binding ProjectMemoryPlaceholder}"
                         AutomationProperties.Name="{Binding ProjectMemoryLabel}"
                         AutomationProperties.HelpText="{Binding ProjectMemoryPlaceholder}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="150" />
                </Grid>
              </StackPanel>
            </Border>
            <Button Classes="primary" Content="{Binding SaveGeneralText}" HorizontalAlignment="Right" Command="{Binding SaveGeneralCommand}" />
          </StackPanel>

          <StackPanel IsVisible="{Binding IsModelsSelected}" IsEnabled="{Binding IsModelsEditable}" Spacing="18">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
              <TextBlock Grid.Column="0" Text="{Binding ModelsTitle}" Classes="title" />
              <Button Grid.Column="1" Classes="secondary" Content="{Binding RefreshText}" Command="{Binding RefreshModelsCommand}" />
            </Grid>
            <TextBlock Text="{Binding ProviderScopeHelpText}" Classes="caption" TextWrapping="Wrap" />
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="ProviderSectionAnchor" Text="{Binding ProviderSectionTitle}" Classes="subtitle" />
                <Grid ColumnDefinitions="240,*" ColumnSpacing="20">
                <!-- 多供应商列表 -->
                <DockPanel Grid.Column="0">
                  <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,12">
                    <TextBlock Text="{Binding ProviderListTitle}" Classes="subtitle" />
                    <TextBlock Text="{Binding ProviderStatus}" Classes="caption" TextWrapping="Wrap" />
                  </StackPanel>
                  <Button DockPanel.Dock="Bottom"
                          Classes="secondary"
                          HorizontalAlignment="Stretch"
                          Margin="0,12,0,0"
                          Content="{Binding AddProviderText}"
                          Command="{Binding AddProviderCommand}" />
                  <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ProviderOptions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ProviderOptionViewModel}">
                          <Button Classes="nav"
                                  ctl:SelectedClass.IsSelected="{Binding IsSelected}"
                                  Command="{Binding SelectCommand}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Left"
                                  Margin="0,0,0,6"
                                  Padding="12,10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                              <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProviderId}" Classes="mono" FontSize="11" Opacity="0.85" />
                              </StackPanel>
                              <Border Grid.Column="1" Classes="chip" VerticalAlignment="Center" Padding="8,2">
                                <TextBlock Text="{Binding KeyStatus}" Classes="caption" />
                              </Border>
                            </Grid>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </DockPanel>

                <!-- 当前供应商编辑 -->
                <StackPanel Grid.Column="1" Spacing="12">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Grid.Column="0" Text="{Binding ProviderEditorTitle}" Classes="subtitle" VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Classes="danger"
                            Content="{Binding RemoveProviderText}"
                            Command="{Binding RemoveProviderCommand}" />
                  </Grid>
                  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="140,*" RowSpacing="12" ColumnSpacing="14">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ProviderIdLabel}" Classes="secondary" VerticalAlignment="Center" />
                    <!-- 已落库供应商禁止改 ID（反人类误改）；草稿可编辑 -->
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding ProviderId, Mode=TwoWay}"
                             Classes="mono"
                             AutomationProperties.Name="{Binding ProviderIdLabel}"
                             IsReadOnly="{Binding !IsSelectedProviderDraft}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ProviderTypeLabel}" Classes="secondary" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              ItemsSource="{Binding ProviderTypeOptions}"
                              SelectedValue="{Binding ProviderType, Mode=TwoWay}"
                              SelectedValueBinding="{Binding Value}"
                              AutomationProperties.Name="{Binding ProviderTypeLabel}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SettingsValueOption">
                          <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding ProviderDisplayNameLabel}" Classes="secondary" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ProviderDisplayName, Mode=TwoWay}"
                             AutomationProperties.Name="{Binding ProviderDisplayNameLabel}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding BaseUrlLabel}" Classes="secondary" VerticalAlignment="Center" />
                    <TextBox Grid.Row="3" Grid.Column="1"
                             Text="{Binding ProviderBaseUrl, Mode=TwoWay}"
                             PlaceholderText="{Binding BaseUrlPlaceholder}"
                             AutomationProperties.Name="{Binding BaseUrlLabel}"
                             AutomationProperties.HelpText="{Binding BaseUrlPlaceholder}" />
                    <WrapPanel Grid.Row="4" Grid.Column="1">
                      <CheckBox Margin="0,0,18,8" IsChecked="{Binding ProviderEnabled, Mode=TwoWay}" Content="{Binding ProviderEnabledText}" />
                      <CheckBox Margin="0,0,18,8" IsChecked="{Binding MakeDefaultLlm, Mode=TwoWay}" Content="{Binding MakeDefaultLlmText}" />
                      <CheckBox Margin="0,0,18,8" IsChecked="{Binding MakeDefaultEmbedding, Mode=TwoWay}" Content="{Binding MakeDefaultEmbeddingText}" />
                      <CheckBox Margin="0,0,18,8" IsChecked="{Binding MakeDefaultReranker, Mode=TwoWay}" Content="{Binding MakeDefaultRerankerText}" />
                      <CheckBox Margin="0,0,18,8" IsChecked="{Binding MakeDefaultSearch, Mode=TwoWay}" Content="{Binding MakeDefaultSearchText}" />
                    </WrapPanel>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding ApiKeyLabel}" Classes="secondary" VerticalAlignment="Center" />
                    <Grid Grid.Row="5" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <TextBox Grid.Column="0"
                               Text="{Binding ApiKey, Mode=TwoWay}"
                               PlaceholderText="{Binding ApiKeyPlaceholder}"
                               PasswordChar="*"
                               AutomationProperties.Name="{Binding ApiKeyLabel}"
                               AutomationProperties.HelpText="{Binding ApiKeyPlaceholder}" />
                      <Button Grid.Column="1" Classes="secondary" Content="{Binding SaveKeyText}" Command="{Binding SaveProviderKeyCommand}" />
                    </Grid>
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding ProviderStatusLabel}" Classes="secondary" VerticalAlignment="Top" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ProviderStatus}" Classes="caption" TextWrapping="Wrap" />
                  </Grid>
                </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="12">
                <TextBlock x:Name="AvailableModelsSectionAnchor" Text="{Binding AvailableModelsSectionTitle}" Classes="subtitle" />
                <ItemsControl ItemsSource="{Binding AvailableModels}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ModelOptionViewModel}">
                      <Grid ColumnDefinitions="2*,140" ColumnSpacing="12" Margin="0,3">
                        <TextBlock Grid.Column="0" Text="{Binding ModelId}" TextWrapping="Wrap" />
                        <Border Grid.Column="1" Classes="chip" HorizontalAlignment="Left">
                          <TextBlock Text="{Binding CapabilityLabel}" Classes="caption" />
                        </Border>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="EmbeddingSectionAnchor" Text="{Binding EmbeddingSectionTitle}" Classes="subtitle" />
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="180,*" RowSpacing="12" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding EmbeddingModelLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="0" Grid.Column="1"
                           Text="{Binding EmbeddingModelId, Mode=TwoWay}"
                           PlaceholderText="{Binding EmbeddingModelPlaceholder}"
                           AutomationProperties.Name="{Binding EmbeddingModelLabel}"
                           AutomationProperties.HelpText="{Binding EmbeddingModelPlaceholder}" />
                  <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding MakeDefaultEmbedding, Mode=TwoWay}" Content="{Binding MakeDefaultEmbeddingText}" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="ManualModelsSectionAnchor" Text="{Binding ManualModelsSectionTitle}" Classes="subtitle" />
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="180,*" RowSpacing="12" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ModelsTextLabel}" Classes="secondary" VerticalAlignment="Top" />
                  <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                IsChecked="{Binding ManualModelsVisible, Mode=TwoWay}"
                                OnContent="" OffContent=""
                                Content="{Binding ManualModelsText}"
                                AutomationProperties.Name="{Binding ManualModelsText}" />
                  <TextBox Grid.Row="1" Grid.Column="1"
                           IsVisible="{Binding ManualModelsVisible}"
                           Text="{Binding ModelsText, Mode=TwoWay}"
                           PlaceholderText="{Binding ModelsPlaceholder}"
                           AcceptsReturn="True"
                           TextWrapping="NoWrap"
                           MinHeight="116"
                           AutomationProperties.Name="{Binding ModelsTextLabel}"
                           AutomationProperties.HelpText="{Binding ModelsPlaceholder}" />
                </Grid>
              </StackPanel>
            </Border>

            <Button Classes="primary" Content="{Binding SaveModelText}" HorizontalAlignment="Right" Command="{Binding SaveModelCommand}" />
          </StackPanel>

          <StackPanel IsVisible="{Binding IsPresetsSelected}" Spacing="18">
            <TextBlock Text="{Binding PresetsTitle}" Classes="title" />
            <TextBlock Text="{Binding PresetScopeHelpText}" Classes="caption" TextWrapping="Wrap" />
            <Border Classes="settings-section" Padding="22" IsEnabled="{Binding IsPresetsEditable}">
              <StackPanel Spacing="12">
                <TextBlock x:Name="NodePresetsSectionAnchor" Text="{Binding NodePresetsSectionTitle}" Classes="subtitle" />
                <Grid ColumnDefinitions="1.2*,2*,130,120" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="{Binding PresetNodeTypeLabel}" Classes="caption" />
                  <TextBlock Grid.Column="1" Text="{Binding PresetNodeModelLabel}" Classes="caption" />
                  <TextBlock Grid.Column="2" Text="{Binding PresetNodeTimeoutLabel}" Classes="caption" />
                  <TextBlock Grid.Column="3" Text="{Binding PresetNodeBudgetLabel}" Classes="caption" />
                </Grid>
                <ItemsControl ItemsSource="{Binding NodePresets}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NodeTypePresetViewModel}">
                      <StackPanel Spacing="8" Margin="0,4,0,10">
                        <Grid ColumnDefinitions="1.2*,2*,130,120" ColumnSpacing="12">
                          <TextBlock Grid.Column="0" Text="{Binding DisplayName}" VerticalAlignment="Center" TextWrapping="Wrap" />
                          <ComboBox Grid.Column="1"
                                    ItemsSource="{Binding $parent[UserControl].DataContext.AvailableLlmModelOptions}"
                                    SelectedItem="{Binding SelectedModelOption, Mode=TwoWay}"
                                    AutomationProperties.Name="{Binding $parent[UserControl].DataContext.PresetNodeModelLabel}"
                                    HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                              <DataTemplate DataType="{x:Type vm:WorkflowModelOption}">
                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                          <TextBox Grid.Column="2"
                                   Text="{Binding TimeoutMs, Mode=TwoWay}"
                                   AutomationProperties.Name="{Binding $parent[UserControl].DataContext.PresetNodeTimeoutLabel}" />
                          <TextBox Grid.Column="3"
                                   Text="{Binding BudgetUsd, Mode=TwoWay}"
                                   AutomationProperties.Name="{Binding $parent[UserControl].DataContext.PresetNodeBudgetLabel}" />
                        </Grid>
                        <Expander Header="{Binding $parent[UserControl].DataContext.PresetAccessTitle}">
                          <Border Classes="layer" Padding="14" Margin="0,6,0,0">
                            <StackPanel Spacing="10">
                              <CheckBox IsChecked="{Binding Permissions.InheritGlobal, Mode=TwoWay}"
                                        Content="{Binding $parent[UserControl].DataContext.InheritNodePermissionsText}" />
                              <StackPanel IsEnabled="{Binding Permissions.IsOverrideEnabled}" Spacing="8">
                                <WrapPanel>
                                  <CheckBox Margin="0,0,18,8" IsChecked="{Binding Permissions.AllowNetwork, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowNetworkText}" />
                                  <CheckBox Margin="0,0,18,8" IsEnabled="{Binding Permissions.AllowNetwork}" IsChecked="{Binding Permissions.AllowWebSearch, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowWebSearchText}" />
                                  <CheckBox Margin="0,0,18,8" IsEnabled="{Binding Permissions.AllowNetwork}" IsChecked="{Binding Permissions.AllowHttpSkill, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowHttpSkillText}" />
                                  <CheckBox Margin="0,0,18,8" IsEnabled="{Binding Permissions.AllowNetwork}" IsChecked="{Binding Permissions.AllowWasmNetwork, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowWasmNetworkText}" />
                                  <CheckBox Margin="0,0,18,8" IsChecked="{Binding Permissions.AllowSecretRead, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowSecretReadText}" />
                                </WrapPanel>
                                <TextBox Text="{Binding Permissions.ReadableRootsText, Mode=TwoWay}"
                                         PlaceholderText="{Binding $parent[UserControl].DataContext.PathPlaceholder}"
                                         AcceptsReturn="True" MinHeight="64"
                                         AutomationProperties.Name="{Binding $parent[UserControl].DataContext.ReadableRootsLabel}" />
                                <TextBox Text="{Binding Permissions.WritableRootsText, Mode=TwoWay}"
                                         PlaceholderText="{Binding $parent[UserControl].DataContext.PathPlaceholder}"
                                         AcceptsReturn="True" MinHeight="64"
                                         AutomationProperties.Name="{Binding $parent[UserControl].DataContext.WritableRootsLabel}" />
                              </StackPanel>
                              <TextBlock Text="{Binding $parent[UserControl].DataContext.PresetToolsTitle}" Classes="caption" FontWeight="SemiBold" />
                              <ItemsControl ItemsSource="{Binding ToolControls}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate DataType="{x:Type vm:ToolControlItemViewModel}">
                                    <CheckBox Margin="0,0,18,8"
                                              IsThreeState="True"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              Content="{Binding DisplayName}" />
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </Expander>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Classes="primary" Content="{Binding SavePresetsText}" HorizontalAlignment="Right" Command="{Binding SavePresetsCommand}" />
              </StackPanel>
            </Border>

            <Border Classes="settings-section" Padding="22" IsEnabled="{Binding IsPresetsEditable}">
              <StackPanel Spacing="14">
                <TextBlock x:Name="DefaultsSectionAnchor" Text="{Binding DefaultsSectionTitle}" Classes="subtitle" />
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="180,*" RowSpacing="12" ColumnSpacing="18">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DefaultModelLabel}" Classes="secondary" VerticalAlignment="Center" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding AvailableLlmModelOptions}"
                          SelectedItem="{Binding SelectedDefaultModelOption, Mode=TwoWay}"
                          AutomationProperties.Name="{Binding DefaultModelLabel}"
                          HorizontalAlignment="Stretch">
                  <ComboBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:WorkflowModelOption}">
                      <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DefaultTimeoutLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DefaultTimeoutMs, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding DefaultTimeoutLabel}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding DefaultBudgetLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DefaultBudgetUsd, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding DefaultBudgetLabel}" />
                <Button Grid.Row="3" Grid.Column="1" Classes="primary" Content="{Binding SavePresetsText}" HorizontalAlignment="Right" Command="{Binding SavePresetsCommand}" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Classes="settings-section" Padding="22" IsEnabled="{Binding IsTemplateRepositoryEditable}">
              <StackPanel Spacing="14">
                <TextBlock x:Name="TemplatesSectionAnchor" Text="{Binding TemplatesSectionTitle}" Classes="subtitle" />
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="180,*" RowSpacing="12" ColumnSpacing="18">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding TemplateRepositoryLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding TemplateRepositoryBaseUrl, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding TemplateRepositoryLabel}" />
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                  <Button Classes="secondary" Content="{Binding OpenTemplateMarketText}" Command="{Binding OpenTemplateMarketCommand}" />
                  <Button Classes="primary" Content="{Binding SaveTemplateRepositoryText}" Command="{Binding SaveTemplateRepositoryCommand}" />
                </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel IsVisible="{Binding IsAutomationSelected}" IsEnabled="{Binding IsAutomationEditable}" Spacing="18">
            <TextBlock Text="{Binding AutomationTitle}" Classes="title" />
            <TextBlock Text="{Binding AutomationScopeHelpText}" Classes="caption" TextWrapping="Wrap" />
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="BudgetSectionAnchor" Text="{Binding BudgetSectionTitle}" Classes="subtitle" />
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="180,*" RowSpacing="12" ColumnSpacing="18">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding BudgetLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding BudgetUsd, Mode=TwoWay}"
                         ToolTip.Tip="{Binding BudgetHelpText}"
                         AutomationProperties.Name="{Binding BudgetLabel}"
                         AutomationProperties.HelpText="{Binding BudgetHelpText}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding PreauthorizedBudgetLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding PreauthorizedUsd, Mode=TwoWay}"
                         ToolTip.Tip="{Binding PreauthorizedHelpText}"
                         AutomationProperties.Name="{Binding PreauthorizedBudgetLabel}"
                         AutomationProperties.HelpText="{Binding PreauthorizedHelpText}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding SpentLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SpentText}" Classes="caption" VerticalAlignment="Center"
                           AutomationProperties.Name="{Binding SpentLabel}" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="ConfirmationsSectionAnchor"
                           Text="{Binding ConfirmationsSectionTitle}"
                           Classes="subtitle"
                           ToolTip.Tip="{Binding ConfirmationPolicyHelpText}"
                           AutomationProperties.HelpText="{Binding ConfirmationPolicyHelpText}" />
                <Grid ColumnDefinitions="*,180,180" ColumnSpacing="12">
                  <TextBlock Grid.Column="1" Text="{Binding NormalModeLabel}" Classes="caption" />
                  <TextBlock Grid.Column="2" Text="{Binding AutoModePolicyLabel}" Classes="caption" />
                </Grid>
                <!-- 按总结机制分组。 -->
                <ItemsControl ItemsSource="{Binding ConfirmationPolicyGroups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ConfirmationPolicyGroupViewModel}">
                      <Border Margin="0,0,0,10" Padding="0,4,0,0">
                        <StackPanel Spacing="8">
                          <TextBlock Text="{Binding Title}" Classes="subtitle" FontWeight="SemiBold" />
                          <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="{x:Type vm:ConfirmationPolicyViewModel}">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,180,180" ColumnSpacing="12" RowSpacing="8" Margin="0,3,0,10">
                                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                  <ToggleSwitch Grid.Row="0" Grid.Column="1"
                                                IsChecked="{Binding NormalAllowByDefault, Mode=TwoWay}"
                                                OnContent="{Binding $parent[UserControl].DataContext.PolicyAllowText}"
                                                OffContent="{Binding $parent[UserControl].DataContext.PolicyReviewText}"
                                                AutomationProperties.Name="{Binding Label}"
                                                AutomationProperties.HelpText="{Binding $parent[UserControl].DataContext.NormalModeLabel}" />
                                  <ToggleSwitch Grid.Row="0" Grid.Column="2"
                                                IsChecked="{Binding AutoModeAutoApproval, Mode=TwoWay}"
                                                OnContent="{Binding $parent[UserControl].DataContext.PolicyAutoOnText}"
                                                OffContent="{Binding $parent[UserControl].DataContext.PolicyAutoOffText}"
                                                AutomationProperties.Name="{Binding Label}"
                                                AutomationProperties.HelpText="{Binding $parent[UserControl].DataContext.AutoModePolicyLabel}" />
                                  <Expander Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                            Header="{Binding $parent[UserControl].DataContext.ApprovalPromptLabel}">
                                    <TextBox Margin="0,6,0,0"
                                             Text="{Binding ApprovalPrompt, Mode=TwoWay}"
                                             PlaceholderText="{Binding $parent[UserControl].DataContext.ApprovalPromptPlaceholder}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="68"
                                             AutomationProperties.Name="{Binding $parent[UserControl].DataContext.ApprovalPromptLabel}"
                                             AutomationProperties.HelpText="{Binding $parent[UserControl].DataContext.ApprovalPromptPlaceholder}" />
                                  </Expander>
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="RuntimeSectionAnchor" Text="{Binding RuntimeSectionTitle}" Classes="subtitle" />
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="220,*" RowSpacing="12" ColumnSpacing="18">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding WorkflowDefaultTimeoutLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WorkflowDefaultTimeoutMs, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding WorkflowDefaultTimeoutLabel}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding MaxLoopIterationsLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MaxLoopIterations, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding MaxLoopIterationsLabel}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding MaxToolRoundsLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MaxToolRounds, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding MaxToolRoundsLabel}" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding RuntimeAutosaveLabel}" Classes="secondary" VerticalAlignment="Center" />
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RuntimeAutosaveMs, Mode=TwoWay}"
                         AutomationProperties.Name="{Binding RuntimeAutosaveLabel}" />
                <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding CheckpointEnabled, Mode=TwoWay}" Content="{Binding CheckpointEnabledLabel}" />
                </Grid>
              </StackPanel>
            </Border>
            <Button Classes="primary" Content="{Binding SaveAutomationText}" HorizontalAlignment="Right" Command="{Binding SaveAutomationCommand}" />
          </StackPanel>

          <StackPanel IsVisible="{Binding IsPermissionsSelected}" IsEnabled="{Binding IsPermissionsEditable}" Spacing="18">
            <TextBlock Text="{Binding PermissionsTitle}" Classes="title" />
            <TextBlock Text="{Binding PermissionsScopeHelpText}" Classes="caption" TextWrapping="Wrap" />
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="12">
                <TextBlock x:Name="CapabilitiesSectionAnchor"
                           Text="{Binding CapabilitiesSectionTitle}"
                           Classes="subtitle"
                           ToolTip.Tip="{Binding GlobalDefaultsHelpText}"
                           AutomationProperties.HelpText="{Binding GlobalDefaultsHelpText}" />
                <WrapPanel>
                  <CheckBox Margin="0,0,18,8" IsChecked="{Binding AllowNetwork, Mode=TwoWay}" Content="{Binding AllowNetworkText}" />
                  <CheckBox Margin="0,0,18,8" IsEnabled="{Binding AllowNetwork}" IsChecked="{Binding AllowWebSearch, Mode=TwoWay}" Content="{Binding AllowWebSearchText}" />
                  <CheckBox Margin="0,0,18,8" IsEnabled="{Binding AllowNetwork}" IsChecked="{Binding AllowHttpSkill, Mode=TwoWay}" Content="{Binding AllowHttpSkillText}" />
                  <CheckBox Margin="0,0,18,8" IsEnabled="{Binding AllowNetwork}" IsChecked="{Binding AllowWasmNetwork, Mode=TwoWay}" Content="{Binding AllowWasmNetworkText}" />
                  <CheckBox Margin="0,0,18,8" IsChecked="{Binding AllowSecretRead, Mode=TwoWay}" Content="{Binding AllowSecretReadText}" />
                </WrapPanel>
              </StackPanel>
            </Border>
            <ItemsControl ItemsSource="{Binding ScopedPermissionProfiles}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:PermissionScopeProfileViewModel}">
                  <Border Classes="settings-section" Padding="22" Margin="0,0,0,14">
                    <StackPanel Spacing="12">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Classes="subtitle" />
                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding InheritGlobal, Mode=TwoWay}"
                                  Content="{Binding $parent[UserControl].DataContext.InheritGlobalText}" />
                      </Grid>
                      <StackPanel IsEnabled="{Binding IsOverrideEnabled}" Spacing="12">
                        <WrapPanel>
                          <CheckBox Margin="0,0,18,8" IsChecked="{Binding AllowNetwork, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowNetworkText}" />
                          <CheckBox Margin="0,0,18,8" IsEnabled="{Binding AllowNetwork}" IsChecked="{Binding AllowWebSearch, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowWebSearchText}" />
                          <CheckBox Margin="0,0,18,8" IsEnabled="{Binding AllowNetwork}" IsChecked="{Binding AllowHttpSkill, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowHttpSkillText}" />
                          <CheckBox Margin="0,0,18,8" IsEnabled="{Binding AllowNetwork}" IsChecked="{Binding AllowWasmNetwork, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowWasmNetworkText}" />
                          <CheckBox Margin="0,0,18,8" IsChecked="{Binding AllowSecretRead, Mode=TwoWay}" Content="{Binding $parent[UserControl].DataContext.AllowSecretReadText}" />
                        </WrapPanel>
                        <TextBox Text="{Binding ReadableRootsText, Mode=TwoWay}"
                                 PlaceholderText="{Binding $parent[UserControl].DataContext.PathPlaceholder}"
                                 AcceptsReturn="True"
                                 MinHeight="76"
                                 AutomationProperties.Name="{Binding $parent[UserControl].DataContext.ReadableRootsLabel}" />
                        <TextBox Text="{Binding WritableRootsText, Mode=TwoWay}"
                                 PlaceholderText="{Binding $parent[UserControl].DataContext.PathPlaceholder}"
                                 AcceptsReturn="True"
                                 MinHeight="76"
                                 AutomationProperties.Name="{Binding $parent[UserControl].DataContext.WritableRootsLabel}" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="ToolControlsSectionAnchor" Text="{Binding ToolControlsSectionTitle}" Classes="subtitle" />
                <ItemsControl ItemsSource="{Binding ToolControlGroups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ToolControlGroupViewModel}">
                      <StackPanel Spacing="10" Margin="0,0,0,18">
                        <TextBlock Text="{Binding DisplayName}" Classes="secondary" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding $parent[UserControl].DataContext.SafeToolsTitle}"
                                   Classes="caption"
                                   IsVisible="{Binding HasSafeControls}" />
                        <ItemsControl ItemsSource="{Binding SafeControls}" IsVisible="{Binding HasSafeControls}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ToolControlItemViewModel}">
                              <CheckBox Margin="0,0,18,8"
                                        IsThreeState="{Binding CanInherit}"
                                        IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                        Content="{Binding DisplayName}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Classes="danger-panel" IsVisible="{Binding HasDangerControls}" Margin="0,4,0,0">
                          <StackPanel Spacing="8">
                            <TextBlock Text="{Binding $parent[UserControl].DataContext.DangerToolsTitle}"
                                       Foreground="{DynamicResource Ariadne.StatusWarning}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding $parent[UserControl].DataContext.DangerToolsHelp}"
                                       Classes="caption"
                                       TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding DangerControls}">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <WrapPanel />
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ToolControlItemViewModel}">
                                  <CheckBox Margin="0,0,18,8"
                                            IsThreeState="{Binding CanInherit}"
                                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                            Content="{Binding DisplayName}"
                                            Foreground="{DynamicResource Ariadne.StatusWarning}" />
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="PathsSectionAnchor" Text="{Binding PathsSectionTitle}" Classes="subtitle" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <StackPanel Grid.Column="0" Spacing="8">
                  <TextBlock Text="{Binding ReadableRootsLabel}" Classes="secondary" />
                  <TextBox Text="{Binding ReadableRootsText, Mode=TwoWay}"
                           PlaceholderText="{Binding PathPlaceholder}"
                           AcceptsReturn="True"
                           MinHeight="130"
                           AutomationProperties.Name="{Binding ReadableRootsLabel}"
                           AutomationProperties.HelpText="{Binding PathPlaceholder}" />
                  <Button Classes="secondary" HorizontalAlignment="Left" Content="{Binding BrowseFolderText}" Command="{Binding BrowseReadableRootsCommand}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="8">
                  <TextBlock Text="{Binding WritableRootsLabel}" Classes="secondary" />
                  <TextBox Text="{Binding WritableRootsText, Mode=TwoWay}"
                           PlaceholderText="{Binding PathPlaceholder}"
                           AcceptsReturn="True"
                           MinHeight="130"
                           AutomationProperties.Name="{Binding WritableRootsLabel}"
                           AutomationProperties.HelpText="{Binding PathPlaceholder}" />
                  <Button Classes="secondary" HorizontalAlignment="Left" Content="{Binding BrowseFolderText}" Command="{Binding BrowseWritableRootsCommand}" />
                </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
            <Button Classes="primary" Content="{Binding SavePermissionsText}" HorizontalAlignment="Right" Command="{Binding SavePermissionsCommand}" />
          </StackPanel>

          <StackPanel IsVisible="{Binding IsPersonalizationSelected}" IsEnabled="{Binding IsPersonalizationEditable}" Spacing="18">
            <TextBlock Text="{Binding PersonalizationTitle}" Classes="title" />
            <TextBlock Text="{Binding PersonalizationScopeHelpText}" Classes="caption" TextWrapping="Wrap" />
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="LanguageSectionAnchor" Text="{Binding LanguageSectionTitle}" Classes="subtitle" />
                <Grid ColumnDefinitions="180,*" ColumnSpacing="18">
                  <TextBlock Grid.Column="0" Text="{Binding LanguageLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding LanguageOptions}"
                            SelectedValue="{Binding SelectedLanguage, Mode=TwoWay}"
                            SelectedValueBinding="{Binding Code}"
                            AutomationProperties.Name="{Binding LanguageLabel}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate DataType="{x:Type vm:LanguageOption}">
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </Grid>
              </StackPanel>
            </Border>
            <!-- 调色板：对齐 settings-theme-spec §6，分组 swatch 卡片（无 WebUI） -->
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="18">
                <TextBlock x:Name="ThemeSectionAnchor"
                           Text="{Binding ThemeSectionTitle}"
                           Classes="subtitle"
                           ToolTip.Tip="{Binding ThemePaletteHelpText}"
                           AutomationProperties.HelpText="{Binding ThemePaletteHelpText}" />

                <!-- 按组排版的调色板卡片 -->
                <ItemsControl ItemsSource="{Binding ThemeGroups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ThemeGroupViewModel}">
                      <StackPanel Spacing="10" Margin="0,0,0,16">
                        <TextBlock Text="{Binding Title}" Classes="secondary" FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{Binding Options}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ThemeOption}">
                              <Button Classes="theme-swatch"
                                      ctl:SelectedClass.IsSelected="{Binding IsSelected}"
                                      Command="{Binding SelectCommand}"
                                      Margin="0,0,10,10"
                                      MinHeight="118"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Padding="14,12">
                                <StackPanel Spacing="8">
                                  <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <Border Grid.Column="1" Width="10" Height="10" CornerRadius="5"
                                            Background="{DynamicResource Ariadne.AccentPrimary}"
                                            IsVisible="{Binding IsSelected}"
                                            VerticalAlignment="Top" Margin="6,2,0,0" />
                                  </Grid>
                                  <Border Height="28" CornerRadius="6" ClipToBounds="True">
                                    <Grid ColumnDefinitions="*,*,*">
                                      <Border Grid.Column="0" Background="{Binding SwatchMain}" />
                                      <Border Grid.Column="1" Background="{Binding SwatchSurface}" />
                                      <Border Grid.Column="2" Background="{Binding SwatchBrand}" />
                                    </Grid>
                                  </Border>
                                  <TextBlock Text="{Binding Description}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 主题自定义三色：折叠色块点开调色板；可跟随系统并分别调昼/夜 -->
                <Border Height="1" Background="{DynamicResource Ariadne.BorderMuted}" Margin="0,4" />
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding ThemeCustomThreeLabel}" Classes="subtitle" />
                  <TextBlock Text="{Binding ThemeCustomThreeHint}" Classes="caption" TextWrapping="Wrap" />
                </StackPanel>
                <Border Classes="layer" Padding="14">
                  <StackPanel Spacing="12">
                    <CheckBox IsChecked="{Binding ThemeFollowSystemColors, Mode=TwoWay}"
                              Content="{Binding ThemeFollowSystemColorsText}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding ThemeFollowSystemColors}">
                      <Button Classes="tab"
                              ctl:SelectedClass.IsSelected="{Binding IsEditingDayThemeColors}"
                              Content="{Binding ThemeEditDayText}"
                              Command="{Binding SelectThemeEditDayCommand}"
                              MinWidth="72" Padding="12,6" />
                      <Button Classes="tab"
                              ctl:SelectedClass.IsSelected="{Binding IsEditingNightThemeColors}"
                              Content="{Binding ThemeEditNightText}"
                              Command="{Binding SelectThemeEditNightCommand}"
                              MinWidth="72" Padding="12,6" />
                    </StackPanel>
                    <UniformGrid Columns="3" Margin="0,0,0,4">
                      <Button Classes="theme-color-slot"
                              ctl:SelectedClass.IsSelected="{Binding IsThemeMainChannelActive}"
                              Command="{Binding SelectThemeMainChannelCommand}"
                              Margin="0,0,8,0"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              Padding="10,8">
                        <StackPanel Spacing="6">
                          <TextBlock Text="{Binding ThemeMainColorLabel}" Classes="caption" />
                          <Border Height="28" CornerRadius="6"
                                  Background="{Binding ThemeMainColorEditor.PreviewBrush}"
                                  BorderBrush="{DynamicResource Ariadne.BorderDefault}"
                                  BorderThickness="1" />
                        </StackPanel>
                      </Button>
                      <Button Classes="theme-color-slot"
                              ctl:SelectedClass.IsSelected="{Binding IsThemeSurfaceChannelActive}"
                              Command="{Binding SelectThemeSurfaceChannelCommand}"
                              Margin="0,0,8,0"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              Padding="10,8">
                        <StackPanel Spacing="6">
                          <TextBlock Text="{Binding ThemeSurfaceColorLabel}" Classes="caption" />
                          <Border Height="28" CornerRadius="6"
                                  Background="{Binding ThemeSurfaceColorEditor.PreviewBrush}"
                                  BorderBrush="{DynamicResource Ariadne.BorderDefault}"
                                  BorderThickness="1" />
                        </StackPanel>
                      </Button>
                      <Button Classes="theme-color-slot"
                              ctl:SelectedClass.IsSelected="{Binding IsThemeBrandChannelActive}"
                              Command="{Binding SelectThemeBrandChannelCommand}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              Padding="10,8">
                        <StackPanel Spacing="6">
                          <TextBlock Text="{Binding ThemeBrandColorLabel}" Classes="caption" />
                          <Border Height="28" CornerRadius="6"
                                  Background="{Binding ThemeBrandColorEditor.PreviewBrush}"
                                  BorderBrush="{DynamicResource Ariadne.BorderDefault}"
                                  BorderThickness="1" />
                        </StackPanel>
                      </Button>
                    </UniformGrid>
                    <!-- 折叠色块；点击弹出完整调色板（无全页变黑） -->
                    <ctl:SpectrumColorPicker SelectedHex="{Binding ActiveThemeColorHex, Mode=TwoWay}"
                                             AccessibleName="{Binding ActiveThemeColorLabel}" />
                  </StackPanel>
                </Border>

                <Border Height="1" Background="{DynamicResource Ariadne.BorderMuted}" Margin="0,4" />
                <TextBlock Text="{Binding ColorMapHintText}" Classes="caption" TextWrapping="Wrap" />

                <!-- Git 自动色 -->
                <StackPanel Spacing="8" Margin="0,4,0,0">
                  <TextBlock Text="{Binding GitAutoColorLabel}" Classes="secondary" FontWeight="SemiBold" />
                  <ctl:SpectrumColorPicker SelectedHex="{Binding GitAutoColor, Mode=TwoWay}"
                                           AccessibleName="{Binding GitAutoColorLabel}" />
                </StackPanel>

                <!-- Git 手动色 -->
                <StackPanel Spacing="8">
                  <TextBlock Text="{Binding GitManualColorLabel}" Classes="secondary" FontWeight="SemiBold" />
                  <ctl:SpectrumColorPicker SelectedHex="{Binding GitManualColor, Mode=TwoWay}"
                                           AccessibleName="{Binding GitManualColorLabel}" />
                </StackPanel>
              </StackPanel>
            </Border>
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="WorkspaceSectionAnchor" Text="{Binding WorkspaceSectionTitle}" Classes="subtitle" />
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="180,*" RowSpacing="12" ColumnSpacing="18">
                  <CheckBox Grid.Row="0" Grid.Column="1"
                            IsChecked="{Binding ProjectPanelVisible, Mode=TwoWay}"
                            Content="{Binding ProjectPanelVisibleText}" />
                  <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                    <CheckBox IsChecked="{Binding ReduceMotion, Mode=TwoWay}"
                              Content="{Binding ReduceMotionText}" />
                    <TextBlock Text="{Binding ReduceMotionHintText}"
                               Classes="caption"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
            <Button Classes="primary" Content="{Binding SavePersonalizationText}" HorizontalAlignment="Right" Command="{Binding SavePersonalizationCommand}" />
          </StackPanel>

          <StackPanel IsVisible="{Binding IsMiscSelected}" Spacing="18">
            <TextBlock Text="{Binding MiscTitle}" Classes="title" />
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="TutorialSectionAnchor" Text="{Binding TutorialText}" Classes="subtitle" />
                <Button Classes="secondary"
                        HorizontalAlignment="Left"
                        Content="{Binding OpenTutorialText}"
                        Command="{Binding ShowTutorialCommand}"
                        AutomationProperties.Name="{Binding OpenTutorialText}" />
              </StackPanel>
            </Border>
            <StackPanel Spacing="18">
            <Border Classes="settings-section" Padding="22" IsEnabled="{Binding IsAppRuntimeEditable}">
              <StackPanel Spacing="14">
                <TextBlock x:Name="AppRuntimeSectionAnchor" Text="{Binding AppRuntimeSectionTitle}" Classes="subtitle" />
                <TextBlock Text="{Binding AppRuntimeScopeHelpText}" Classes="caption" TextWrapping="Wrap" />
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="220,*" RowSpacing="12" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding QdrantBinaryPathLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding QdrantBinaryPath, Mode=TwoWay}"
                           AutomationProperties.Name="{Binding QdrantBinaryPathLabel}" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding QdrantStartupTimeoutLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding QdrantStartupTimeoutMs, Mode=TwoWay}"
                           AutomationProperties.Name="{Binding QdrantStartupTimeoutLabel}" />
                </Grid>
                <Button Classes="primary" Content="{Binding SaveAppRuntimeText}" HorizontalAlignment="Right" Command="{Binding SaveAppRuntimeCommand}" />
              </StackPanel>
            </Border>
            <Border Classes="settings-section" Padding="22" IsEnabled="{Binding IsMiscEditable}">
              <StackPanel Spacing="14">
                <TextBlock x:Name="RetrievalSectionAnchor" Text="{Binding RetrievalSectionTitle}" Classes="subtitle" />
                <TextBlock Text="{Binding RetrievalScopeHelpText}" Classes="caption" TextWrapping="Wrap" />
                <CheckBox IsChecked="{Binding VectorEnabled, Mode=TwoWay}" Content="{Binding VectorEnabledText}" />
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="220,*" RowSpacing="12" ColumnSpacing="18">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding VectorBackendLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <ComboBox Grid.Row="0" Grid.Column="1"
                            ItemsSource="{Binding VectorBackendOptions}"
                            SelectedValue="{Binding VectorBackend, Mode=TwoWay}"
                            SelectedValueBinding="{Binding Value}"
                            AutomationProperties.Name="{Binding VectorBackendLabel}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:SettingsValueOption">
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding VectorCollectionLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding VectorCollection, Mode=TwoWay}"
                           AutomationProperties.Name="{Binding VectorCollectionLabel}" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding VectorDimensionsLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding VectorDimensions, Mode=TwoWay}"
                           AutomationProperties.Name="{Binding VectorDimensionsLabel}" />
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding QdrantHostLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding QdrantHost, Mode=TwoWay}"
                           AutomationProperties.Name="{Binding QdrantHostLabel}" />
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding QdrantPortLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding QdrantPort, Mode=TwoWay}"
                           AutomationProperties.Name="{Binding QdrantPortLabel}" />
                  <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding QdrantDataDirLabel}" Classes="secondary" VerticalAlignment="Center" IsVisible="{Binding IsQdrantSidecarBackend}" />
                  <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding QdrantDataDir, Mode=TwoWay}"
                           IsVisible="{Binding IsQdrantSidecarBackend}"
                           AutomationProperties.Name="{Binding QdrantDataDirLabel}" />
                  <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding ChunkSizeLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ChunkSizeChars, Mode=TwoWay}"
                           AutomationProperties.Name="{Binding ChunkSizeLabel}" />
                  <TextBlock Grid.Row="7" Grid.Column="0" Text="{Binding ChunkOverlapLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding ChunkOverlapChars, Mode=TwoWay}"
                           AutomationProperties.Name="{Binding ChunkOverlapLabel}" />
                </Grid>
                <CheckBox IsChecked="{Binding RerankerEnabled, Mode=TwoWay}" Content="{Binding RerankerEnabledText}" />
              </StackPanel>
            </Border>
            <Border Classes="settings-section" Padding="22" IsEnabled="{Binding IsMiscEditable}">
              <StackPanel Spacing="14">
                <TextBlock x:Name="GitSectionAnchor" Text="{Binding GitSectionTitle}" Classes="subtitle" />
                <WrapPanel>
                  <CheckBox Margin="0,0,18,8" IsChecked="{Binding TrackDocuments, Mode=TwoWay}" Content="{Binding TrackDocumentsText}" />
                  <CheckBox Margin="0,0,18,8" IsChecked="{Binding TrackWorkflows, Mode=TwoWay}" Content="{Binding TrackWorkflowsText}" />
                  <CheckBox Margin="0,0,18,8" IsChecked="{Binding TrackSkills, Mode=TwoWay}" Content="{Binding TrackSkillsText}" />
                  <CheckBox Margin="0,0,18,8" IsChecked="{Binding TrackNonSensitiveConfig, Mode=TwoWay}" Content="{Binding TrackConfigText}" />
                </WrapPanel>
                <TextBlock Text="{Binding IgnoredPathsLabel}" Classes="secondary" />
                <TextBox Text="{Binding IgnoredPathsText, Mode=TwoWay}"
                         PlaceholderText="{Binding IgnoredPathsPlaceholder}"
                         AcceptsReturn="True"
                         MinHeight="120"
                         AutomationProperties.Name="{Binding IgnoredPathsLabel}"
                         AutomationProperties.HelpText="{Binding IgnoredPathsPlaceholder}" />
              </StackPanel>
            </Border>
            <Border Classes="settings-section" Padding="22">
              <StackPanel Spacing="14">
                <TextBlock x:Name="DiagnosticsSectionAnchor" Text="{Binding DiagnosticsSectionTitle}" Classes="subtitle" />
                <Grid ColumnDefinitions="180,*" RowDefinitions="Auto" ColumnSpacing="18">
                  <TextBlock Grid.Column="0" Text="{Binding DiagnosticsLabel}" Classes="secondary" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding DiagnosticsStatusText}" Classes="caption" TextWrapping="Wrap" />
                </Grid>
              </StackPanel>
            </Border>
            <Button Classes="primary" Content="{Binding SaveMiscText}" HorizontalAlignment="Right" Command="{Binding SaveMiscCommand}" />
            </StackPanel>
          </StackPanel>
        </Panel>
      </ScrollViewer>

      <ListBox x:Name="SettingsSectionIndex"
               Classes="settings-section-index"
               ItemsSource="{Binding SectionIndexItems}"
               SelectedItem="{Binding SectionNavigationSelection, Mode=TwoWay}"
               SelectionMode="Single"
               Width="176"
               MaxHeight="560"
               Margin="0,18,12,18"
               HorizontalAlignment="Right"
               VerticalAlignment="Top"
               ZIndex="4"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:SettingsSectionNavigationItemViewModel}">
            <TextBlock Text="{Binding Title}"
                       TextWrapping="Wrap"
                       AutomationProperties.Name="{Binding Title}" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

    </Grid>
  </Grid>
</UserControl>
