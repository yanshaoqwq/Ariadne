<UserControl
    x:Class="Ariadne.Desktop.Views.GitPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="clr-namespace:Ariadne.Desktop.Controls"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:GitPageViewModel">
  <Grid ColumnDefinitions="*,Auto" Background="{DynamicResource Ariadne.BackgroundMain}">
    <Grid Grid.Column="0"
          RowDefinitions="Auto,Auto,*"
          Margin="24,18,20,20">
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="{Binding Title}" Classes="title" />
          <TextBlock Text="{Binding Description}" Classes="caption" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
          <TextBlock Text="{Binding OperationStatusText}"
                     Classes="caption"
                     VerticalAlignment="Center"
                     IsVisible="{Binding IsBusy}" />
          <Button Classes="secondary"
                  Content="{Binding RefreshText}"
                  Command="{Binding RefreshCommand}" />
          <Button Classes="subtle"
                  Content="{Binding ToggleRightPanelText}"
                  Command="{Binding ToggleRightPanelCommand}" />
        </StackPanel>
      </Grid>

      <TextBlock Grid.Row="1"
                 Text="{Binding StatusText}"
                 Classes="caption"
                 Margin="0,10,0,10"
                 TextWrapping="Wrap" />

      <Grid Grid.Row="2">
        <ListBox ItemsSource="{Binding Commits}"
                 SelectedItem="{Binding SelectedCommit, Mode=TwoWay}"
                 SelectionMode="Single"
                 Background="Transparent"
                 BorderThickness="0"
                 IsVisible="{Binding HasCommits}"
                 AutomationProperties.Name="{Binding BranchGraphText}">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0,0,0,8" />
              <Setter Property="MinHeight" Value="78" />
              <Setter Property="Background" Value="{DynamicResource Ariadne.BackgroundSurface}" />
              <Setter Property="BorderBrush" Value="{DynamicResource Ariadne.BorderMuted}" />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="CornerRadius" Value="8" />
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Background" Value="{DynamicResource Ariadne.BackgroundSubtle}" />
              <Setter Property="BorderBrush" Value="{DynamicResource Ariadne.BorderDefault}" />
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Background" Value="{DynamicResource Ariadne.AccentLight}" />
              <Setter Property="BorderBrush" Value="{DynamicResource Ariadne.AccentPrimary}" />
              <Setter Property="BorderThickness" Value="2" />
            </Style>
            <Style Selector="ListBoxItem:focus">
              <Setter Property="BorderBrush" Value="{DynamicResource Ariadne.AccentPrimary}" />
              <Setter Property="BorderThickness" Value="2" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:GitHistoryItemViewModel}">
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="12"
                    Margin="14,10">
                <Grid Grid.Column="0" ColumnDefinitions="Auto,18,64">
                  <Border Grid.Column="0" Width="{Binding LaneOffset}" />
                  <Grid Grid.Column="1">
                    <Border Width="2"
                            Background="{DynamicResource Ariadne.BorderDefault}"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding HasGraphContinuation}" />
                    <Ellipse Width="12"
                             Height="12"
                             Fill="{DynamicResource Ariadne.AccentPrimary}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                  </Grid>
                  <TextBlock Grid.Column="2"
                             Text="{Binding ShortCommitId}"
                             Classes="mono"
                             Margin="8,0,0,0"
                             VerticalAlignment="Center" />
                </Grid>

                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" RowSpacing="5">
                  <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Summary}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RelativeTimeText}"
                               Classes="caption"
                               HorizontalAlignment="Right" />
                  </Grid>
                  <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Grid.Column="0"
                               Text="{Binding RefsText}"
                               Classes="caption"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasRefs}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding AuthorText}"
                               Classes="caption"
                               HorizontalAlignment="Right"
                               TextWrapping="Wrap" />
                  </Grid>
                  <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6">
                    <Border Classes="chip"
                            Padding="7,2"
                            IsVisible="{Binding IsHead}">
                      <TextBlock Text="{Binding HeadBadgeText}" Classes="caption" FontWeight="SemiBold" />
                    </Border>
                    <Border Classes="chip"
                            Padding="7,2"
                            IsVisible="{Binding IsMerge}">
                      <TextBlock Text="{Binding MergeBadgeText}" Classes="caption" />
                    </Border>
                    <Border Classes="chip"
                            Padding="7,2"
                            IsVisible="{Binding HasKind}">
                      <TextBlock Text="{Binding KindText}" Classes="caption" />
                    </Border>
                  </StackPanel>
                </Grid>

                <Grid.ContextMenu>
                  <ContextMenu Classes="ariadne">
                    <MenuItem Header="{Binding ViewDetailsText}" Command="{Binding ViewDetailsCommand}" />
                    <Separator />
                    <MenuItem Header="{Binding RestoreText}" Command="{Binding RestoreCommand}" />
                    <MenuItem Header="{Binding CopyIdText}" Command="{Binding CopyIdCommand}" />
                  </ContextMenu>
                </Grid.ContextMenu>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Classes="empty-state" IsVisible="{Binding IsCommitListEmpty}" Margin="0,36,0,0">
          <StackPanel Spacing="8" HorizontalAlignment="Center" MaxWidth="360">
            <ctl:EmptyStateArt Kind="GitRag" Width="140" Height="112" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding EmptyTitle}" Classes="subtitle" HorizontalAlignment="Center" TextAlignment="Center" />
            <TextBlock Text="{Binding EmptyHint}" Classes="caption" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Column="1"
            Width="340"
            Background="{DynamicResource Ariadne.BackgroundSurface}"
            BorderBrush="{DynamicResource Ariadne.BorderMuted}"
            BorderThickness="1,0,0,0"
            IsVisible="{Binding IsRightPanelOpen}">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="20,16,14,8">
          <TextBlock Grid.Column="0" Text="{Binding DetailsText}" Classes="subtitle" VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Classes="subtle"
                  Content="{Binding ToggleRightPanelText}"
                  Command="{Binding ToggleRightPanelCommand}" />
        </Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="20,0,20,20" Spacing="16">
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding RepositoryStatusLabel}" Classes="subtitle" />
              <Grid ColumnDefinitions="96,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding RepositoryStatusLabel}" Classes="subtle" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RepositoryStatusText}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding CurrentBranchLabel}" Classes="subtle" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentBranchText}" Classes="mono" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding HeadLabel}" Classes="subtle" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HeadText}" Classes="mono" TextWrapping="Wrap" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding DirtyStateLabel}" Classes="subtle" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DirtyStateText}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding DiffSummaryLabel}" Classes="subtle" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DiffSummaryText}" TextWrapping="Wrap" />
              </Grid>
              <StackPanel Spacing="3" IsVisible="{Binding HasRepositoryReason}">
                <TextBlock Text="{Binding RepositoryReasonLabel}" Classes="subtle" />
                <TextBlock Text="{Binding RepositoryReasonText}" TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>

            <Separator />

            <StackPanel Spacing="8">
              <TextBlock Text="{Binding CreateCheckpointText}" Classes="subtitle" />
              <TextBox Text="{Binding CheckpointMessage, Mode=TwoWay}"
                       PlaceholderText="{Binding CheckpointPlaceholder}"
                       IsEnabled="{Binding !IsBusy}" />
              <Button Classes="primary"
                      HorizontalAlignment="Stretch"
                      Content="{Binding CreateCheckpointText}"
                      Command="{Binding CreateCheckpointCommand}" />
            </StackPanel>

            <Separator />

            <StackPanel Spacing="8">
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding SummaryLabel}" Classes="subtle" />
                <TextBlock Text="{Binding SelectedSummary}" TextWrapping="Wrap" />
              </StackPanel>
              <Grid ColumnDefinitions="96,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding TimeLabel}" Classes="subtle" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedTime}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding AuthorLabel}" Classes="subtle" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAuthor}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding BranchRefsLabel}" Classes="subtle" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedRefs}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding KindLabel}" Classes="subtle" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedKind}" TextWrapping="Wrap" />
              </Grid>
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="{Binding RestoreBranchNameText}" Classes="subtle" />
              <TextBox Text="{Binding RestoreBranchName, Mode=TwoWay}" IsEnabled="{Binding !IsBusy}" />
              <Button Classes="secondary"
                      HorizontalAlignment="Stretch"
                      Content="{Binding RestoreNewBranchText}"
                      Command="{Binding RestoreCommand}" />
            </StackPanel>

            <Expander Header="{Binding TechnicalDetailsText}">
              <StackPanel Margin="0,8,0,0" Spacing="8">
                <StackPanel Spacing="3">
                  <TextBlock Text="{Binding CommitLabel}" Classes="subtle" />
                  <TextBlock Text="{Binding SelectedCommitId}" Classes="mono" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Spacing="3">
                  <TextBlock Text="{Binding ParentsLabel}" Classes="subtle" />
                  <TextBlock Text="{Binding SelectedParents}" Classes="mono" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Spacing="3" IsVisible="{Binding HasDiffPreview}">
                  <TextBlock Text="{Binding DiffPreviewLabel}" Classes="subtle" />
                  <Border Classes="layer" Padding="8">
                    <TextBlock Text="{Binding DiffPreviewText}"
                               Classes="mono"
                               TextWrapping="Wrap"
                               MaxHeight="220" />
                  </Border>
                </StackPanel>
              </StackPanel>
            </Expander>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
