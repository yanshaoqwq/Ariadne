<UserControl
    x:Class="Ariadne.Desktop.Views.GitPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:GitPageViewModel">
  <Grid ColumnDefinitions="*,Auto" Background="{DynamicResource Ariadne.BackgroundMain}">

    <Canvas x:Name="GitCanvas" Grid.Column="0"
            Background="{DynamicResource Ariadne.CanvasBackground}"
            ClipToBounds="True">
      <StackPanel Canvas.Left="24" Canvas.Top="18" Spacing="2">
        <TextBlock Text="{Binding Title}" Classes="title" />
        <TextBlock Text="{Binding Description}" Classes="caption" TextWrapping="Wrap" />
      </StackPanel>
      <Button Canvas.Right="20" Canvas.Top="18" Classes="secondary" Content="{Binding RefreshText}" Command="{Binding RefreshCommand}" />
      <TextBlock Canvas.Left="24" Canvas.Top="62" Text="{Binding StatusText}" Classes="caption" />

      <ScrollViewer Canvas.Left="0" Canvas.Top="82"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Width="780" Margin="24,12" Spacing="10">
          <ItemsControl ItemsSource="{Binding Commits}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:GitHistoryItemViewModel}">
                <Border Classes="layer" Padding="14,10" Margin="0,0,0,8"
                        PointerPressed="OnCommitPointerPressed">
                  <Border.ContextMenu>
                    <ContextMenu Classes="ariadne">
                      <MenuItem Header="{Binding ViewDetailsText}" Command="{Binding ViewDetailsCommand}" />
                      <MenuItem Header="{Binding CreateCheckpointText}" Command="{Binding CreateCheckpointCommand}" />
                      <Separator />
                      <MenuItem Header="{Binding RestoreText}" Command="{Binding RestoreCommand}" />
                      <MenuItem Header="{Binding CopyIdText}" Command="{Binding CopyIdCommand}" />
                    </ContextMenu>
                  </Border.ContextMenu>
                  <Grid ColumnDefinitions="Auto,120,*,120" ColumnSpacing="12">
                    <Button Grid.Column="0" Classes="subtle" Padding="0" Command="{Binding SelectCommand}">
                      <Ellipse Width="14" Height="14" Fill="{DynamicResource Ariadne.GitManual}" />
                    </Button>
                    <TextBlock Grid.Column="1" Text="{Binding ShortCommitId}" Classes="mono" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Spacing="2">
                      <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding RefsText}" Classes="caption" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="3" Classes="chip" HorizontalAlignment="Left" VerticalAlignment="Center">
                      <TextBlock Text="{Binding KindText}" Classes="caption" />
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Border Classes="layer" Padding="24" IsVisible="{Binding !HasSelection}">
            <TextBlock Text="{Binding EmptyText}" Classes="secondary" HorizontalAlignment="Center" />
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border x:Name="GitTogglePill"
              Canvas.Right="0"
              Width="22"
              Height="52"
              Background="{DynamicResource Ariadne.BackgroundSurface}"
              BorderBrush="{DynamicResource Ariadne.BorderDefault}"
              BorderThickness="1"
              CornerRadius="8,0,0,8"
              Cursor="Hand"
              ToolTip.Tip="{Binding ToggleRightPanelText}"
              PointerPressed="OnPillPointerPressed"
              PointerMoved="OnPillPointerMoved"
              PointerReleased="OnPillPointerReleased">
        <Path Classes="icon" Width="14" Height="14"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Data="{StaticResource Ariadne.Icon.ChevronRight}" />
      </Border>
    </Canvas>

    <Panel Grid.Column="1">
      <Border
          Width="300"
          Background="{DynamicResource Ariadne.BackgroundSurface}"
          BorderBrush="{DynamicResource Ariadne.BorderMuted}"
          BorderThickness="1,0,0,0"
          IsVisible="{Binding IsRightPanelOpen}">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="{Binding DetailsText}" Classes="subtitle" Margin="20,16,20,8" />
          <ScrollViewer>
            <StackPanel Margin="20,0,20,20" Spacing="16">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding CreateCheckpointText}" Classes="subtitle" />
                <TextBox Text="{Binding CheckpointMessage, Mode=TwoWay}" PlaceholderText="{Binding CheckpointPlaceholder}" />
                <Button Classes="primary" HorizontalAlignment="Stretch" Content="{Binding CreateCheckpointText}" Command="{Binding CreateCheckpointCommand}" />
              </StackPanel>

              <Separator />

              <StackPanel Spacing="3">
                <TextBlock Text="{Binding SummaryLabel}" Classes="subtle" />
                <TextBlock Text="{Binding SelectedSummary}" Classes="body" TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding CommitLabel}" Classes="subtle" />
                <TextBlock Text="{Binding SelectedCommitId}" Classes="mono" TextWrapping="Wrap" />
              </StackPanel>
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding KindLabel}" Classes="subtle" />
                <TextBlock Text="{Binding SelectedKind}" Classes="body" />
              </StackPanel>
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding ParentsLabel}" Classes="subtle" />
                <TextBlock Text="{Binding SelectedParents}" Classes="mono" TextWrapping="Wrap" />
              </StackPanel>

              <Separator />

              <StackPanel Spacing="6">
                <TextBlock Text="{Binding RestoreBranchNameText}" Classes="subtle" />
                <TextBox Text="{Binding RestoreBranchName, Mode=TwoWay}" />
                <Button Classes="secondary" HorizontalAlignment="Stretch" Content="{Binding RestoreNewBranchText}" Command="{Binding RestoreCommand}" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Button Classes="panel-float" Command="{Binding ToggleRightPanelCommand}"
              ToolTip.Tip="{Binding ToggleRightPanelText}"
              IsVisible="{Binding !IsRightPanelOpen}">
        <Path Classes="icon" Width="16" Height="16" Data="{StaticResource Ariadne.Icon.ChevronLeft}" />
      </Button>
    </Panel>
  </Grid>
</UserControl>
