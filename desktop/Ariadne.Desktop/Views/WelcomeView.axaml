<UserControl
    x:Class="Ariadne.Desktop.Views.WelcomeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:backend="clr-namespace:Ariadne.Desktop.Backend"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:WelcomeViewModel">

  <!-- 欢迎页：左品牌区 + 右最近项目，整屏居中、大留白、桌面感 -->
  <Grid RowDefinitions="*,Auto" Background="{DynamicResource Ariadne.WindowBase}">

    <Grid
        Grid.Row="0"
        MaxWidth="1040"
        Margin="64,56"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        ColumnDefinitions="1.05*,40,1.25*">

      <!-- 左：品牌 + 主操作 -->
      <DockPanel Grid.Column="0">
        <StackPanel DockPanel.Dock="Top" Spacing="18">
          <StackPanel Orientation="Horizontal" Spacing="14">
            <Border
                Width="52"
                Height="52"
                CornerRadius="14"
                Background="{DynamicResource Ariadne.AccentPrimary}"
                BoxShadow="{DynamicResource Ariadne.Shadow.Card}">
              <TextBlock
                  Text="{Binding BrandName, Converter={x:Static StringConverters.IsNullOrEmpty}, FallbackValue=A}"
                  IsVisible="False" />
            </Border>
            <StackPanel VerticalAlignment="Center" Spacing="2">
              <TextBlock Text="{Binding BrandName}" Classes="display" />
              <TextBlock Text="{Binding Subtitle}" Classes="secondary" TextWrapping="Wrap" MaxWidth="320" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Spacing="10" Margin="0,28,0,0">
          <Button Classes="primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Height="44" Content="{Binding CreateProjectText}" />
          <Button Classes="secondary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Height="44" Content="{Binding OpenProjectText}" />
          <Separator Margin="0,10" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Classes="subtle" Content="{Binding TutorialText}" />
            <Button Classes="subtle" Content="{Binding FeedbackText}" />
          </StackPanel>
        </StackPanel>

        <Border /><!-- DockPanel filler -->
      </DockPanel>

      <!-- 右：最近项目卡片 -->
      <Border
          Grid.Column="2"
          Classes="card"
          Padding="26">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0" Spacing="3" Margin="0,0,0,18">
            <TextBlock Text="{Binding RecentProjectsTitle}" Classes="title" />
            <TextBlock Text="{Binding StatusText}" Classes="caption" />
          </StackPanel>

          <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding RecentProjects}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type backend:RecentProjectEntry}">
                  <Border Classes="layer" Padding="14,12" Margin="0,0,0,10">
                    <Grid ColumnDefinitions="36,*">
                      <Border
                          Grid.Column="0"
                          Width="28"
                          Height="28"
                          CornerRadius="8"
                          VerticalAlignment="Center"
                          Background="{DynamicResource Ariadne.AccentLight}">
                        <Path
                            Classes="icon"
                            Width="15"
                            Height="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stroke="{DynamicResource Ariadne.AccentPrimary}"
                            Data="M5,4 L14,4 L19,9 L19,20 L5,20 Z M14,4 L14,9 L19,9 M8,13 L16,13 M8,16 L14,16" />
                      </Border>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ProjectRoot}" Classes="mono" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- 底部状态条 -->
    <Border
        Grid.Row="1"
        Background="{DynamicResource Ariadne.BackgroundSurface}"
        BorderBrush="{DynamicResource Ariadne.BorderMuted}"
        BorderThickness="0,1,0,0"
        Padding="16,9">
      <TextBlock Text="{Binding StatusText}" Classes="subtle" />
    </Border>
  </Grid>
</UserControl>
