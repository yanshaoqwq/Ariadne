<UserControl
    x:Class="Ariadne.Desktop.Views.WelcomeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="clr-namespace:Ariadne.Desktop.Controls"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:Name="Root"
    x:DataType="vm:WelcomeViewModel">

  <!-- 欢迎页：氛围底 + 左主操作 + 右最近项目，桌面感、大留白 -->
  <Panel>
    <!-- 中性底；欢迎页内容承担视觉主次，不用装饰光斑抢焦点。 -->
    <Border Background="{DynamicResource Ariadne.WindowBase}" />

    <ScrollViewer Grid.Row="0"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
    <Grid Margin="0">
      <Grid
          MaxWidth="1080"
          Margin="48,40"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          ColumnDefinitions="*,36,1.15*"
          MinHeight="420">

        <!-- 左：品牌 + 主操作卡片 -->
        <StackPanel Grid.Column="0" Spacing="28" VerticalAlignment="Center">
          <!-- 品牌区：竖向层次，避免 logo 与标题挤成一行 -->
          <StackPanel Spacing="16">
            <!-- Logo：斜钢笔 + 波浪线；纸底 + 个性化强调色笔画 -->
            <ctl:BrandLogo Width="64" Height="64" OnAccent="False" HorizontalAlignment="Left" />
            <StackPanel Spacing="8">
              <TextBlock Text="{Binding BrandName}"
                         FontSize="34"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource Ariadne.TextHeading}"
                         LetterSpacing="0" />
              <TextBlock Text="{Binding Subtitle}"
                         Classes="secondary"
                         FontSize="15"
                         LineHeight="24"
                         TextWrapping="Wrap"
                         MaxWidth="400" />
              <Border Classes="chip" HorizontalAlignment="Left" Margin="0,4,0,0"
                      Background="{DynamicResource Ariadne.AccentLight}"
                      BorderBrush="{DynamicResource Ariadne.AccentBorder}">
                <TextBlock Text="{Binding HeroTagline}"
                           Classes="caption"
                           Foreground="{DynamicResource Ariadne.AccentPrimary}"
                           FontWeight="SemiBold" />
              </Border>
            </StackPanel>
          </StackPanel>

          <!-- 主操作：双卡，图标 + 标题 + 说明 -->
          <StackPanel Spacing="12">
            <Button Classes="welcome-action primary-action"
                    Command="{Binding CreateProjectCommand}"
                    IsEnabled="{Binding CanStartProjectAction}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Margin="4,2">
                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                        Background="#33FFFFFF" VerticalAlignment="Center">
                  <Path Classes="icon" Width="18" Height="18"
                        Stroke="{DynamicResource Ariadne.TextOnAccent}"
                        Data="M12,5 L12,19 M5,12 L19,12" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                  <TextBlock Text="{Binding CreateProjectText}"
                             FontWeight="SemiBold"
                             FontSize="15"
                             Foreground="{DynamicResource Ariadne.TextOnAccent}" />
                  <TextBlock Text="{Binding CreateProjectHint}"
                             FontSize="12"
                             Opacity="0.88"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource Ariadne.TextOnAccent}" />
                </StackPanel>
              </Grid>
            </Button>

            <Button Classes="welcome-action secondary-action"
                    Command="{Binding OpenProjectCommand}"
                    IsEnabled="{Binding CanStartProjectAction}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Margin="4,2">
                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11"
                        Background="{DynamicResource Ariadne.AccentLight}"
                        VerticalAlignment="Center">
                  <Path Classes="icon" Width="18" Height="18"
                        Stroke="{DynamicResource Ariadne.AccentPrimary}"
                        Data="M4,6 L10,6 L12,8 L20,8 L20,18 L4,18 Z" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                  <TextBlock Text="{Binding OpenProjectText}"
                             FontWeight="SemiBold"
                             FontSize="15"
                             Foreground="{DynamicResource Ariadne.TextPrimary}" />
                  <TextBlock Text="{Binding OpenProjectHint}"
                             Classes="caption"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Grid>
            </Button>
          </StackPanel>

          <Border IsVisible="{Binding HasStatusText}"
                  Background="{DynamicResource Ariadne.BackgroundElevated}"
                  BorderBrush="{DynamicResource Ariadne.BorderMuted}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12,9">
            <TextBlock Text="{Binding StatusText}"
                       Classes="caption"
                       TextWrapping="Wrap"
                       AutomationProperties.LiveSetting="Assertive" />
          </Border>

          <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
            <Button Classes="subtle" Padding="10,6" Content="{Binding TutorialText}" Command="{Binding TutorialCommand}" />
            <Border Width="1" Height="14" Margin="6,0" Background="{DynamicResource Ariadne.BorderMuted}" VerticalAlignment="Center" />
            <Button Classes="subtle" Padding="10,6" Content="{Binding FeedbackText}" Command="{Binding FeedbackCommand}" />
          </StackPanel>
        </StackPanel>

        <!-- 右：最近项目面板 -->
        <Border Grid.Column="2"
                x:Name="RecentProjectsCard"
                Classes="card welcome-recent"
                Padding="0"
                MaxHeight="520"
                VerticalAlignment="Center"
                ClipToBounds="True">
          <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0"
                    Padding="22,18"
                    BorderBrush="{DynamicResource Ariadne.BorderMuted}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource Ariadne.BackgroundElevated}">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <TextBlock Grid.Column="0"
                           Text="{Binding RecentProjectsTitle}"
                           Classes="subtitle"
                           VerticalAlignment="Center" />
                <Border Grid.Column="1"
                        Classes="chip"
                        VerticalAlignment="Center"
                        IsVisible="{Binding HasRecentProjects}"
                        Background="{DynamicResource Ariadne.AccentLight}"
                        BorderBrush="{DynamicResource Ariadne.AccentBorder}"
                        Padding="10,3">
                  <TextBlock FontSize="12"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource Ariadne.AccentPrimary}"
                             Text="{Binding RecentCountText}" />
                </Border>
              </Grid>
            </Border>

            <Panel Grid.Row="1">
              <ScrollViewer IsVisible="{Binding HasRecentProjects}"
                            IsEnabled="{Binding CanStartProjectAction}"
                            Padding="14,12"
                            VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding RecentProjects}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:RecentProjectItemViewModel}">
                      <Button Classes="welcome-recent-item"
                              Command="{Binding OpenCommand}"
                              Margin="0,0,0,8"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch">
                        <Border Classes="layer recent-item" Padding="14,12" CornerRadius="10">
                          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    Width="36"
                                    Height="36"
                                    CornerRadius="10"
                                    Background="{DynamicResource Ariadne.AccentLight}"
                                    VerticalAlignment="Center">
                              <Path Classes="icon" Width="16" Height="16"
                                    Stroke="{DynamicResource Ariadne.AccentPrimary}"
                                    Data="M5,4 L14,4 L19,9 L19,20 L5,20 Z M14,4 L14,9 L19,9 M8,13 L16,13 M8,16 L14,16" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Name}"
                                         FontWeight="SemiBold"
                                         FontSize="14"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Text="{Binding ProjectRoot}"
                                         Classes="mono"
                                         FontSize="11"
                                         Opacity="0.8"
                                         TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Path Grid.Column="2"
                                  Classes="icon"
                                  Width="14" Height="14"
                                  Opacity="0.45"
                                  VerticalAlignment="Center"
                                  Data="{StaticResource Ariadne.Icon.ChevronRight}" />
                          </Grid>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <Border Classes="empty-state" IsVisible="{Binding IsRecentLoading}" Padding="28,48">
                <TextBlock Text="{Binding RecentLoadingText}"
                           Classes="secondary"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
              </Border>

              <Border Classes="empty-state" IsVisible="{Binding IsRecentError}" Padding="28,40">
                <StackPanel Spacing="10" HorizontalAlignment="Center" MaxWidth="300">
                  <TextBlock Text="{Binding RecentErrorText}"
                             Classes="secondary"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             AutomationProperties.LiveSetting="Assertive" />
                  <Button Classes="secondary"
                          Content="{Binding RetryRecentProjectsText}"
                          Command="{Binding RetryRecentProjectsCommand}"
                          HorizontalAlignment="Center" />
                </StackPanel>
              </Border>

              <Border Classes="empty-state" IsVisible="{Binding IsRecentEmpty}" Padding="28,48">
                <StackPanel Spacing="10" HorizontalAlignment="Center" MaxWidth="280">
                  <ctl:EmptyStateArt Kind="WelcomeQuill" Width="140" Height="112" HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding EmptyRecentTitle}"
                             Classes="subtitle"
                             HorizontalAlignment="Center"
                             TextAlignment="Center" />
                  <TextBlock Text="{Binding EmptyRecentHint}"
                             Classes="caption"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             LineHeight="20" />
                </StackPanel>
              </Border>
            </Panel>
          </Grid>
        </Border>
      </Grid>

    </Grid>
    </ScrollViewer>
  </Panel>
</UserControl>
