<UserControl
    x:Class="Ariadne.Desktop.Views.RunLogPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:backend="clr-namespace:Ariadne.Desktop.Backend"
    xmlns:ctl="clr-namespace:Ariadne.Desktop.Controls"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:RunLogPageViewModel">
  <Grid RowDefinitions="52,*" Background="{DynamicResource Ariadne.BackgroundMain}">

    <!-- 顶栏：标题 + 搜索 + 级别筛选 + 刷新 -->
    <Grid
        Grid.Row="0"
        ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
        Background="{DynamicResource Ariadne.BackgroundSurface}"
        Margin="0"
        VerticalAlignment="Stretch">
      <Border Grid.ColumnSpan="6" BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,0,0,1" />
      <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="subtitle" VerticalAlignment="Center" Margin="18,0,0,0" />
      <TextBox Grid.Column="1" Text="{Binding SearchQuery, Mode=TwoWay}" PlaceholderText="{Binding SearchPlaceholder}" MaxWidth="320" HorizontalAlignment="Left" Margin="18,0,8,0" VerticalAlignment="Center" KeyDown="OnSearchKeyDown" />
      <ComboBox Grid.Column="2"
                ItemsSource="{Binding LevelOptions}"
                SelectedValue="{Binding SelectedLevel, Mode=TwoWay}"
                SelectedValueBinding="{Binding Value}"
                MinWidth="110"
                VerticalAlignment="Center"
                Margin="0,0,8,0">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:RunLogLevelOption}">
            <TextBlock Text="{Binding Label}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button Grid.Column="3" Classes="primary" Width="36" Height="32" Padding="0" Command="{Binding SearchCommand}" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip.Tip="{Binding SearchText}">
        <Path Classes="icon" Width="15" Height="15"
              Stroke="{DynamicResource Ariadne.TextOnAccent}"
              Data="{StaticResource Ariadne.Icon.Search}" />
      </Button>
      <Button Grid.Column="4" Classes="secondary" Content="{Binding MarkReadText}" Command="{Binding MarkReadCommand}" VerticalAlignment="Center" Margin="0,0,8,0" />
      <Button Grid.Column="5" Classes="secondary" Content="{Binding RefreshText}" Command="{Binding RefreshCommand}" VerticalAlignment="Center" Margin="0,0,18,0" />
    </Grid>

    <ScrollViewer Grid.Row="1">
      <StackPanel Margin="20,16" Spacing="10">
        <TextBlock Text="{Binding StatusText}" Classes="caption" Opacity="0.9" />
        <ItemsControl ItemsSource="{Binding Logs}" IsVisible="{Binding HasLogs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:RunLogItemViewModel}">
              <Border Classes="layer log-row" Padding="14,11" Margin="0,0,0,8">
                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="12">
                  <TextBlock Grid.Column="0" Text="{Binding TimestampText}" Classes="mono" Width="112" VerticalAlignment="Center" Opacity="0.85" />
                  <Border Grid.Column="1" Classes="chip" Background="{Binding LevelBackground}" Padding="8,2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Level}" Classes="caption" Foreground="{Binding LevelForeground}" FontWeight="SemiBold" />
                  </Border>
                  <TextBlock Grid.Column="2" Text="{Binding Message}" Classes="secondary" VerticalAlignment="Center" TextWrapping="Wrap" LineHeight="20" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Border Classes="empty-state" IsVisible="{Binding IsLogListEmpty}" Margin="0,40,0,0">
          <StackPanel Spacing="8" HorizontalAlignment="Center" MaxWidth="380">
            <ctl:EmptyStateArt Kind="RunLog" Width="140" Height="100" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding EmptyTitle}" Classes="subtitle" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding EmptyHint}" Classes="caption" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
