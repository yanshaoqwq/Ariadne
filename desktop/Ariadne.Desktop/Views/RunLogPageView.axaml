<UserControl
    x:Class="Ariadne.Desktop.Views.RunLogPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:backend="clr-namespace:Ariadne.Desktop.Backend"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:RunLogPageViewModel">
  <Grid RowDefinitions="52,*" Background="{DynamicResource Ariadne.BackgroundMain}">

    <!-- 顶栏：标题 + 搜索 + 级别筛选 + 刷新 -->
    <Grid
        Grid.Row="0"
        ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
        Background="{DynamicResource Ariadne.BackgroundSurface}"
        Margin="0"
        VerticalAlignment="Stretch">
      <Border Grid.ColumnSpan="6" BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,0,0,1" />
      <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="subtitle" VerticalAlignment="Center" Margin="18,0,0,0" />
      <TextBox Grid.Column="1" Text="{Binding SearchQuery, Mode=TwoWay}" PlaceholderText="{Binding SearchPlaceholder}" MaxWidth="320" HorizontalAlignment="Left" Margin="18,0" VerticalAlignment="Center" />
      <ComboBox Grid.Column="2"
                ItemsSource="{Binding LevelOptions}"
                SelectedValue="{Binding SelectedLevel, Mode=TwoWay}"
                SelectedValueBinding="{Binding Value}"
                MinWidth="110"
                VerticalAlignment="Center"
                Margin="0,0,8,0">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="{x:Type vm:RunLogLevelOption}">
            <TextBlock Text="{Binding Label}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button Grid.Column="3" Classes="secondary" Content="{Binding MarkReadText}" Command="{Binding MarkReadCommand}" VerticalAlignment="Center" Margin="0,0,8,0" />
      <Button Grid.Column="4" Classes="secondary" Content="{Binding RefreshText}" Command="{Binding RefreshCommand}" VerticalAlignment="Center" Margin="0,0,18,0" />
    </Grid>

    <ScrollViewer Grid.Row="1">
      <StackPanel Margin="18" Spacing="8">
        <TextBlock Text="{Binding StatusText}" Classes="caption" />
        <ItemsControl ItemsSource="{Binding Logs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type backend:UiRunLogEntry}">
              <Border Classes="layer" Padding="14,10" Margin="0,0,0,8">
                <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                  <TextBlock Grid.Column="0" Text="{Binding TimestampMs}" Classes="mono" Width="112" VerticalAlignment="Center" />
                  <Border Grid.Column="1" Classes="chip">
                    <TextBlock Text="{Binding Level}" Classes="caption" />
                  </Border>
                  <TextBlock Grid.Column="2" Text="{Binding Message}" Classes="secondary" VerticalAlignment="Center" TextWrapping="Wrap" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
