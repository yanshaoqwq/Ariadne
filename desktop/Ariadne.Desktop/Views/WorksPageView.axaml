<UserControl
    x:Class="Ariadne.Desktop.Views.WorksPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:WorksPageViewModel">
  <!-- 作品页：中阅读/修改器 + 右栏（顶部标签切换 导航树/项目 AI，可收起）。无左栏。 -->
  <Grid ColumnDefinitions="*,Auto" Background="{DynamicResource Ariadne.BackgroundMain}">

    <!-- ============ 中：阅读/修改器 ============ -->
    <DockPanel Grid.Column="0">
      <!-- 顶部工具条 -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource Ariadne.BackgroundSurface}" BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,0,0,1" Padding="16,8">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="{Binding CurrentDocumentText}" Classes="body secondary" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <Button Classes="subtle" Padding="10,5" Content="{Binding ReadModeText}" Command="{Binding ReadModeCommand}" />
            <Button Classes="subtle" Padding="10,5" Content="{Binding EditModeText}" Command="{Binding EditModeCommand}" />
            <ComboBox ItemsSource="{Binding ExportFormats}"
                      SelectedValue="{Binding ExportFormat, Mode=TwoWay}"
                      SelectedValueBinding="{Binding Value}"
                      MinWidth="112">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ExportFormatOption}">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Border Width="1" Margin="6,4" Background="{DynamicResource Ariadne.BorderMuted}" />
            <!-- 图标按钮：导入稿件 / 导出合并 / 保存 -->
            <Button Classes="icon-btn" ToolTip.Tip="{Binding ImportText}" Command="{Binding ImportCommand}">
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Import}" />
            </Button>
            <Button Classes="icon-btn" ToolTip.Tip="{Binding ExportText}" Command="{Binding ExportCommand}">
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Export}" />
            </Button>
            <Button Classes="icon-btn save" ToolTip.Tip="{Binding SaveText}" Command="{Binding SaveCommand}">
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Save}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 正文阅读区：居中、限宽、衬线、松行高 -->
      <ScrollViewer Background="{DynamicResource Ariadne.BackgroundMain}">
        <ScrollViewer.ContextMenu>
          <ContextMenu Classes="ariadne">
            <MenuItem Header="{Binding CtxCopyText}" Command="{Binding CopyCommand}" />
            <MenuItem Header="{Binding CtxSelectAllText}" Command="{Binding SelectAllCommand}" />
            <Separator />
            <MenuItem Header="{Binding CtxQuickAiText}" Command="{Binding QuickAiCommand}" />
            <MenuItem Header="{Binding CtxInsertOutlineText}" Command="{Binding InsertOutlineCommand}" />
            <Separator />
            <MenuItem Header="{Binding CtxToggleEditText}" Command="{Binding ToggleEditCommand}" />
          </ContextMenu>
        </ScrollViewer.ContextMenu>
        <Border MaxWidth="760" Margin="0,40" HorizontalAlignment="Center" Classes="card" Padding="56,48">
          <StackPanel Spacing="20">
            <TextBlock Text="{Binding StatusText}" Classes="caption" />
            <TextBox Text="{Binding DocumentContent, Mode=TwoWay}"
                     Classes="reading"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="420"
                     BorderThickness="0"
                     Background="Transparent"
                     PlaceholderText="{Binding QuickAiHint}" />
            <Border Classes="layer" Padding="14">
              <StackPanel Spacing="10">
                <TextBlock Text="{Binding QuickEditTitle}" Classes="subtitle" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <TextBox Grid.Column="0" Text="{Binding QuickEditInstruction, Mode=TwoWay}" PlaceholderText="{Binding QuickEditPlaceholder}" />
                  <Button Grid.Column="1" Classes="secondary" Content="{Binding QuickEditGenerateText}" Command="{Binding QuickAiCommand}" />
                </Grid>
                <TextBlock Text="{Binding QuickEditDiffText}" Classes="caption" />
                <TextBox Text="{Binding QuickEditDiff}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" IsReadOnly="True" />
                <Button Classes="primary" HorizontalAlignment="Right" Content="{Binding QuickEditApplyText}" Command="{Binding ApplyQuickEditCommand}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>
      </ScrollViewer>
    </DockPanel>

    <!-- ============ 右：导航树 / 项目 AI（右上标签切换，可收起） ============ -->
    <Panel Grid.Column="1">
      <Border
          Width="280"
          Background="{DynamicResource Ariadne.BackgroundSurface}"
          BorderBrush="{DynamicResource Ariadne.BorderMuted}"
          BorderThickness="1,0,0,0"
          IsVisible="{Binding IsRightPanelOpen}">
      <DockPanel>
        <!-- 右上标签切换 + 收起键 -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto"
              Background="{DynamicResource Ariadne.BackgroundSurface}"
              Margin="12,8,8,0">
          <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button Classes="tab" Classes.selected="{Binding IsNavTreeTab}"
                    Content="{Binding NavTreeText}" Command="{Binding ShowNavTreeCommand}" />
            <Button Classes="tab" Classes.selected="{Binding IsProjectAiTab}"
                    Content="{Binding ProjectAiText}" Command="{Binding ShowProjectAiCommand}" />
          </StackPanel>
          <Button Grid.Column="1" Classes="panel-collapse" VerticalAlignment="Center"
                  Command="{Binding ToggleRightPanelCommand}" ToolTip.Tip="{Binding ToggleRightPanelText}">
            <Path Classes="icon" Width="16" Height="16" Data="{StaticResource Ariadne.Icon.ChevronRight}" />
          </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Ariadne.BorderMuted}" />

        <!-- 标签内容区：Grid 叠层（天然 Stretch），隐藏的标签不占空间 -->
        <Grid>
          <!-- 标签内容 1：导航树（章节树 + 大纲入口）-->
          <DockPanel IsVisible="{Binding IsNavTreeTab}">
            <Border DockPanel.Dock="Top" Padding="10,10,10,4">
              <Button Classes="subtle" Padding="10,6" HorizontalAlignment="Left" ToolTip.Tip="{Binding OutlineText}" Command="{Binding InsertOutlineCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7">
                  <Path Classes="icon" Width="15" Height="15"
                        Data="M5,4 L14,4 L19,9 L19,20 L5,20 Z M14,4 L14,9 L19,9 M8,13 L16,13 M8,16 L14,16" />
                  <TextBlock Text="{Binding OutlineText}" Classes="caption" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Border>
            <ScrollViewer Margin="8,4">
              <StackPanel Spacing="1">
                <ItemsControl ItemsSource="{Binding WorksTreeNodes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:WorksTreeItemViewModel}">
                      <Button Classes="nav" Command="{Binding OpenCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <TextBlock Text="{Binding DisplayTitle}" Classes="caption" TextWrapping="Wrap" />
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding EmptyIndexText}" Classes="subtle" Margin="12,12,0,0" />
              </StackPanel>
            </ScrollViewer>
          </DockPanel>

          <!-- 标签内容 2：项目 AI -->
          <DockPanel IsVisible="{Binding IsProjectAiTab}">
            <Border DockPanel.Dock="Bottom" Padding="12,8"
                    BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,1,0,0">
              <DockPanel>
                <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                  <Button Grid.Column="1" Classes="primary" Width="34" Height="34" Padding="0"
                          Command="{Binding SendProjectAiCommand}"
                          ToolTip.Tip="{Binding ProjectAiText}">
                    <Path Classes="icon" Width="17" Height="17"
                          Stroke="{DynamicResource Ariadne.TextOnAccent}"
                          Data="M4,12 L20,4 L14,20 L11,13 Z M11,13 L4,12" />
                  </Button>
                </Grid>
                <TextBox MinHeight="60" MaxHeight="120" FontSize="13"
                         Text="{Binding ProjectAiMessage, Mode=TwoWay}"
                         AcceptsReturn="True" TextWrapping="Wrap" BorderThickness="0"
                         Background="Transparent" VerticalContentAlignment="Top"
                         PlaceholderText="{Binding ProjectAiPlaceholder}" />
              </DockPanel>
            </Border>
            <ScrollViewer Margin="12,8">
              <StackPanel Spacing="12">
                <TextBlock Text="{Binding ProjectAiAnswer}" Classes="subtle" TextWrapping="Wrap" />
                <Separator />
                <TextBlock Text="{Binding ProjectMemoryText}" Classes="subtitle" />
                <TextBox Text="{Binding ProjectMemory, Mode=TwoWay}"
                         PlaceholderText="{Binding ProjectMemoryPlaceholder}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="140" />
                <Button Classes="secondary" HorizontalAlignment="Right" Content="{Binding SaveProjectMemoryText}" Command="{Binding SaveProjectMemoryCommand}" />
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Grid>
      </DockPanel>
      </Border>

      <!-- 收起态：右缘悬浮左向箭头 -->
      <Button Classes="panel-float" Command="{Binding ToggleRightPanelCommand}"
              ToolTip.Tip="{Binding ToggleRightPanelText}"
              IsVisible="{Binding !IsRightPanelOpen}">
        <Path Classes="icon" Width="16" Height="16" Data="{StaticResource Ariadne.Icon.ChevronLeft}" />
      </Button>
    </Panel>
  </Grid>
</UserControl>
