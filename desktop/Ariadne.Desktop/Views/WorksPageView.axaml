<UserControl
    x:Class="Ariadne.Desktop.Views.WorksPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="clr-namespace:Ariadne.Desktop.Controls"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:DataType="vm:WorksPageViewModel">
  <!-- 作品页：中阅读/修改器 + 右栏（顶部标签切换 导航树/项目 AI，可收起）。无左栏。 -->
  <Grid Background="{DynamicResource Ariadne.BackgroundMain}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="{Binding RightPanelSplitterWidth}" />
      <ColumnDefinition Width="{Binding RightPanelColumnWidth, Mode=TwoWay}" MinWidth="24" MaxWidth="520" />
    </Grid.ColumnDefinitions>

    <!-- ============ 中：阅读/修改器 ============ -->
    <DockPanel Grid.Column="0">
      <!-- 顶部工具条 -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource Ariadne.BackgroundSurface}" BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,0,0,1" Padding="16,8">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="{Binding CurrentDocumentText}" Classes="body secondary" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
            <Button Classes="subtle" ctl:SelectedClass.IsSelected="{Binding !IsEditMode}" Padding="10,5" Content="{Binding ReadModeText}" Command="{Binding ReadModeCommand}" />
            <Button Classes="subtle" ctl:SelectedClass.IsSelected="{Binding IsEditMode}" Padding="10,5" Content="{Binding EditModeText}" Command="{Binding EditModeCommand}" />
            <ComboBox ItemsSource="{Binding ExportFormats}"
                      SelectedValue="{Binding ExportFormat, Mode=TwoWay}"
                      SelectedValueBinding="{Binding Value}"
                      MinWidth="112">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ExportFormatOption}">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Border Width="1" Margin="6,4" Background="{DynamicResource Ariadne.BorderMuted}" />
            <!-- 图标按钮：导入稿件 / 导出合并 / 保存 -->
            <Button Classes="icon-btn" ToolTip.Tip="{Binding ImportText}" AutomationProperties.Name="{Binding ImportText}" Command="{Binding OpenImportPanelCommand}">
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Import}" />
            </Button>
            <Button Classes="icon-btn" ToolTip.Tip="{Binding ExportText}" AutomationProperties.Name="{Binding ExportText}" Command="{Binding ExportCommand}">
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Export}" />
            </Button>
            <Button Classes="icon-btn save" ToolTip.Tip="{Binding SaveText}" AutomationProperties.Name="{Binding SaveText}" Command="{Binding SaveCommand}">
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Save}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 正文阅读/编辑区：按块虚拟化渲染，避免整章 TextBox 常驻。 -->
      <Grid Background="{DynamicResource Ariadne.EditorBackground}">
        <Grid.ContextMenu>
          <ContextMenu Classes="ariadne">
            <MenuItem Header="{Binding CtxCopyText}" Command="{Binding CopyCommand}" />
            <MenuItem Header="{Binding CtxSelectAllText}" Command="{Binding SelectAllCommand}" />
            <Separator />
            <MenuItem Header="{Binding CtxQuickAiText}" Command="{Binding QuickAiCommand}" />
            <MenuItem Header="{Binding CtxInsertOutlineText}" Command="{Binding InsertOutlineCommand}" />
            <Separator />
            <MenuItem Header="{Binding CtxToggleEditText}" Command="{Binding ToggleEditCommand}" />
          </ContextMenu>
        </Grid.ContextMenu>
        <Grid MaxWidth="1180" Margin="40,30,40,44" HorizontalAlignment="Stretch" RowDefinitions="Auto,*" RowSpacing="18">
          <!-- 作品树空：二次元打响指全幅空态，不露出编辑器壳 -->
          <Border Grid.Row="0" Grid.RowSpan="2" Classes="empty-state"
                  IsVisible="{Binding IsWorksTreeEmpty}"
                  VerticalAlignment="Center" HorizontalAlignment="Center"
                  Padding="40,48">
            <StackPanel Spacing="14" HorizontalAlignment="Center" MaxWidth="360">
              <ctl:EmptyStateArt Kind="WorksSnap" Width="160" Height="128" HorizontalAlignment="Center" />
              <TextBlock Text="{Binding EmptyIndexTitle}" Classes="title" HorizontalAlignment="Center" TextAlignment="Center" />
              <TextBlock Text="{Binding EmptyIndexHint}" Classes="caption" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
              <TextBlock Text="{Binding EmptyIndexText}" Classes="subtle" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
              <Button Classes="primary" HorizontalAlignment="Center" Margin="0,8,0,0"
                      Content="{Binding ImportText}" Command="{Binding OpenImportPanelCommand}" />
            </StackPanel>
          </Border>

          <!-- 有索引但未选文档：单一空态，不重复「未选择」与文档壳（U72） -->
          <Border Grid.Row="0" Grid.RowSpan="2" Classes="empty-state"
                  IsVisible="{Binding ShowNoDocumentEmpty}"
                  VerticalAlignment="Center" HorizontalAlignment="Center"
                  Padding="40,48">
            <StackPanel Spacing="10" HorizontalAlignment="Center" MaxWidth="360">
              <ctl:EmptyStateArt Kind="WorksSnap" Width="140" Height="112" HorizontalAlignment="Center" />
              <TextBlock Text="{Binding NoDocumentText}" Classes="subtitle" HorizontalAlignment="Center" TextAlignment="Center" />
              <TextBlock Text="{Binding EmptyIndexHint}" Classes="caption" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border Grid.Row="0"
                  Classes="document-header"
                  Padding="28,18"
                  IsVisible="{Binding ShowDocumentChrome}">
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="18">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DocumentTitle}" Classes="title" TextWrapping="Wrap" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CharacterCountText}" Classes="caption" VerticalAlignment="Center" />
              <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding DocumentInfoText}" Classes="caption" TextWrapping="Wrap" />
              <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding StatusText}" Classes="caption" TextWrapping="Wrap" />
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Classes="document-surface"
                  Padding="64,52"
                  IsVisible="{Binding ShowDocumentChrome}">
            <Grid RowDefinitions="*,Auto" RowSpacing="24" MinHeight="640">
              <TextBlock Grid.Row="0"
                         Text="{Binding DocumentBodyText}"
                         Classes="reading"
                         IsVisible="{Binding !HasDocumentBlocks}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
              <ListBox Grid.Row="0"
                       ItemsSource="{Binding DocumentBlocks}"
                       IsVisible="{Binding !IsEditMode}"
                       Background="Transparent"
                       BorderThickness="0"
                       SelectionMode="Single">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:DocumentBlockViewModel}">
                    <SelectableTextBlock Text="{Binding Text}"
                                         Classes="reading"
                                         Margin="0,0,0,18" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <ListBox x:Name="DocumentEditor"
                       Grid.Row="0"
                       ItemsSource="{Binding DocumentBlocks}"
                       IsVisible="{Binding IsEditMode}"
                       Background="Transparent"
                       BorderThickness="0"
                       SelectionMode="Single">
                <ListBox.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                  </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:DocumentBlockViewModel}">
                    <TextBox Text="{Binding Text, Mode=TwoWay}"
                             Classes="document-editor"
                             KeyDown="OnDocumentBlockEditorKeyDown"
                             KeyUp="OnDocumentBlockEditorKeyUp"
                             GotFocus="OnDocumentBlockEditorGotFocus"
                             LostFocus="OnDocumentBlockEditorLostFocus"
                             PointerReleased="OnDocumentBlockEditorPointerReleased"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="96"
                             BorderThickness="0"
                             Background="Transparent"
                             Margin="0,0,0,18"
                             PlaceholderText="{Binding $parent[UserControl].DataContext.QuickAiHint}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <Border Grid.Row="1" Classes="soft-panel" Padding="16" IsVisible="{Binding IsEditMode}">
                <StackPanel Spacing="12">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Grid.Column="0" Text="{Binding QuickEditTitle}" Classes="subtitle" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="secondary" Content="{Binding QuickEditGenerateText}" Command="{Binding QuickAiCommand}" />
                  </Grid>
                  <TextBox Text="{Binding QuickEditInstruction, Mode=TwoWay}" PlaceholderText="{Binding QuickEditPlaceholder}" />
                  <TextBlock Text="{Binding QuickEditDiffText}" Classes="caption" />
                  <TextBox Text="{Binding QuickEditDiff}"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           MinHeight="110"
                           MaxHeight="280"
                           IsReadOnly="True" />
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Classes="secondary" Content="{Binding QuickEditUndoText}" Command="{Binding UndoQuickEditCommand}" />
                    <Button Classes="primary" Content="{Binding QuickEditApplyText}" Command="{Binding ApplyQuickEditCommand}" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </DockPanel>

    <!-- ============ 右：导航树 / 项目 AI（右上标签切换，可收起） ============ -->
    <GridSplitter Grid.Column="1"
                  Width="4"
                  Background="{DynamicResource Ariadne.BorderMuted}"
                  ResizeDirection="Columns"
                  IsVisible="{Binding IsRightPanelOpen}" />

    <Panel Grid.Column="2">
      <Border
          Background="{DynamicResource Ariadne.BackgroundSurface}"
          BorderBrush="{DynamicResource Ariadne.BorderMuted}"
          BorderThickness="1,0,0,0"
          IsVisible="{Binding IsRightPanelOpen}">
      <DockPanel>
        <!-- 右上标签切换 + 收起键 -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto"
              Background="{DynamicResource Ariadne.BackgroundSurface}"
              Margin="12,8,8,0">
          <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button Classes="tab" ctl:SelectedClass.IsSelected="{Binding IsNavTreeTab}"
                    Content="{Binding NavTreeText}" Command="{Binding ShowNavTreeCommand}" />
            <Button Classes="tab" ctl:SelectedClass.IsSelected="{Binding IsProjectAiTab}"
                    Content="{Binding ProjectAiText}" Command="{Binding ShowProjectAiCommand}" />
          </StackPanel>
          <Button Grid.Column="1" Classes="panel-collapse" VerticalAlignment="Center"
                  Command="{Binding ToggleRightPanelCommand}" ToolTip.Tip="{Binding ToggleRightPanelText}" AutomationProperties.Name="{Binding ToggleRightPanelText}">
            <Path Classes="icon" Width="16" Height="16" Data="{StaticResource Ariadne.Icon.ChevronRight}" />
          </Button>
        </Grid>
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Ariadne.BorderMuted}" />

        <!-- 标签内容区：Grid 叠层（天然 Stretch），隐藏的标签不占空间 -->
        <Grid>
          <!-- 标签内容 1：导航树（章节树 + 大纲入口）-->
          <DockPanel IsVisible="{Binding IsNavTreeTab}">
            <Border DockPanel.Dock="Top" Padding="10,10,10,4">
              <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="subtle" Padding="10,6" ToolTip.Tip="{Binding OutlineText}" AutomationProperties.Name="{Binding OutlineText}" Command="{Binding InsertOutlineCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                      <Path Classes="icon" Width="15" Height="15"
                            Data="M5,4 L14,4 L19,9 L19,20 L5,20 Z M14,4 L14,9 L19,9 M8,13 L16,13 M8,16 L14,16" />
                      <TextBlock Text="{Binding OutlineText}" Classes="caption" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                  <Button Classes="subtle" Padding="10,6" Content="{Binding ImportText}" Command="{Binding ToggleImportPanelCommand}" />
                </StackPanel>
                <Border Classes="layer" Padding="12" IsVisible="{Binding IsImportPanelOpen}">
                  <StackPanel Spacing="8">
                    <TextBlock Text="{Binding ImportTitle}" Classes="subtitle" />
                    <TextBox Text="{Binding ImportChapterId, Mode=TwoWay}" PlaceholderText="{Binding ImportChapterIdText}" />
                    <TextBox Text="{Binding ImportChapterTitle, Mode=TwoWay}" PlaceholderText="{Binding ImportChapterTitleText}" />
                    <TextBox Text="{Binding ImportOrder, Mode=TwoWay}" PlaceholderText="{Binding ImportOrderText}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBox Grid.Column="0" Text="{Binding ImportSourcePath, Mode=TwoWay}" PlaceholderText="{Binding ImportSourcePlaceholder}" />
                      <Button Grid.Column="1" Classes="secondary" Content="{Binding BrowseImportSourceText}" Command="{Binding BrowseImportSourceCommand}" />
                    </Grid>
                    <TextBox Text="{Binding ImportTargetPath, Mode=TwoWay}" PlaceholderText="{Binding ImportTargetPlaceholder}" />
                    <Button Classes="primary" HorizontalAlignment="Right" Content="{Binding ImportText}" Command="{Binding ImportCommand}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
            <ScrollViewer Margin="8,4">
              <StackPanel Spacing="8">
                <!-- F19：正式总结投影。加载失败与合法空态分开，确认历史不混入正式知识。 -->
                <Border Classes="layer" Padding="12" IsVisible="{Binding HasSummaryContext}">
                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBlock Grid.Column="0" Text="{Binding SummaryTitle}" Classes="subtitle" />
                      <TextBlock Grid.Column="1" Text="{Binding SummaryChapterHeading}" Classes="subtle" />
                    </Grid>

                    <TextBlock Text="{Binding SummaryLoadingText}"
                               Classes="caption"
                               IsVisible="{Binding IsSummaryLoading}" />
                    <Border Classes="soft-panel" Padding="10" IsVisible="{Binding HasSummaryError}">
                      <TextBlock Text="{Binding SummaryErrorText}" Classes="caption" TextWrapping="Wrap" />
                    </Border>
                    <TextBlock Text="{Binding SummaryEmptyText}"
                               Classes="caption"
                               TextWrapping="Wrap"
                               IsVisible="{Binding ShowSummaryEmpty}" />

                    <StackPanel Spacing="8" IsVisible="{Binding ShowSummaryContent}">
                      <Border Classes="soft-panel" Padding="10" IsVisible="{Binding HasActiveSummarySegment}">
                        <TextBlock Text="{Binding ActiveSummarySegmentText}" Classes="caption" TextWrapping="Wrap" />
                      </Border>

                      <Border Classes="soft-panel" Padding="10" IsVisible="{Binding HasChapterSummary}">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding ChapterSummaryLabel}" Classes="caption" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding ChapterSummaryText}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>

                      <Border Classes="soft-panel" Padding="10" IsVisible="{Binding HasStageSummary}">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding StageSummaryLabel}" Classes="caption" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding SummaryStageHeading}" Classes="subtle" />
                          <TextBlock Text="{Binding StageSummaryText}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>

                      <Expander Header="{Binding SummarySegmentsLabel}"
                                IsExpanded="True"
                                IsVisible="{Binding HasSummarySegments}">
                        <ItemsControl ItemsSource="{Binding SummarySegments}" Margin="0,6,0,0">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:WorksSummarySegmentItemViewModel}">
                              <Button Classes="nav"
                                      ctl:SelectedClass.IsSelected="{Binding IsSelected}"
                                      Command="{Binding RevealCommand}"
                                      ToolTip.Tip="{Binding RevealText}"
                                      AutomationProperties.Name="{Binding RevealText}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Margin="0,0,0,4">
                                <StackPanel Spacing="3">
                                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="caption" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding SourceStateText}" Classes="subtle" />
                                  </Grid>
                                  <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                                  <TextBlock Text="{Binding SourceText}" Classes="subtle" TextWrapping="Wrap" />
                                </StackPanel>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Expander>

                      <Expander Header="{Binding SummaryEventsLabel}"
                                IsExpanded="True"
                                IsVisible="{Binding HasSummaryEvents}">
                        <ItemsControl ItemsSource="{Binding SummaryEvents}" Margin="0,6,0,0">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:WorksSummaryDetailItemViewModel}">
                              <Border Classes="soft-panel" Padding="9" Margin="0,0,0,4">
                                <StackPanel Spacing="3">
                                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="caption" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" Classes="subtle" />
                                  </Grid>
                                  <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Expander>

                      <Expander Header="{Binding SummaryChangesLabel}"
                                IsExpanded="True"
                                IsVisible="{Binding HasSummaryChanges}">
                        <ItemsControl ItemsSource="{Binding SummaryChanges}" Margin="0,6,0,0">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:WorksSummaryDetailItemViewModel}">
                              <Border Classes="soft-panel" Padding="9" Margin="0,0,0,4">
                                <StackPanel Spacing="3">
                                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="caption" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" Classes="subtle" />
                                  </Grid>
                                  <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Expander>

                      <Expander Header="{Binding SummaryForeshadowingLabel}"
                                IsExpanded="True"
                                IsVisible="{Binding HasSummaryForeshadowing}">
                        <ItemsControl ItemsSource="{Binding SummaryForeshadowing}" Margin="0,6,0,0">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:WorksSummaryDetailItemViewModel}">
                              <Border Classes="soft-panel" Padding="9" Margin="0,0,0,4">
                                <StackPanel Spacing="3">
                                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="caption" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" Classes="subtle" />
                                  </Grid>
                                  <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Expander>

                      <Expander Header="{Binding SummaryConfirmationsLabel}"
                                IsExpanded="False"
                                IsVisible="{Binding HasSummaryConfirmations}">
                        <ItemsControl ItemsSource="{Binding SummaryConfirmations}" Margin="0,6,0,0">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:WorksSummaryDetailItemViewModel}">
                              <Border Classes="soft-panel" Padding="9" Margin="0,0,0,4">
                                <StackPanel Spacing="3">
                                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="caption" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" Classes="subtle" />
                                  </Grid>
                                  <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Expander>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding WorksTreeNodes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:WorksTreeItemViewModel}">
                      <Button Classes="nav" Command="{Binding OpenCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                          <TextBlock Grid.Row="0" Text="{Binding DisplayTitle}" Classes="caption" TextWrapping="Wrap" />
                          <TextBlock Grid.Row="1" Text="{Binding DisplayPath}" Classes="subtle" TextWrapping="Wrap" IsVisible="{Binding HasPath}" />
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- 侧栏索引空：主栏已有打响指全幅空态，此处只保留短提示 -->
                <Border Classes="empty-state" Padding="12,16" IsVisible="{Binding IsWorksTreeEmpty}">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding EmptyIndexTitle}" Classes="subtitle" />
                    <TextBlock Text="{Binding EmptyIndexHint}" Classes="caption" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </DockPanel>

          <!-- 标签内容 2：项目 AI -->
          <DockPanel IsVisible="{Binding IsProjectAiTab}">
            <Border DockPanel.Dock="Bottom" Padding="12,10"
                    BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,1,0,0">
              <!-- 与工作区共用 ProjectAiComposer（主题色焦点边仅此一体区） -->
              <ctl:ProjectAiComposer />
            </Border>
            <ScrollViewer Margin="12,8">
              <StackPanel Spacing="10">
                <TextBlock Text="{Binding ProjectAiAnswer}"
                           Classes="subtle"
                           TextWrapping="Wrap"
                           IsVisible="{Binding !HasProjectAiBubbles}" />
                <ItemsControl ItemsSource="{Binding ProjectAiBubbles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ChatBubbleViewModel}">
                      <Border Background="{Binding BubbleBackground}"
                              BorderBrush="{DynamicResource Ariadne.BorderMuted}"
                              BorderThickness="1"
                              CornerRadius="10"
                              Padding="12,8"
                              HorizontalAlignment="{Binding HorizontalAlignment}"
                              MaxWidth="320"
                              Margin="0,0,0,6">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding RoleLabel}" Classes="subtle" FontSize="11" />
                          <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="13" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Grid>
      </DockPanel>
      </Border>

      <!-- 收起态：右缘悬浮左向箭头 -->
      <Button Classes="panel-float" Command="{Binding ToggleRightPanelCommand}"
              ToolTip.Tip="{Binding ToggleRightPanelText}" AutomationProperties.Name="{Binding ToggleRightPanelText}"
              IsVisible="{Binding !IsRightPanelOpen}">
        <Path Classes="icon" Width="16" Height="16" Data="{StaticResource Ariadne.Icon.ChevronLeft}" />
      </Button>
    </Panel>
  </Grid>
</UserControl>
