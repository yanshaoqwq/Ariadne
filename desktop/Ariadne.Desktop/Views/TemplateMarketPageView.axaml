<UserControl
    x:Class="Ariadne.Desktop.Views.TemplateMarketPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:Name="Root"
    x:DataType="vm:TemplateMarketPageViewModel">
  <Grid RowDefinitions="52,*" Background="{DynamicResource Ariadne.BackgroundMain}">

    <!-- 顶栏 -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Background="{DynamicResource Ariadne.BackgroundSurface}">
      <Border Grid.ColumnSpan="3" BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,0,0,1" />
      <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="subtitle" VerticalAlignment="Center" Margin="18,0,0,0" />
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,18,0">
        <TextBlock Text="{Binding OnlineSearchText}" Classes="subtle" VerticalAlignment="Center" />
      </StackPanel>
    </Grid>

    <ScrollViewer Grid.Row="1">
      <StackPanel MaxWidth="1040" Margin="32,28">

        <!-- 搜索栏：600px 固定宽度居中，右侧搜索键 -->
        <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch" ColumnSpacing="8">
          <TextBox Grid.Column="0"
              Text="{Binding SearchQuery, Mode=TwoWay}"
              PlaceholderText="{Binding SearchPlaceholder}"
              MinHeight="48"
              FontSize="16" />
          <Button Grid.Column="1" Classes="primary" Width="52" Height="48" Padding="0"
                  Command="{Binding SearchCommand}"
                  ToolTip.Tip="{Binding SearchText}">
            <Path Classes="icon" Width="20" Height="20"
                  Stroke="{DynamicResource Ariadne.TextOnAccent}"
                  Data="{StaticResource Ariadne.Icon.Search}" />
          </Button>
        </Grid>

        <ItemsControl ItemsSource="{Binding Tags}" HorizontalAlignment="Center" Margin="0,16,0,24">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:TemplateTagViewModel}">
              <Button Classes="subtle" Margin="4" Padding="0" Command="{Binding SelectCommand}">
                <Border Classes="chip">
                  <TextBlock Text="{Binding Title}" Classes="caption" />
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl ItemsSource="{Binding Templates}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="3" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:TemplateCardViewModel}">
              <Border Classes="card" Margin="8" Padding="18" MinHeight="168">
                <DockPanel>
                  <StackPanel DockPanel.Dock="Top" Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding Name}" Classes="subtitle" />
                      <Border Grid.Column="1" Classes="chip" Background="{DynamicResource Ariadne.AccentLight}" IsVisible="{Binding RequiresPermissions}">
                        <TextBlock Text="{Binding #Root.DataContext.PermissionText}" Classes="caption" Foreground="{DynamicResource Ariadne.AccentPrimary}" />
                      </Border>
                    </Grid>
                    <TextBlock Text="{Binding Id}" Classes="mono" />
                    <TextBlock Text="{Binding TagsText}" Classes="caption" TextWrapping="Wrap" />
                  </StackPanel>
                  <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Classes="secondary" Content="{Binding #Root.DataContext.DetailText}" Command="{Binding ShowDetailsCommand}" />
                    <Button Classes="primary" Content="{Binding #Root.DataContext.ImportText}" Command="{Binding InstallCommand}" />
                  </StackPanel>
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 空态说明 -->
        <Border Classes="layer" Padding="32" Margin="8,16" HorizontalAlignment="Stretch">
          <TextBlock Text="{Binding StatusText}" Classes="secondary" HorizontalAlignment="Center" />
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,8">
          <Button Classes="secondary" Content="{Binding LoadMoreText}" Command="{Binding LoadMoreCommand}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
