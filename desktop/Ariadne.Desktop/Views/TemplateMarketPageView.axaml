<UserControl
    x:Class="Ariadne.Desktop.Views.TemplateMarketPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="clr-namespace:Ariadne.Desktop.Controls"
    xmlns:vm="clr-namespace:Ariadne.Desktop.ViewModels"
    x:Name="Root"
    x:DataType="vm:TemplateMarketPageViewModel"
    Loaded="OnLoaded">
  <Grid RowDefinitions="52,*" Background="{DynamicResource Ariadne.BackgroundMain}">

    <!-- 顶栏：标题 + 在线检索状态芯片（避免右上角孤儿 subtle 文案） -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Background="{DynamicResource Ariadne.BackgroundSurface}">
      <Border Grid.ColumnSpan="3" BorderBrush="{DynamicResource Ariadne.BorderMuted}" BorderThickness="0,0,0,1" />
      <TextBlock Grid.Column="0" Text="{Binding Title}" Classes="subtitle" VerticalAlignment="Center" Margin="18,0,0,0" />
      <Border Grid.Column="2"
              Classes="chip"
              VerticalAlignment="Center"
              Margin="0,0,18,0"
              Background="{DynamicResource Ariadne.BackgroundSubtle}"
              BorderBrush="{DynamicResource Ariadne.BorderMuted}">
        <TextBlock Text="{Binding OnlineSearchText}"
                   Classes="caption"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Ariadne.TextSecondary}" />
      </Border>
    </Grid>

    <ScrollViewer Grid.Row="1">
      <StackPanel MaxWidth="1040" Margin="32,28">

        <!-- 一体搜索壳：左侧提示图标 + 输入 + 右侧提交，居中限宽 -->
        <Border Classes="search-shell"
                MaxWidth="560"
                HorizontalAlignment="Center">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Path Grid.Column="0"
                  Classes="icon"
                  Width="16"
                  Height="16"
                  Margin="10,0,2,0"
                  Opacity="0.55"
                  Data="{StaticResource Ariadne.Icon.Search}"
                  IsHitTestVisible="False" />
            <TextBox Grid.Column="1"
                     Classes="search-input"
                     Text="{Binding SearchQuery, Mode=TwoWay}"
                     PlaceholderText="{Binding SearchPlaceholder}"
                     AutomationProperties.Name="{Binding SearchPlaceholder}" />
            <Button Grid.Column="2"
                    Classes="search-submit"
                    Command="{Binding SearchCommand}"
                    ToolTip.Tip="{Binding SearchText}"
                    AutomationProperties.Name="{Binding SearchText}">
              <Path Classes="icon" Data="{StaticResource Ariadne.Icon.Search}" />
            </Button>
          </Grid>
        </Border>

        <ItemsControl ItemsSource="{Binding Tags}"
                      IsEnabled="{Binding CanInteract}"
                      HorizontalAlignment="Center"
                      Margin="0,18,0,26">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:TemplateTagViewModel}">
              <Button Classes="chip-filter"
                      Margin="0,0,8,8"
                      Padding="12,6"
                      Command="{Binding SelectCommand}"
                      Content="{Binding Title}"
                      AutomationProperties.Name="{Binding Title}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl ItemsSource="{Binding Templates}"
                      IsVisible="{Binding HasResults}"
                      IsEnabled="{Binding CanInteract}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="3" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:TemplateCardViewModel}">
              <Border Classes="card" Margin="8" Padding="16" MinHeight="160">
                <DockPanel>
                  <StackPanel DockPanel.Dock="Top" Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="{Binding Name}" Classes="subtitle" TextTrimming="CharacterEllipsis" />
                      <Border Grid.Column="1" Classes="chip" Background="{DynamicResource Ariadne.AccentLight}" IsVisible="{Binding RequiresPermissions}">
                        <TextBlock Text="{Binding #Root.DataContext.PermissionText}" Classes="caption" Foreground="{DynamicResource Ariadne.AccentPrimary}" />
                      </Border>
                    </Grid>
                    <TextBlock Text="{Binding Id}" Classes="mono" Opacity="0.85" />
                    <TextBlock Text="{Binding TagsText}" Classes="caption" TextWrapping="Wrap" Opacity="0.9" />
                  </StackPanel>
                  <StackPanel DockPanel.Dock="Bottom"
                              Orientation="Horizontal"
                              Spacing="8"
                              HorizontalAlignment="Right"
                              Margin="0,14,0,0">
                    <Button Classes="secondary btn-compact"
                            Content="{Binding #Root.DataContext.DetailText}"
                            Command="{Binding ShowDetailsCommand}" />
                    <Button Classes="primary btn-compact"
                            Content="{Binding #Root.DataContext.ImportText}"
                            Command="{Binding InstallCommand}" />
                  </StackPanel>
                </DockPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Classes="empty-state"
                IsVisible="{Binding IsLoading}"
                Margin="8,24"
                HorizontalAlignment="Stretch">
          <TextBlock Text="{Binding LoadingText}"
                     Classes="secondary"
                     HorizontalAlignment="Center"
                     AutomationProperties.LiveSetting="Polite" />
        </Border>

        <Border Classes="empty-state"
                IsVisible="{Binding IsEmpty}"
                Margin="8,24"
                HorizontalAlignment="Stretch">
          <StackPanel Spacing="8" HorizontalAlignment="Center" MaxWidth="400">
            <ctl:EmptyStateArt Kind="Templates" Width="140" Height="100" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding EmptyText}"
                       Classes="secondary"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Classes="empty-state"
                IsVisible="{Binding IsError}"
                Margin="8,24"
                HorizontalAlignment="Stretch">
          <StackPanel Spacing="10" HorizontalAlignment="Center" MaxWidth="420">
            <TextBlock Text="{Binding StatusText}"
                       Classes="secondary"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       AutomationProperties.LiveSetting="Assertive" />
            <Button Classes="secondary"
                    Content="{Binding RetryText}"
                    Command="{Binding SearchCommand}"
                    HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border Classes="empty-state"
                IsVisible="{Binding IsEndOfList}"
                Margin="8,18"
                HorizontalAlignment="Stretch">
          <TextBlock Text="{Binding EndOfListText}"
                     Classes="caption"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,8">
          <Button Classes="secondary"
                  IsVisible="{Binding IsLoadMoreVisible}"
                  IsEnabled="{Binding CanLoadMore}"
                  Content="{Binding LoadMoreText}"
                  Command="{Binding LoadMoreCommand}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
